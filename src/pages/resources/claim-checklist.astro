---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

const contactHref = `/#contact`;

// 12-point claim-readiness checklist (RU). Based on the Claim Readiness tool.
const checklist = [
  ['Уведомление в срок', 'Notice подан в течение 28 дней с момента, когда сторона узнала или должна была узнать о событии (Sub-Clause 20.2.1).'],
  ['Форма уведомления', 'Соблюдён формальный порядок: правильный адресат, письменная форма, ссылка на соответствующий пункт контракта.'],
  ['Отдельный event file', 'По событию открыт отдельный файл: хронология, письма, инструкции, RFI, протоколы совещаний, фотографии.'],
  ['Contemporary records', 'Ведутся ежедневные/еженедельные записи во время события, а не восстановленные задним числом.'],
  ['Причинно-следственная связь', 'Установлена цепочка: событие → последствие → задержка и/или затраты. Без «широких» claim без связи.'],
  ['Разделение последствий', 'Delay (EOT), disruption и prolongation costs разделены, а не смешаны в одну сумму.'],
  ['Договорное основание', 'Указаны конкретные пункты контракта и Particular Conditions, дающие право на claim.'],
  ['Вид relief', 'Чётко определено, что требуется: продление срока (EOT), дополнительная оплата, или и то и другое.'],
  ['Анализ задержки', 'Для EOT выполнен delay analysis по программе работ с оценкой влияния на критический путь.'],
  ['Обоснование затрат', 'Суммы подтверждены первичными документами: счета, табели, расчёты, котировки.'],
  ['Промежуточные сроки', 'Соблюдён срок fully detailed claim — 84 дня (Sub-Clause 20.2.4) или иной по контракту.'],
  ['Актуальная версия', 'Проверена действующая редакция контракта и приложений; формулировки адаптированы под проект.'],
];
---

<Layout
  title="Бесплатный чеклист: готовность FIDIC-claim — FIDIC.uz"
  description="Скачайте бесплатный чеклист из 12 пунктов: как подготовить FIDIC-claim, который пройдёт проверку. От экспертов Bridge Consult."
>
  <section class="lm-hero">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center md:px-8 md:py-24">
      <p class="lm-eyebrow">Бесплатный материал · PDF</p>
      <h1 class="lm-title">Чеклист готовности FIDIC-claim</h1>
      <p class="lm-lead">
        12 пунктов, по которым эксперт проверяет claim перед подачей: уведомления, сроки,
        contemporary records, причинно-следственная связь, обоснование затрат.
        Оставьте контакт — откроем чеклист и пришлём его вам.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-24 md:px-8">
    <div class="lm-card">
      <!-- Gate form -->
      <form id="lm-form" class="lm-form">
        <p class="lm-form__title">Получить чеклист бесплатно</p>
        <div class="lm-field">
          <label for="lm-name">Имя</label>
          <input id="lm-name" name="name" type="text" autocomplete="name" placeholder="Ваше имя" required />
        </div>
        <div class="lm-field">
          <label for="lm-contact">Телефон / Telegram / email</label>
          <input id="lm-contact" name="contact" type="text" autocomplete="email" placeholder="+998 ... / @username" required />
        </div>
        <button type="submit" class="btn btn-primary w-full justify-center">Открыть чеклист →</button>
        <p class="lm-note">Отправляя форму, вы соглашаетесь, что с вами может связаться команда Bridge Consult.</p>
      </form>

      <!-- Revealed after submit -->
      <div id="lm-result" class="lm-result" hidden>
        <div class="lm-result__head no-print">
          <p class="lm-result__ok">✓ Готово! Чеклист открыт ниже.</p>
          <button type="button" class="btn btn-ghost" data-lm-print>Печать / Сохранить PDF</button>
        </div>

        <article class="lm-doc">
          <header class="lm-doc__head">
            <p class="lm-doc__brand">FIDIC<span>.uz</span> · Bridge Consult</p>
            <h2>Чеклист готовности FIDIC-claim</h2>
            <p class="lm-doc__sub">12 пунктов проверки перед подачей претензии по контрактам FIDIC (издания 2017).</p>
          </header>
          <ol class="lm-list">
            {checklist.map(([title, desc]) => (
              <li>
                <span class="lm-list__check" aria-hidden="true"></span>
                <div>
                  <p class="lm-list__title">{title}</p>
                  <p class="lm-list__desc">{desc}</p>
                </div>
              </li>
            ))}
          </ol>
          <footer class="lm-doc__foot">
            <p>Нужна экспертная проверка вашего claim? <a href={contactHref}>Оставьте заявку</a> или напишите в Telegram {site.contacts.telegramHandle}.</p>
            <p class="lm-doc__disc">Справочный материал, не является юридическим заключением. © {new Date().getFullYear()} {site.poweredBy}.</p>
          </footer>
        </article>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function () {
    var form = document.getElementById('lm-form');
    var result = document.getElementById('lm-result');
    if (!form || !result) return;

    var printBtn = document.querySelector('[data-lm-print]');
    if (printBtn) printBtn.addEventListener('click', function () { window.print(); });

    function reveal() {
      form.setAttribute('hidden', '');
      result.removeAttribute('hidden');
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (window.gtag) window.gtag('event', 'lead_magnet_unlock', { event_category: 'lead', magnet: 'claim-checklist' });
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = (document.getElementById('lm-name').value || '').trim();
      var contact = (document.getElementById('lm-contact').value || '').trim();
      if (!name || !contact) return;

      var payload = {
        name: name,
        contact: contact,
        topic: 'Лид-магнит: чеклист готовности claim',
        message: 'Запросил(а) бесплатный чеклист готовности FIDIC-claim.',
        source: 'lead-magnet/claim-checklist',
      };
      // Capture the lead, then always reveal (don't block the user on errors).
      fetch('/api/lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(reveal, reveal);
    });
  })();
</script>

<style>
  .lm-hero {
    background:
      radial-gradient(circle at 80% 10%, rgba(201, 164, 92, 0.14), transparent 30rem),
      radial-gradient(circle at 12% 90%, rgba(91, 140, 255, 0.1), transparent 32rem);
  }
  .lm-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brass);
  }
  .lm-title {
    margin-top: 0.7rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 3.4rem);
    line-height: 1.05;
    color: var(--color-fg);
  }
  .lm-lead {
    margin: 1.1rem auto 0;
    max-width: 40rem;
    color: var(--color-fg-dim);
    line-height: 1.65;
  }

  .lm-card {
    border: 1px solid color-mix(in oklab, var(--color-brass) 26%, var(--color-line));
    border-radius: 1.1rem;
    padding: clamp(1.4rem, 4vw, 2.4rem);
    background: linear-gradient(180deg, rgba(18, 22, 31, 0.7), rgba(8, 10, 15, 0.85));
  }

  .lm-form__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-fg);
    margin-bottom: 1.1rem;
  }
  .lm-field { display: grid; gap: 0.4rem; margin-bottom: 0.9rem; }
  .lm-field label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .lm-field input {
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: 0.7rem;
    padding: 0.85rem 0.95rem;
    background: rgba(4, 6, 10, 0.62);
    color: var(--color-fg);
    outline: none;
  }
  .lm-field input:focus { border-color: var(--color-brass); }
  .lm-note { margin-top: 0.8rem; font-size: 0.78rem; color: var(--color-muted); line-height: 1.5; }

  .lm-result__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1.4rem;
  }
  .lm-result__ok { color: var(--color-brass-bright); font-weight: 600; }

  .lm-doc__head { border-bottom: 1px solid var(--color-line); padding-bottom: 1rem; }
  .lm-doc__brand {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }
  .lm-doc__brand span { color: var(--color-brass); }
  .lm-doc__head h2 {
    margin-top: 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    font-weight: 700;
    color: var(--color-fg);
  }
  .lm-doc__sub { margin-top: 0.4rem; color: var(--color-fg-dim); font-size: 0.92rem; }

  .lm-list { margin-top: 1.4rem; display: grid; gap: 1rem; counter-reset: lm; }
  .lm-list li { display: grid; grid-template-columns: auto 1fr; gap: 0.8rem; align-items: start; }
  .lm-list__check {
    counter-increment: lm;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border: 1px solid color-mix(in oklab, var(--color-brass) 45%, var(--color-line));
    border-radius: 999px;
    color: var(--color-brass-bright);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .lm-list__check::before { content: counter(lm); }
  .lm-list__title { font-weight: 600; color: var(--color-fg); }
  .lm-list__desc { margin-top: 0.2rem; color: var(--color-fg-dim); font-size: 0.92rem; line-height: 1.55; }

  .lm-doc__foot { margin-top: 1.6rem; border-top: 1px solid var(--color-line); padding-top: 1rem; }
  .lm-doc__foot p { font-size: 0.85rem; color: var(--color-fg-dim); line-height: 1.6; }
  .lm-doc__foot a { color: var(--color-brass); }
  .lm-doc__disc { margin-top: 0.5rem; font-size: 0.74rem; color: var(--color-muted); }

  @media print {
    .no-print { display: none !important; }
    .lm-hero, .site-header, .site-footer, #scroll-progress, #cursor-dot, #cursor-ring { display: none !important; }
    .lm-card { border: none !important; background: #fff !important; padding: 0 !important; }
    .lm-doc, .lm-doc * { color: #111 !important; }
    .lm-doc__sub, .lm-list__desc, .lm-doc__foot p { color: #444 !important; }
    .lm-list__check { color: #6b4e16 !important; border-color: #b9892f !important; }
  }
</style>
