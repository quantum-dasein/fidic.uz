---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { certificates, courseFor, formatDate } from '../../lib/certificates';

export function getStaticPaths() {
  return certificates.map((cert) => ({
    params: { code: cert.code },
    props: { cert },
  }));
}

const { cert } = Astro.props;
const c = courseFor(cert);
const verifyUrl = `${site.url}/verify/${cert.code}/`;
---

<Layout
  title={`Сертификат №${cert.number} действителен — ${site.name}`}
  bare
  alwaysOpen
  forceNoindex
  noHeaderOffset
>
  <main class="vf">
    <div class="vf__bg" aria-hidden="true"></div>

    <article class="vf__card">
      <header class="vf__head">
        <a href="/" class="vf__brand">
          <span class="vf__brand-mark" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M4 6.5C7 4.8 9.5 4.8 12 6.2C14.5 4.8 17 4.8 20 6.5V18C17 16.6 14.5 16.6 12 18C9.5 16.6 7 16.6 4 18V6.5Z" stroke="var(--color-brass)" stroke-width="1.4" stroke-linejoin="round"/>
              <path d="M12 6.2V18" stroke="var(--color-brass)" stroke-width="1.4"/>
            </svg>
          </span>
          <span class="vf__brand-text">FIDIC<span>.uz</span></span>
        </a>
        <p class="vf__registry">Реестр сертификатов · Certificate registry</p>
      </header>

      {cert.demo && (
        <p class="vf__demo">Демонстрационная запись · Sample record</p>
      )}

      <div class="vf__status">
        <span class="vf__check" aria-hidden="true">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none">
            <path d="m5 13 4 4L19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <div>
          <p class="vf__status-ru">Сертификат действителен</p>
          <p class="vf__status-en">This certificate is valid</p>
        </div>
      </div>

      <dl class="vf__grid">
        <div class="vf__row">
          <dt>Регистровый номер · Registry No.</dt>
          <dd class="vf__mono">{cert.number}</dd>
        </div>
        <div class="vf__row">
          <dt>Код проверки · Verification code</dt>
          <dd class="vf__mono">{cert.code}</dd>
        </div>
        <div class="vf__row vf__row--wide">
          <dt>ФИО · Holder</dt>
          <dd class="vf__name">{cert.name}{cert.nameEn && <span class="vf__name-en"> · {cert.nameEn}</span>}</dd>
        </div>
        <div class="vf__row vf__row--wide">
          <dt>Курс · Course</dt>
          <dd>
            <span class="vf__course">«{c.titleRu}»</span>
            <span class="vf__course-en">{c.titleEn}</span>
            <span class="vf__course-sub">{c.subtitleRu}</span>
          </dd>
        </div>
        <div class="vf__row">
          <dt>Дата курса · Course date</dt>
          <dd>{formatDate(cert.courseDate)}</dd>
        </div>
        <div class="vf__row">
          <dt>Дата выдачи · Issued</dt>
          <dd>{formatDate(cert.issueDate)}</dd>
        </div>
        <div class="vf__row">
          <dt>Объём · Volume</dt>
          <dd>{c.hours} ак. ч · {c.hours} h</dd>
        </div>
        <div class="vf__row">
          <dt>Форма · Format</dt>
          <dd>{c.format}</dd>
        </div>
        <div class="vf__row vf__row--wide">
          <dt>Организатор · Issued by</dt>
          <dd>{c.organizer}</dd>
        </div>
        <div class="vf__row vf__row--wide">
          <dt>Тренеры · Trainers</dt>
          <dd>
            <ul class="vf__trainers">
              {c.trainers.map((t) => <li>{t}</li>)}
            </ul>
          </dd>
        </div>
      </dl>

      <footer class="vf__foot">
        <p>
          Это официальная запись реестра, подтверждающая подлинность сертификата, выданного {c.organizer}.
          This is the official registry record confirming the authenticity of the certificate issued by {c.organizer}.
        </p>
        <p class="vf__disclaimer">
          Наименование «FIDIC» используется исключительно в описательных целях для обозначения тематики курса.
          Настоящий курс не является официальным сертификатом FIDIC и не аккредитован FIDIC.
        </p>
        <a class="vf__link" href="/">{site.url.replace('https://', '')}</a>
      </footer>
    </article>
  </main>
</Layout>

<style>
  .vf {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: clamp(1.25rem, 4vw, 3rem) 1rem;
    background: var(--color-ink);
    color: var(--color-fg);
  }
  .vf__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 80% 6%, rgba(201, 164, 92, 0.14), transparent 30rem),
      radial-gradient(circle at 8% 96%, rgba(91, 140, 255, 0.1), transparent 32rem);
    pointer-events: none;
  }

  .vf__card {
    position: relative;
    width: min(100%, 44rem);
    border: 1px solid color-mix(in oklab, var(--color-brass) 30%, var(--color-line));
    border-radius: 1.1rem;
    padding: clamp(1.4rem, 4vw, 2.4rem);
    background: linear-gradient(180deg, rgba(18, 22, 31, 0.96), rgba(8, 10, 15, 0.98));
    box-shadow: 0 2rem 6rem rgba(0, 0, 0, 0.5);
  }

  .vf__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--color-line);
  }
  .vf__brand { display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .vf__brand-mark {
    display: grid; place-items: center;
    width: 2.3rem; height: 2.3rem;
    border: 1px solid color-mix(in oklab, var(--color-brass) 40%, var(--color-line));
    border-radius: 0.55rem;
    background: var(--color-ink-2, #11151c);
  }
  .vf__brand-text { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: var(--color-fg); }
  .vf__brand-text span { color: var(--color-brass); }
  .vf__registry {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .vf__demo {
    margin-top: 1rem;
    padding: 0.5rem 0.8rem;
    border: 1px dashed color-mix(in oklab, var(--color-brass) 50%, var(--color-line));
    border-radius: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-brass-bright);
    text-align: center;
  }

  .vf__status {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.4rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid color-mix(in oklab, #43d17a 36%, var(--color-line));
    border-radius: 0.85rem;
    background: rgba(67, 209, 122, 0.08);
  }
  .vf__check {
    display: grid; place-items: center;
    flex: 0 0 auto;
    width: 3rem; height: 3rem;
    border-radius: 999px;
    background: #43d17a;
    color: #04140a;
  }
  .vf__status-ru { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.2rem, 4vw, 1.5rem); color: var(--color-fg); }
  .vf__status-en { font-size: 0.85rem; color: var(--color-fg-dim); }

  .vf__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem 1.2rem;
    margin-top: 1.6rem;
  }
  .vf__row { display: grid; gap: 0.25rem; min-width: 0; }
  .vf__row--wide { grid-column: 1 / -1; }
  .vf__grid dt {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .vf__grid dd { color: var(--color-fg); line-height: 1.45; font-size: 0.98rem; }
  .vf__mono { font-family: var(--font-mono); letter-spacing: 0.05em; color: var(--color-brass-bright); }
  .vf__name { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; }
  .vf__name-en { font-weight: 400; font-size: 0.9rem; color: var(--color-fg-dim); }
  .vf__course { display: block; font-weight: 600; }
  .vf__course-en { display: block; font-size: 0.88rem; color: var(--color-fg-dim); }
  .vf__course-sub { display: block; margin-top: 0.3rem; font-size: 0.82rem; color: var(--color-muted); line-height: 1.5; }
  .vf__trainers { display: grid; gap: 0.15rem; }
  .vf__trainers li { font-size: 0.92rem; }

  .vf__foot {
    margin-top: 1.8rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--color-line);
    display: grid;
    gap: 0.7rem;
  }
  .vf__foot p { font-size: 0.8rem; line-height: 1.6; color: var(--color-fg-dim); }
  .vf__disclaimer { color: var(--color-muted); font-size: 0.74rem; }
  .vf__link {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-brass);
    text-decoration: none;
  }
  .vf__link:hover { color: var(--color-brass-bright); }

  @media (max-width: 540px) {
    .vf__grid { grid-template-columns: 1fr; }
    .vf__row { grid-column: 1 / -1; }
  }
</style>
