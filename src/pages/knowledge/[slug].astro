---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const dateStr = new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(article.data.date);
const iso = article.data.date.toISOString();
const url = `${site.url}/knowledge/${article.id}`;

const related = (await getCollection('articles'))
  .filter((a) => a.id !== article.id && a.data.category === article.data.category)
  .slice(0, 2);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: iso,
  dateModified: iso,
  inLanguage: 'ru',
  articleSection: article.data.category,
  keywords: article.data.tags.join(', '),
  mainEntityOfPage: url,
  author: { '@type': 'Organization', name: article.data.author, url: site.poweredByUrl },
  publisher: {
    '@type': 'Organization',
    name: site.poweredBy,
    logo: { '@type': 'ImageObject', url: `${site.url}/favicon.svg` },
  },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'База знаний', item: `${site.url}/knowledge` },
    { '@type': 'ListItem', position: 3, name: article.data.title, item: url },
  ],
};
---
<Layout
  title={`${article.data.title} | FIDIC.uz`}
  description={article.data.description}
  type="article"
  keywords={article.data.tags.join(', ')}
  published={iso}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <article class="mx-auto max-w-3xl px-5 py-16 md:px-8 md:py-24">
    <a href="/knowledge" class="link-underline mb-10 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-muted hover:text-brass">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      База знаний
    </a>

    <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-muted">
      <span class="text-brass uppercase tracking-widest">{article.data.category}</span>
      <span>·</span><span>{dateStr}</span>
      <span>·</span><span>{article.data.readingTime} мин</span>
    </div>

    <h1 class="mt-5 font-display font-700 leading-[1.08] tracking-tight text-fg" style="font-size: clamp(1.8rem, 6vw, 3rem)">{article.data.title}</h1>
    <p class="mt-5 text-xl leading-relaxed text-fg-dim">{article.data.description}</p>

    {article.data.tags.length > 0 && (
      <div class="mt-7 flex flex-wrap gap-2">
        {article.data.tags.map((t) => <span class="chip">{t}</span>)}
      </div>
    )}

    <hr class="my-10 border-line" />

    <div class="prose-fidic">
      <Content />
    </div>

    <!-- author / CTA -->
    <div class="mt-14 card p-7">
      <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{article.data.author}</p>
      <p class="mt-2 leading-relaxed text-fg-dim">
        Материал подготовлен экспертами Bridge Consult — практикующей командой по контрактам FIDIC, claims и проектам МФО. Нужна помощь по реальному контракту?
      </p>
      <a href="/#contact" class="btn btn-primary mt-5">Запросить консультацию
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </article>

  {related.length > 0 && (
    <section class="border-t border-line">
      <div class="mx-auto max-w-3xl px-5 py-14 md:px-8">
        <p class="eyebrow mb-6">Читайте также</p>
        <div class="grid gap-4 sm:grid-cols-2">
          {related.map((a) => (
            <a href={`/knowledge/${a.id}`} class="card group p-5">
              <span class="font-mono text-[11px] uppercase tracking-widest text-brass">{a.data.category}</span>
              <h3 class="mt-2 font-display text-lg font-700 text-fg transition-colors group-hover:text-brass-bright">{a.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
