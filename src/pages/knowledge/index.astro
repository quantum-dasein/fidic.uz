---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const categories = ['Все', ...new Set(articles.map((a) => a.data.category))];
const featured = articles.find((a) => a.data.featured) ?? articles[0];
const dateStr = featured
  ? new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(featured.data.date)
  : '';
---
<Layout title="База знаний FIDIC — статьи, кейсы, разборы | FIDIC.uz" description="Статьи и разборы по контрактам FIDIC, EPC, claims, DAAB и проектам международных банков развития.">
  <section class="relative border-b border-line">
    <div class="absolute inset-0 bp-grid opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
      <p class="eyebrow mb-4">Knowledge Hub</p>
      <h1 class="max-w-3xl font-display text-4xl font-700 leading-[1.05] tracking-tight text-fg md:text-6xl">
        База знаний по инфраструктурным контрактам
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-fg-dim">
        Разборы FIDIC, EPC, claims, DAAB и проектов МФО — простым языком и с практической пользой.
      </p>
    </div>
  </section>

  <!-- Featured -->
  {featured && (
    <section class="mx-auto max-w-7xl px-5 pt-14 md:px-8">
      <a href={`/knowledge/${featured.id}`} class="card group block overflow-hidden p-8 md:p-12">
        <div class="flex items-center gap-3">
          <span class="font-mono text-[11px] uppercase tracking-widest text-brass">{featured.data.category}</span>
          <span class="h-1 w-1 rounded-full bg-muted"></span>
          <span class="font-mono text-xs text-muted">Рекомендуем</span>
        </div>
        <h2 class="mt-4 max-w-3xl font-display text-3xl font-700 leading-tight text-fg transition-colors group-hover:text-brass-bright md:text-4xl">{featured.data.title}</h2>
        <p class="mt-4 max-w-2xl leading-relaxed text-fg-dim">{featured.data.description}</p>
        <div class="mt-6 flex items-center gap-4 text-sm text-muted">
          <span>{dateStr}</span><span>·</span><span>{featured.data.readingTime} мин чтения</span>
        </div>
      </a>
    </section>
  )}

  <!-- Filter + grid -->
  <section class="mx-auto max-w-7xl px-5 py-14 md:px-8">
    <div id="cat-filter" class="mb-10 flex flex-wrap gap-2">
      {categories.map((c, i) => (
        <button class="cat-btn chip transition-colors hover:border-brass hover:text-brass" data-cat={c} aria-pressed={i === 0 ? 'true' : 'false'}>{c}</button>
      ))}
    </div>

    <div id="article-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((a, i) => (
        <div class="article-item" data-cat={a.data.category}>
          <ArticleCard
            href={`/knowledge/${a.id}`}
            title={a.data.title}
            description={a.data.description}
            category={a.data.category}
            date={a.data.date}
            readingTime={a.data.readingTime}
            delay={(i % 3) * 80}
          />
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (function () {
      var btns = document.querySelectorAll('.cat-btn');
      var items = document.querySelectorAll('.article-item');
      btns.forEach(function (b) {
        b.addEventListener('click', function () {
          var cat = b.getAttribute('data-cat');
          btns.forEach(function (x) {
            var on = x === b;
            x.setAttribute('aria-pressed', on ? 'true' : 'false');
            x.style.borderColor = on ? 'var(--color-brass)' : '';
            x.style.color = on ? 'var(--color-brass)' : '';
          });
          items.forEach(function (it) {
            it.style.display = (cat === 'Все' || it.getAttribute('data-cat') === cat) ? '' : 'none';
          });
        });
      });
    })();
  </script>
</Layout>
