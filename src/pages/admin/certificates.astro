---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { certificates, course, formatDate } from '../../lib/certificates';

// Internal overview of every issued certificate. Not linked anywhere and
// noindex — security by obscurity (not real auth). Do not share the URL.
const real = certificates.filter((c) => !c.demo);
const demo = certificates.filter((c) => c.demo);
const ordered = [...real, ...demo];
const verifyUrl = (code: string) => `${site.url}/verify/${code}/`;
---

<Layout title={`Реестр сертификатов (внутр.) — ${site.name}`} bare alwaysOpen forceNoindex noHeaderOffset>
  <main class="adm">
    <header class="adm__head">
      <div>
        <p class="adm__eyebrow">Bridge Consult · внутренняя страница</p>
        <h1 class="adm__title">Реестр сертификатов</h1>
        <p class="adm__sub">{course.titleRu} · выдано: <strong>{real.length}</strong></p>
      </div>
      <div class="adm__headActions">
        <a class="adm__verify" href="/verify/">Страница проверки →</a>
        <a class="adm__verify" href="/verify/DEMO-2026/">Demo →</a>
      </div>
    </header>

    <div class="adm__note">
      ⚠️ Внутренняя страница: не indexируется и нигде не ссылается, но защищена только секретностью URL. Не делись ссылкой публично.
    </div>

    <section class="adm__ops" aria-label="Certificate operations">
      <div class="adm__stat">
        <span>REAL</span>
        <strong>{real.length}</strong>
        <p>боевых сертификатов в реестре</p>
      </div>
      <div class="adm__stat">
        <span>DEMO</span>
        <strong>{demo.length}</strong>
        <p>тестовых записей для проверки макета</p>
      </div>
      <div class="adm__guide">
        <p class="adm__guideTitle">Canva workflow</p>
        <ol>
          <li>Скопировать QR URL из таблицы.</li>
          <li>В Canva вставить QR или PNG из <code>certs-output</code>.</li>
          <li>На сертификате указать тот же код проверки.</li>
          <li>После правки реестра сделать redeploy.</li>
        </ol>
      </div>
    </section>

    <div class="adm__tablewrap">
      <table class="adm__table">
        <thead>
          <tr>
            <th>№</th>
            <th>Статус</th>
            <th>ФИО</th>
            <th>Код / QR URL</th>
            <th>Дата курса</th>
            <th>Выдан</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          {ordered.map((c) => (
            <tr class={c.demo ? 'is-demo' : ''}>
              <td class="adm__mono">{c.number}{c.demo && <span class="adm__tag">DEMO</span>}</td>
              <td><span class={`adm__status ${c.demo ? 'is-demo' : 'is-real'}`}>{c.demo ? 'demo' : 'real'}</span></td>
              <td>{c.name}{c.nameEn && <span class="adm__en"> · {c.nameEn}</span>}</td>
              <td>
                <a class="adm__link" href={`/verify/${c.code}/`} target="_blank" rel="noreferrer">{c.code} ↗</a>
                <span class="adm__url">{verifyUrl(c.code)}</span>
              </td>
              <td class="adm__mono">{formatDate(c.courseDate)}</td>
              <td class="adm__mono">{formatDate(c.issueDate)}</td>
              <td class="adm__actions">
                <button type="button" data-copy={verifyUrl(c.code)}>Copy QR URL</button>
                <button type="button" data-copy={c.code}>Copy code</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="adm__foot">
      Выпуск нового сертификата: <code>node scripts/issue-cert.mjs "ФИО"</code> → коммит <code>src/data/certificates.json</code> → redeploy.
    </p>
  </main>
</Layout>

<script is:inline>
  (function () {
    document.addEventListener('click', function (event) {
      var button = event.target.closest('[data-copy]');
      if (!button) return;
      var value = button.getAttribute('data-copy') || '';
      if (!value) return;
      function done() {
        var old = button.textContent;
        button.textContent = 'Copied';
        window.setTimeout(function () { button.textContent = old; }, 1200);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).then(done, done);
      } else {
        var input = document.createElement('input');
        input.value = value;
        document.body.appendChild(input);
        input.select();
        try { document.execCommand('copy'); } catch {}
        input.remove();
        done();
      }
    });
  })();
</script>

<style>
  .adm {
    min-height: 100svh;
    padding: clamp(1.25rem, 4vw, 3rem);
    background: var(--color-ink);
    color: var(--color-fg);
  }
  .adm__head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    max-width: 60rem;
    margin: 0 auto;
  }
  .adm__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .adm__title {
    margin-top: 0.4rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
  }
  .adm__sub { margin-top: 0.4rem; color: var(--color-fg-dim); }
  .adm__sub strong { color: var(--color-brass-bright); }
  .adm__verify {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-brass);
    text-decoration: none;
    white-space: nowrap;
  }
  .adm__verify:hover { color: var(--color-brass-bright); }
  .adm__headActions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: flex-end;
  }

  .adm__note {
    max-width: 60rem;
    margin: 1.2rem auto 0;
    padding: 0.7rem 0.9rem;
    border: 1px solid color-mix(in oklab, var(--color-brass) 40%, var(--color-line));
    border-radius: 0.6rem;
    background: rgba(201, 164, 92, 0.07);
    font-size: 0.8rem;
    color: var(--color-fg-dim);
    line-height: 1.5;
  }

  .adm__ops {
    display: grid;
    grid-template-columns: 10rem 10rem minmax(0, 1fr);
    gap: 0.9rem;
    max-width: 60rem;
    margin: 1rem auto 0;
  }
  .adm__stat,
  .adm__guide {
    border: 1px solid var(--color-line);
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.035);
    padding: 0.9rem;
  }
  .adm__stat span,
  .adm__guideTitle {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-brass);
  }
  .adm__stat strong {
    display: block;
    margin-top: 0.4rem;
    color: var(--color-fg);
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
  }
  .adm__stat p {
    margin-top: 0.45rem;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.35;
  }
  .adm__guide ol {
    margin-top: 0.55rem;
    display: grid;
    gap: 0.25rem;
    color: var(--color-fg-dim);
    font-size: 0.8rem;
    line-height: 1.4;
  }
  .adm__guide code {
    border-radius: 0.25rem;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.05rem 0.25rem;
    color: var(--color-fg);
  }

  .adm__tablewrap {
    max-width: 60rem;
    margin: 1.4rem auto 0;
    overflow-x: auto;
    border: 1px solid var(--color-line);
    border-radius: 0.8rem;
  }
  .adm__table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .adm__table th {
    text-align: left;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-line);
    white-space: nowrap;
  }
  .adm__table td {
    padding: 0.75rem 0.9rem;
    border-bottom: 1px solid color-mix(in oklab, var(--color-line) 60%, transparent);
    vertical-align: top;
  }
  .adm__table tr:last-child td { border-bottom: none; }
  .adm__table tr.is-demo { opacity: 0.6; }
  .adm__mono { font-family: var(--font-mono); white-space: nowrap; }
  .adm__en { color: var(--color-muted); font-size: 0.82rem; }
  .adm__link { color: var(--color-brass); text-decoration: none; font-family: var(--font-mono); }
  .adm__link:hover { color: var(--color-brass-bright); }
  .adm__url {
    display: block;
    max-width: 22rem;
    margin-top: 0.25rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .adm__status {
    display: inline-flex;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.18rem 0.48rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
  }
  .adm__status.is-real {
    border-color: color-mix(in oklab, #62d98a 45%, var(--color-line));
    color: #9af0b3;
    background: rgba(98, 217, 138, 0.08);
  }
  .adm__status.is-demo {
    color: var(--color-muted);
  }
  .adm__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    min-width: 11rem;
  }
  .adm__actions button {
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.34rem 0.55rem;
    color: var(--color-fg-dim);
    font-size: 0.72rem;
    transition: border-color 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo), background 0.2s var(--ease-out-expo);
  }
  .adm__actions button:hover {
    border-color: var(--color-brass);
    color: var(--color-brass-bright);
    background: rgba(201, 164, 92, 0.08);
  }
  .adm__tag {
    margin-left: 0.4rem;
    font-size: 0.6rem;
    color: var(--color-brass-bright);
    border: 1px solid var(--color-line);
    border-radius: 0.3rem;
    padding: 0.05rem 0.3rem;
  }
  .adm__foot {
    max-width: 60rem;
    margin: 1.4rem auto 0;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .adm__foot code {
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.1rem 0.35rem;
    border-radius: 0.3rem;
    color: var(--color-fg-dim);
  }

  @media (max-width: 760px) {
    .adm__ops {
      grid-template-columns: 1fr;
    }
  }
</style>
