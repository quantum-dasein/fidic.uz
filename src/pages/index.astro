---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Pillars from '../components/Pillars.astro';
import RainbowBook from '../components/RainbowBook.astro';
import DisputeLadder from '../components/DisputeLadder.astro';
import CertificationTeaser from '../components/CertificationTeaser.astro';
import Faq from '../components/Faq.astro';
import AskAI from '../components/AskAI.astro';
import Contact from '../components/Contact.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---
<Layout noHeaderOffset>
  <Hero />
  <Marquee />
  <Pillars />
  <RainbowBook />
  <DisputeLadder />

  <!-- Knowledge strip -->
  <section id="knowledge" class="section relative">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
      <div class="reveal mb-12 flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
        <div>
          <p class="eyebrow mb-4">База знаний</p>
          <h2 class="font-display text-4xl font-700 leading-tight tracking-tight text-fg md:text-5xl">Свежие материалы</h2>
        </div>
        <a href="/knowledge" class="link-underline inline-flex items-center gap-2 font-600 text-brass">
          Все статьи
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {articles.map((a, i) => (
          <ArticleCard
            href={`/knowledge/${a.id}`}
            title={a.data.title}
            description={a.data.description}
            category={a.data.category}
            date={a.data.date}
            readingTime={a.data.readingTime}
            delay={i * 90}
          />
        ))}
      </div>
    </div>
  </section>

  <CertificationTeaser />
  <Faq />
  <AskAI />
  <Contact />
</Layout>
