---
import { site, nav } from '../data/site';
import { type Lang, defaultLang, useTranslations, localizePath } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const home = localizePath('/', lang);
const navItems = nav.map((n) => ({ label: t(n.key), href: localizePath(n.href, lang) }));
const resourcesHref = localizePath('/resources', lang);
const claimChecklistHref = localizePath('/resources/claim-checklist', lang);
---
<footer class="site-footer relative overflow-hidden border-t border-line bg-ink-2/40">
  <div class="site-footer__grid" aria-hidden="true"></div>
  <div class="site-footer__rail" aria-hidden="true"></div>
  <div class="relative z-10 mx-auto max-w-7xl px-5 py-16 md:px-8">
    <div class="grid gap-12 md:grid-cols-12">
      <!-- Brand -->
      <div class="site-footer__brand md:col-span-5">
        <a href={home} class="footer-logo inline-flex items-center gap-3">
          <span class="footer-logo__mark flex h-10 w-10 items-center justify-center rounded-md border border-brass/35 bg-ink">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 6.5C7 4.8 9.5 4.8 12 6.2C14.5 4.8 17 4.8 20 6.5V18C17 16.6 14.5 16.6 12 18C9.5 16.6 7 16.6 4 18V6.5Z" stroke="var(--color-brass)" stroke-width="1.4" stroke-linejoin="round"/>
              <path d="M12 6.2V18" stroke="var(--color-brass)" stroke-width="1.4"/>
            </svg>
          </span>
          <span class="font-display text-2xl font-700 tracking-tight text-fg">FIDIC<span class="text-brass">.uz</span></span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-muted">{t('footer.about')}</p>
        <p class="mt-6 text-xs uppercase tracking-[0.25em] text-muted">{t('footer.poweredBy')}</p>
        <a href={site.poweredByUrl} target="_blank" rel="noopener" class="footer-link link-underline mt-1 inline-block font-display text-lg text-brass">{site.poweredBy}</a>
      </div>

      <!-- Nav -->
      <div class="site-footer__panel md:col-span-3">
        <p class="eyebrow mb-5">{t('footer.sections')}</p>
        <ul class="space-y-3">
          {navItems.map((item) => (
            <li><a href={item.href} class="footer-link text-sm text-fg-dim transition-colors hover:text-brass">{item.label}</a></li>
          ))}
          <li><a href="/verify/" class="footer-link text-sm text-fg-dim transition-colors hover:text-brass">{lang === 'uz' ? 'Sertifikatni tekshirish' : lang === 'en' ? 'Verify a certificate' : 'Проверить сертификат'}</a></li>
          <li><a href={resourcesHref} class="footer-link text-sm text-fg-dim transition-colors hover:text-brass">{lang === 'uz' ? 'Bepul materiallar' : lang === 'en' ? 'Free resources' : 'Бесплатные материалы'}</a></li>
          <li><a href={localizePath('/tools/calculators', lang)} class="footer-link text-sm text-fg-dim transition-colors hover:text-brass">{lang === 'uz' ? 'FIDIC kalkulyatorlari' : lang === 'en' ? 'FIDIC calculators' : 'FIDIC калькуляторы'}</a></li>
          <li><a href={claimChecklistHref} class="footer-link text-sm text-fg-dim transition-colors hover:text-brass">{lang === 'uz' ? 'Bepul claim cheklisti' : lang === 'en' ? 'Free claim checklist' : 'Бесплатный чеклист claim'}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="site-footer__panel md:col-span-4">
        <p class="eyebrow mb-5">{t('footer.contacts')}</p>
        <ul class="space-y-3 text-sm text-fg-dim">
          <li><a href={site.contacts.phoneHref} class="footer-link transition-colors hover:text-brass">{site.contacts.phone}</a></li>
          <li><a href={`mailto:${site.contacts.email}`} class="footer-link transition-colors hover:text-brass">{site.contacts.email}</a></li>
          <li><a href={site.contacts.telegram} target="_blank" rel="noopener" class="footer-link transition-colors hover:text-brass">Telegram {site.contacts.telegramHandle}</a></li>
          <li class="pt-1 text-muted">{site.contacts.address}</li>
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom mt-14 flex flex-col items-start justify-between gap-3 border-t border-line pt-6 text-xs text-muted md:flex-row md:items-center">
      <p>© {year} FIDIC.uz — {t('footer.project')} {site.poweredBy}. {t('footer.rights')}</p>
      <p class="font-mono">{t('footer.disclaimer')}</p>
    </div>
  </div>
</footer>
