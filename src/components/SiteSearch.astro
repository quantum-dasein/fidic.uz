---

<button type="button" class="site-search-trigger" data-site-search-open aria-label={copy.open}>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M11 19a8 8 0 1 1 5.3-14A8 8 0 0 1 11 19Zm6-2 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  </svg>
  <span>{copy.open}</span>
  <kbd>/</kbd>
</button>

<div id="site-search" class="site-search" data-lang={lang} data-copy={JSON.stringify(copy)} data-journeys={JSON.stringify(journeys)} data-quick-actions={JSON.stringify(quickActions)} aria-hidden="true">
  <div class="site-search__backdrop" data-site-search-close></div>
  <section class="site-search__panel" role="dialog" aria-modal="true" aria-labelledby="site-search-title">
    <div class="site-search__head">
      <div>
        <p class="eyebrow" id="site-search-title">{copy.title}</p>
        <p>{copy.hint}</p>
      </div>
      <button type="button" class="site-search__close" data-site-search-close aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="site-search__input-wrap">
      <svg width="19" height="19" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M11 19a8 8 0 1 1 5.3-14A8 8 0 0 1 11 19Zm6-2 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input id="site-search-input" type="search" autocomplete="off" spellcheck="false" placeholder={copy.placeholder} />
    </div>

    <div class="site-search__body">
      <label class="site-search__all">
        <input id="site-search-all-langs" type="checkbox" />
        <span>{copy.allLangs}</span>
      </label>

      <div id="site-search-status" class="site-search__status">{copy.loading}</div>
      <div id="site-search-insights" class="site-search__insights"></div>
      <div id="site-search-quick" class="site-search__quick"></div>
      <div id="site-search-results" class="site-search__results"></div>
      <div id="site-search-journeys" class="site-search__journeys"></div>
    </div>
  </section>
</div>

<script is:inline>
  (function () {
    if (window.__fidicSiteSearchBound) return;
    window.__fidicSiteSearchBound = true;

    var root = document.getElementById('site-search');
    if (!root) return;

    var input = document.getElementById('site-search-input');
    var results = document.getElementById('site-search-results');
    var journeysRoot = document.getElementById('site-search-journeys');
    var status = document.getElementById('site-search-status');
    var insights = document.getElementById('site-search-insights');
    var quickRoot = document.getElementById('site-search-quick');
    var allLangs = document.getElementById('site-search-all-langs');
    var lang = root.getAttribute('data-lang') || 'ru';
    var copy = JSON.parse(root.getAttribute('data-copy') || '{}');
    var journeys = JSON.parse(root.getAttribute('data-journeys') || '[]');
    var quickActions = JSON.parse(root.getAttribute('data-quick-actions') || '[]');
    var items = [];
    var ready = false;
    var activeIndex = -1;
    var queryTimer = null;
    var lastTrackedQuery = '';

    function track(eventName, params) {
      if (typeof window.gtag !== 'function') return;
      var payload = params || {};
      payload.language = payload.language || lang;
      payload.source_path = window.location.pathname;
      Object.keys(payload).forEach(function (key) {
        if (payload[key] === null || payload[key] === undefined || payload[key] === '') delete payload[key];
      });
      window.gtag('event', eventName, payload);
    }

    function normalize(value) {
      return String(value || '')
        .toLowerCase()
        .replace(/ё/g, 'е')
        .replace(/['’‘ʼʻ`]/g, '')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, function (char) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char];
      });
    }

    function highlight(value, query) {
      var safe = escapeHtml(value);
      var token = normalize(query).split(' ').filter(Boolean)[0];
      if (!token || token.length < 2) return safe;
      return safe.replace(new RegExp('(' + token.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'ig'), '<mark>$1</mark>');
    }

    function score(item, query) {
      var q = normalize(query);
      if (!q) return 0;
      var tokens = q.split(' ').filter(Boolean);
      var title = normalize(item.title);
      var description = normalize(item.description);
      var category = normalize(item.category);
      var tags = normalize((item.tags || []).join(' '));
      var text = normalize(item.text);
      var total = 0;

      tokens.forEach(function (token) {
        if (title === token) total += 90;
        if (title.indexOf(token) === 0) total += 55;
        if (title.indexOf(token) !== -1) total += 38;
        if (tags.indexOf(token) !== -1) total += 24;
        if (category.indexOf(token) !== -1) total += 16;
        if (description.indexOf(token) !== -1) total += 14;
        if (text.indexOf(token) !== -1) total += 5;
      });

      if (item.type === 'tool') total += 5;
      if (item.lang === lang) total += 8;
      return total;
    }

    function journeyScore(journey, query) {
      var q = normalize(query);
      if (!q) return 0;
      var tokens = q.split(' ').filter(Boolean);
      var source = normalize([journey.title, journey.description, (journey.triggers || []).join(' ')].join(' '));
      var total = 0;

      (journey.triggers || []).forEach(function (trigger) {
        var normalizedTrigger = normalize(trigger);
        if (normalizedTrigger && q.indexOf(normalizedTrigger) !== -1) total += 12;
      });

      tokens.forEach(function (token) {
        if (source.indexOf(token) !== -1) total += 3;
      });

      return total;
    }

    function quickActionScore(action, query) {
      var q = normalize(query);
      if (!q) return 0;
      var tokens = q.split(' ').filter(Boolean);
      var source = normalize([action.label, action.description, (action.triggers || []).join(' ')].join(' '));
      var total = 0;

      (action.triggers || []).forEach(function (trigger) {
        var normalizedTrigger = normalize(trigger);
        if (normalizedTrigger && q.indexOf(normalizedTrigger) !== -1) total += 14;
      });

      tokens.forEach(function (token) {
        if (source.indexOf(token) !== -1) total += 4;
      });

      return total;
    }

    function renderQuickActions(query) {
      if (!quickRoot) return 0;
      if (!query.trim() || query.trim().length < 2) {
        quickRoot.innerHTML = '';
        return 0;
      }

      var rankedActions = quickActions
        .map(function (action) { return { action: action, score: quickActionScore(action, query) }; })
        .filter(function (entry) { return entry.score > 0; })
        .sort(function (a, b) { return b.score - a.score; })
        .slice(0, 3);

      if (!rankedActions.length) {
        quickRoot.innerHTML = '';
        return 0;
      }

      quickRoot.innerHTML = '<section><span class="site-search__meta">' + escapeHtml(copy.quickActions || 'Quick actions') + '</span><div>' +
        rankedActions.map(function (entry, index) {
          var action = entry.action;
          return '<a href="' + escapeHtml(action.href) + '" data-search-quick-action="' + escapeHtml(action.label) + '" data-search-quick-rank="' + String(index + 1) + '">' +
            '<strong>' + highlight(action.label, query) + '</strong>' +
            '<em>' + highlight(action.description, query) + '</em>' +
          '</a>';
        }).join('') +
      '</div></section>';
      return rankedActions.length;
    }

    function renderJourneys(query) {
      if (!journeysRoot) return;
      if (!query.trim() || query.trim().length < 2) {
        journeysRoot.innerHTML = '';
        return 0;
      }

      var rankedJourneys = journeys
        .map(function (journey) { return { journey: journey, score: journeyScore(journey, query) }; })
        .filter(function (entry) { return entry.score > 0; })
        .sort(function (a, b) { return b.score - a.score; })
        .slice(0, 2);

      journeysRoot.innerHTML = rankedJourneys.map(function (entry) {
        var journey = entry.journey;
        return '<article class="site-search__journey">' +
          '<span class="site-search__meta">' + escapeHtml(copy.guided || 'Recommended path') + '</span>' +
          '<strong>' + highlight(journey.title, query) + '</strong>' +
          '<em>' + highlight(journey.description, query) + '</em>' +
          '<div class="site-search__steps">' +
            (journey.steps || []).map(function (step, index) {
              return '<a href="' + escapeHtml(step[1]) + '" data-search-journey="' + escapeHtml(journey.title) + '" data-search-step="' + escapeHtml(step[0]) + '" data-search-rank="' + String(index + 1) + '">' +
                '<span>' + String(index + 1) + '</span>' +
                escapeHtml(step[0]) +
              '</a>';
            }).join('') +
          '</div>' +
        '</article>';
      }).join('');
      return rankedJourneys.length;
    }

    function renderInsights(query, ranked, journeyCount) {
      if (!insights) return;
      if (!query.trim() || query.trim().length < 2 || (!ranked.length && !journeyCount)) {
        insights.innerHTML = '';
        return;
      }

      var counts = {};
      ranked.forEach(function (entry) {
        counts[entry.item.type] = (counts[entry.item.type] || 0) + 1;
      });
      var mix = Object.keys(counts).map(function (type) {
        var label = copy.types && copy.types[type] ? copy.types[type] : type;
        return '<span>' + escapeHtml(label) + ': <strong>' + String(counts[type]) + '</strong></span>';
      }).join('');
      var top = ranked[0] && ranked[0].item;
      var action = top
        ? '<a href="' + escapeHtml(top.url) + '" data-search-insight-link="1" data-search-insight-title="' + escapeHtml(top.title) + '">' + escapeHtml(top.title) + '</a>'
        : '<span>' + escapeHtml(copy.guided || 'Recommended path') + '</span>';

      insights.innerHTML = '<article>' +
        '<div><span class="site-search__meta">' + escapeHtml(copy.insights || 'Search insights') + '</span><p>' + escapeHtml(copy.contentMix || 'Content mix') + '</p><div class="site-search__mix">' + mix + '</div></div>' +
        '<div><span class="site-search__meta">' + escapeHtml(copy.bestAction || 'Best next step') + '</span>' + action + '</div>' +
      '</article>';
    }

    function setOpen(open) {
      root.classList.toggle('is-open', open);
      root.setAttribute('aria-hidden', open ? 'false' : 'true');
      document.documentElement.classList.toggle('search-lock', open);
      document.body.classList.toggle('search-lock', open);
      if (open) {
        track('site_search_open', { event_category: 'search' });
        loadIndex();
        setTimeout(function () { input && input.focus(); }, 40);
      }
    }

    function loadIndex() {
      if (ready) return;
      fetch('/search-index.json')
        .then(function (res) { return res.json(); })
        .then(function (json) {
          items = (json.items || []).map(function (item) {
            item._haystack = normalize([item.title, item.description, item.category, (item.tags || []).join(' '), item.text].join(' '));
            return item;
          });
          ready = true;
          render();
        })
        .catch(function () {
          if (status) status.textContent = copy.empty || 'No results';
        });
    }

    function render() {
      var q = input ? input.value : '';
      activeIndex = -1;
      if (!ready) {
        if (status) status.textContent = copy.loading || 'Loading...';
        return;
      }
      if (!q.trim()) {
        if (status) status.textContent = copy.hint || '';
        if (results) results.innerHTML = '';
        if (insights) insights.innerHTML = '';
        if (quickRoot) quickRoot.innerHTML = '';
        renderJourneys(q);
        return;
      }

      var langMode = allLangs && allLangs.checked;
      var ranked = items
        .filter(function (item) { return langMode || item.lang === lang; })
        .map(function (item) { return { item: item, score: score(item, q) }; })
        .filter(function (entry) { return entry.score > 0; })
        .sort(function (a, b) { return b.score - a.score; })
        .slice(0, 9);

      if (!results) return;
      results.innerHTML = ranked.map(function (entry, index) {
        var item = entry.item;
        var typeLabel = copy.types && copy.types[item.type] ? copy.types[item.type] : item.type;
        var meta = '<span>' + escapeHtml(typeLabel) + '</span><span>' + escapeHtml(item.category) + '</span>' + (langMode ? '<span>' + escapeHtml(item.lang.toUpperCase()) + '</span>' : '');
        return '<a class="site-search__result" href="' + escapeHtml(item.url) + '" data-result-index="' + index + '" data-search-result-type="' + escapeHtml(item.type) + '" data-search-result-title="' + escapeHtml(item.title) + '" data-search-result-rank="' + String(index + 1) + '">' +
          '<span class="site-search__meta">' + meta + '</span>' +
          '<strong>' + highlight(item.title, q) + '</strong>' +
          '<em>' + highlight(item.description, q) + '</em>' +
        '</a>';
      }).join('');
      var quickCount = renderQuickActions(q);
      var journeyCount = renderJourneys(q);
      renderInsights(q, ranked, journeyCount);
      if (status) status.textContent = ranked.length || journeyCount || quickCount ? '' : (copy.empty || 'No results');

      window.clearTimeout(queryTimer);
      queryTimer = window.setTimeout(function () {
        var normalizedQuery = normalize(q);
        if (!normalizedQuery || normalizedQuery.length < 2 || normalizedQuery === lastTrackedQuery) return;
        lastTrackedQuery = normalizedQuery;
        track('site_search_query', {
          event_category: 'search',
          search_term: q.trim(),
          result_count: ranked.length,
          guided_path_count: journeyCount,
          quick_action_count: quickCount,
          all_languages: Boolean(langMode),
        });
      }, 700);
    }

    document.addEventListener('click', function (event) {
      if (event.target.closest('[data-site-search-open]')) {
        event.preventDefault();
        setOpen(true);
      }
      if (event.target.closest('[data-site-search-close]')) setOpen(false);

      var resultLink = event.target.closest('.site-search__result');
      if (resultLink) {
        track('site_search_result_click', {
          event_category: 'search',
          search_term: input ? input.value.trim() : '',
          result_type: resultLink.getAttribute('data-search-result-type'),
          result_title: resultLink.getAttribute('data-search-result-title'),
          result_rank: resultLink.getAttribute('data-search-result-rank'),
          link_url: resultLink.href,
        });
      }

      var journeyLink = event.target.closest('.site-search__steps a');
      if (journeyLink) {
        track('site_search_guided_path_click', {
          event_category: 'search',
          search_term: input ? input.value.trim() : '',
          guided_path: journeyLink.getAttribute('data-search-journey'),
          guided_step: journeyLink.getAttribute('data-search-step'),
          guided_rank: journeyLink.getAttribute('data-search-rank'),
          link_url: journeyLink.href,
        });
      }

      var insightLink = event.target.closest('[data-search-insight-link]');
      if (insightLink) {
        track('site_search_insight_click', {
          event_category: 'search',
          search_term: input ? input.value.trim() : '',
          result_title: insightLink.getAttribute('data-search-insight-title'),
          link_url: insightLink.href,
        });
      }

      var quickLink = event.target.closest('[data-search-quick-action]');
      if (quickLink) {
        track('site_search_quick_action_click', {
          event_category: 'search',
          search_term: input ? input.value.trim() : '',
          quick_action: quickLink.getAttribute('data-search-quick-action'),
          quick_rank: quickLink.getAttribute('data-search-quick-rank'),
          link_url: quickLink.href,
        });
      }
    });

    document.addEventListener('keydown', function (event) {
      var target = event.target;
      var typing = target && /input|textarea|select/i.test(target.tagName || '');
      if (event.key === '/' && !typing) {
        event.preventDefault();
        setOpen(true);
      }
      if (event.key === 'Escape') setOpen(false);
      if (!root.classList.contains('is-open')) return;
      var links = Array.from(document.querySelectorAll('.site-search__quick a, .site-search__result, .site-search__steps a'));
      if (event.key === 'ArrowDown' && links.length) {
        event.preventDefault();
        activeIndex = Math.min(activeIndex + 1, links.length - 1);
        links.forEach(function (link, index) { link.classList.toggle('is-active', index === activeIndex); });
        links[activeIndex].scrollIntoView({ block: 'nearest' });
      }
      if (event.key === 'ArrowUp' && links.length) {
        event.preventDefault();
        activeIndex = Math.max(activeIndex - 1, 0);
        links.forEach(function (link, index) { link.classList.toggle('is-active', index === activeIndex); });
        links[activeIndex].scrollIntoView({ block: 'nearest' });
      }
      if (event.key === 'Enter' && activeIndex >= 0 && links[activeIndex]) {
        event.preventDefault();
        links[activeIndex].click();
      }
    });

    if (input) input.addEventListener('input', render);
    if (allLangs) allLangs.addEventListener('change', render);
  })();
</script>

