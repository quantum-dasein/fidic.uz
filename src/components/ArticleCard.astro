---
interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  date: Date;
  readingTime: number;
  delay?: number;
}
const { href, title, description, category, date, readingTime, delay = 0 } = Astro.props;
const dateStr = new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
---
<a href={href} class="tilt card reveal group flex flex-col p-6 md:p-7" data-delay={delay}>
  <div class="flex items-center justify-between">
    <span class="font-mono text-[11px] uppercase tracking-widest text-brass">{category}</span>
    <span class="font-mono text-xs text-muted">{readingTime} мин</span>
  </div>
  <h3 class="mt-4 font-display text-xl font-700 leading-snug text-fg transition-colors group-hover:text-brass-bright md:text-2xl">{title}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-fg-dim">{description}</p>
  <div class="mt-6 flex items-center justify-between border-t border-line pt-4">
    <span class="text-xs text-muted">{dateStr}</span>
    <span class="flex items-center gap-1.5 text-sm font-600 text-brass">
      Читать
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</a>
