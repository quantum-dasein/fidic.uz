---
const faqs = [
  {
    q: 'Что такое контракты FIDIC простыми словами?',
    a: 'FIDIC — это стандартные формы договоров для строительных и инфраструктурных проектов, разработанные Международной федерацией инженеров-консультантов. Они задают «правила игры» между заказчиком, подрядчиком и инженером: кто за что отвечает, как платят, как меняют объёмы и как решают споры. Их применяют более чем в 100 странах.',
  },
  {
    q: 'Чем отличаются Red, Yellow и Silver Book?',
    a: 'Red Book — проектирует заказчик, оплата по измеренным объёмам. Yellow Book — проектирует подрядчик (design-build), твёрдая цена. Silver Book — EPC «под ключ» с максимальной определённостью цены и срока для инвестора и почти всеми рисками на подрядчике. Выбор зависит прежде всего от того, кто отвечает за проектирование.',
  },
  {
    q: 'Какую книгу FIDIC используют для проектов Всемирного банка и АБР?',
    a: 'Как правило — Pink Book (MDB Harmonised Construction Contract), гармонизированную для банков развития версию Red Book. К ней почти всегда прилагаются Особые условия конкретного банка с требованиями по добросовестности, аудиту и закупкам.',
  },
  {
    q: 'Что такое правило 28 дней в claims?',
    a: 'По изданиям 2017 года (Sub-Clause 20.2.1) сторона обязана подать уведомление о претензии в течение 28 дней с момента, когда узнала о событии. Это пресекательный срок: при его пропуске можно полностью потерять право на претензию, даже если она обоснована по существу.',
  },
  {
    q: 'Что такое DAAB?',
    a: 'DAAB (Dispute Avoidance/Adjudication Board) — постоянный совет по предотвращению и разрешению споров, назначаемый на весь срок проекта. Его решение обязательно к немедленному исполнению; несогласная сторона может позже передать спор в арбитраж, подав Notice of Dissatisfaction в срок.',
  },
  {
    q: 'Чем редакция FIDIC 2017 отличается от 1999?',
    a: 'Издания 2017 года подробнее и процедурнее: 21 статья вместо 20, единый порядок претензий обеих сторон (Clause 20), отдельная статья о спорах (Clause 21), переход от DAB к DAAB с упором на предотвращение споров и требование к Инженеру действовать нейтрально при определениях.',
  },
  {
    q: 'Помогает ли FIDIC.uz с реальным контрактом?',
    a: 'Да. За порталом стоит практикующая команда Bridge Consult: сертифицированные специалисты FIDIC (FCCE, FCCP), эксперты по claims, арбитражу и проектам МФО. Оставьте заявку на сайте или напишите в Telegram — предложим формат работы по вашему проекту.',
  },
];
---
<section id="faq" class="section relative">
  <div class="mx-auto max-w-4xl px-5 md:px-8">
    <div class="reveal mb-12 text-center">
      <p class="eyebrow mb-4">FAQ</p>
      <h2 class="font-display text-4xl font-700 leading-tight tracking-tight text-fg md:text-5xl">Частые вопросы о FIDIC</h2>
    </div>

    <div class="divide-y divide-line border-y border-line">
      {faqs.map((f, i) => (
        <details class="faq-item group" name="faq" open={i === 0}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-6">
            <span class="font-display text-lg font-600 text-fg transition-colors group-hover:text-brass md:text-xl">{f.q}</span>
            <span class="faq-icon flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-line text-brass transition-transform duration-300">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </span>
          </summary>
          <p class="pb-6 leading-relaxed text-fg-dim">{f.a}</p>
        </details>
      ))}
    </div>
  </div>

  <style>
    .faq-item[open] .faq-icon { transform: rotate(45deg); }
    .faq-item summary::-webkit-details-marker { display: none; }
  </style>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
</section>
