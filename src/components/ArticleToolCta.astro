const c = copy[lang];
const selected = c[kind];
const actions = [selected.primary, selected.secondary, selected.tertiary];
---

<aside class={`article-tool-cta article-tool-cta--${kind}`}>
  <div class="article-tool-cta__copy">
    <p>{c.eyebrow}</p>
    <h2>{selected.title}</h2>
    <span>{selected.text}</span>
  </div>
  <div class="article-tool-cta__actions">
    {actions.map(([label, href], index) => (
      <a
        href={localizePath(href, lang)}
        class={index === 0 ? 'is-primary' : ''}
        data-analytics-event="article_cta_click"
        data-analytics-cta-type={kind}
        data-analytics-cta-rank={String(index + 1)}
        data-analytics-label={label}
        data-analytics-destination={href}
        data-analytics-article-slug={slug}
        data-analytics-article-category={category}
        data-analytics-lang={lang}
      >
        {label}
      </a>
    ))}
  </div>
</aside>

<style>
  .article-tool-cta {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1.2rem;
    margin-top: 3rem;
    border: 1px solid var(--color-line-soft);
    border-radius: 1rem;
    padding: clamp(1.15rem, 3vw, 1.6rem);
    background:
      radial-gradient(circle at 88% 12%, var(--cta-glow, rgba(201,164,92,0.13)), transparent 14rem),
      linear-gradient(180deg, color-mix(in oklab, var(--color-ink-2) 92%, transparent), var(--color-ink));
  }

  .article-tool-cta--claims { --cta-accent: var(--color-brass); --cta-glow: rgba(201,164,92,0.14); }
  .article-tool-cta--tender { --cta-accent: var(--color-blueprint); --cta-glow: rgba(91,140,255,0.14); }
  .article-tool-cta--books { --cta-accent: var(--color-fidic-green); --cta-glow: rgba(47,143,91,0.13); }
  .article-tool-cta--certification { --cta-accent: var(--color-fidic-yellow); --cta-glow: rgba(224,168,46,0.13); }
  .article-tool-cta--practice { --cta-accent: var(--color-fidic-silver); --cta-glow: rgba(185,188,196,0.11); }

  .article-tool-cta__copy {
    min-width: 0;
  }

  .article-tool-cta__copy p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cta-accent, var(--color-brass));
  }

  .article-tool-cta__copy h2 {
    margin: 0.7rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--color-fg);
  }

  .article-tool-cta__copy span {
    display: block;
    margin-top: 0.8rem;
    color: var(--color-fg-dim);
    line-height: 1.65;
  }

  .article-tool-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: center;
  }

  .article-tool-cta__actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in oklab, var(--cta-accent, var(--color-brass)) 45%, var(--color-line));
    border-radius: 999px;
    padding: 0.72rem 1rem;
    color: var(--color-fg);
    font-size: 0.84rem;
    font-weight: 700;
    text-decoration: none;
    transition: border-color 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
  }

  .article-tool-cta__actions a:hover {
    border-color: var(--cta-accent, var(--color-brass));
    color: color-mix(in oklab, var(--cta-accent, var(--color-brass)) 80%, var(--color-fg));
    transform: translateY(-2px);
  }

  .article-tool-cta__actions a.is-primary {
    border-color: var(--cta-accent, var(--color-brass));
    background: color-mix(in oklab, var(--cta-accent, var(--color-brass)) 18%, transparent);
  }

  @media (min-width: 720px) {
    .article-tool-cta {
      grid-template-columns: minmax(0, 1fr) minmax(13rem, 0.48fr);
      align-items: center;
    }

    .article-tool-cta__actions {
      justify-content: flex-end;
    }
  }

  @media (max-width: 520px) {
    .article-tool-cta__actions a {
      width: 100%;
    }
  }
</style>
