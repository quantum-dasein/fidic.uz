---
const pillars = [
  {
    n: '01',
    title: 'База знаний',
    desc: 'Статьи, разборы кейсов, сравнение редакций и библиотека терминов по FIDIC, EPC, claims и проектам МФО.',
    href: '/knowledge',
    cta: 'Открыть статьи',
    icon: 'M4 5h16M4 12h16M4 19h10',
  },
  {
    n: '02',
    title: 'Интерактивная серия',
    desc: 'Радужная серия FIDIC как интерактивная книга: профиль риска, ключевые статьи и применимость каждой формы.',
    href: '/#suite',
    cta: 'Снять книгу с полки',
    icon: 'M4 6.5C7 4.8 9.5 4.8 12 6.2C14.5 4.8 17 4.8 20 6.5V18C17 16.6 14.5 16.6 12 18C9.5 16.6 7 16.6 4 18V6.5Z',
  },
  {
    n: '03',
    title: 'Подготовка к сертификации',
    desc: 'Материалы и пробные тесты для FIDIC Credentialing: Red, Yellow, Silver Book, Claims, DAAB и Procurement.',
    href: '/certification',
    cta: 'Проверить себя',
    icon: 'M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6L12 2z',
  },
  {
    n: '04',
    title: 'Экспертиза Bridge Consult',
    desc: 'За FIDIC.uz стоит практикующая команда. Нужен анализ контракта или сопровождение спора — запросите консультацию.',
    href: '/#contact',
    cta: 'Запросить консультацию',
    icon: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  },
];
---
<section class="section relative">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="reveal mb-14 flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <p class="eyebrow mb-4">Что внутри</p>
        <h2 class="font-display text-4xl font-700 leading-[1.05] tracking-tight text-fg md:text-5xl">
          Один портал — четыре способа<br class="hidden md:block" /> работать с FIDIC
        </h2>
      </div>
      <p class="max-w-sm text-fg-dim">От первого знакомства с радужной серией до подготовки к сертификации и экспертного сопровождения реальных проектов.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {pillars.map((p, i) => (
        <a href={p.href} class="tilt card reveal group flex flex-col p-7" data-delay={i * 90}>
          <div class="flex items-center justify-between">
            <span class="flex h-11 w-11 items-center justify-center rounded-lg border border-line text-brass transition-colors group-hover:border-brass">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d={p.icon} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="font-mono text-xs text-muted">{p.n}</span>
          </div>
          <h3 class="mt-6 font-display text-xl font-700 text-fg">{p.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-fg-dim">{p.desc}</p>
          <span class="mt-6 flex items-center gap-1.5 text-sm font-600 text-brass">
            {p.cta}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
