---
import { type Lang, defaultLang, localizePath } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;

const copy = {
  ru: {
    eyebrow: 'Инструмент',
    title: 'Claim Readiness Checklist',
    text: 'Проверьте, хватает ли вашему claim notices, contemporary records, причинной связи и расчёта перед подачей Инженеру или DAAB.',
    cta: 'Проверить claim',
  },
  en: {
    eyebrow: 'Tool',
    title: 'Claim Readiness Checklist',
    text: 'Check whether your claim has notices, contemporary records, causation and quantum before submission to the Engineer or DAAB.',
    cta: 'Check a claim',
  },
  uz: {
    eyebrow: 'Vosita',
    title: 'Claim Readiness Checklist',
    text: 'Claim topshirishdan oldin notices, contemporary records, sababiy bog‘liqlik va hisob-kitob yetarliligini tekshiring.',
    cta: 'Claim’ni tekshirish',
  },
} as const;

const c = copy[lang];
const href = localizePath('/tools/claim-readiness', lang);
---

<section class="relative border-y border-line bg-ink-2/30">
  <div class="mx-auto max-w-7xl px-5 py-10 md:px-8">
    <a href={href} class="card group grid gap-6 p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8">
      <div>
        <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.eyebrow}</p>
        <h2 class="mt-2 font-display text-2xl font-700 text-fg md:text-3xl">{c.title}</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-fg-dim">{c.text}</p>
      </div>
      <span class="btn btn-primary justify-center">{c.cta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>
  </div>
</section>

