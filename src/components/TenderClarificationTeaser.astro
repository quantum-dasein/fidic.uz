---
import { type Lang, defaultLang, localizePath } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;

const copy = {
  ru: {
    eyebrow: 'Clarification Generator',
    title: 'Соберите вопросы к тендеру до подачи цены',
    text: 'Выберите рискованные зоны tender package, получите список clarification questions и commercial assumptions для pre-bid review.',
    cta: 'Открыть генератор',
  },
  en: {
    eyebrow: 'Clarification Generator',
    title: 'Build tender questions before pricing',
    text: 'Select risky areas of the tender package and generate clarification questions with commercial assumptions for pre-bid review.',
    cta: 'Open generator',
  },
  uz: {
    eyebrow: 'Clarification Generator',
    title: 'Narx berishdan oldin tender savollarini tuzing',
    text: 'Tender paketidagi riskli joylarni tanlang va pre-bid review uchun clarification questions hamda commercial assumptions oling.',
    cta: 'Generatorni ochish',
  },
} as const;

const c = copy[lang];
const href = localizePath('/tools/tender-clarification-generator', lang);
---

<section class="relative border-y border-line bg-ink">
  <div class="mx-auto max-w-7xl px-5 py-10 md:px-8">
    <a href={href} class="clarifier-teaser group grid overflow-hidden rounded-2xl border border-line-soft bg-ink-2/70 p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8">
      <div class="relative z-10 min-w-0">
        <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.eyebrow}</p>
        <h2 class="mt-2 font-display text-2xl font-700 leading-tight text-fg md:text-3xl">{c.title}</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-fg-dim">{c.text}</p>
      </div>
      <span class="btn btn-primary relative z-10 mt-5 justify-center md:mt-0">{c.cta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <span class="clarifier-teaser__stack" aria-hidden="true">
        <i></i><i></i><i></i>
      </span>
    </a>
  </div>
</section>

<style>
  .clarifier-teaser {
    position: relative;
    transition: border-color 0.35s var(--ease-out-expo), transform 0.35s var(--ease-out-expo);
  }

  .clarifier-teaser:hover {
    border-color: color-mix(in oklab, var(--color-brass) 50%, var(--color-line));
    transform: translateY(-2px);
  }

  .clarifier-teaser__stack {
    position: absolute;
    right: clamp(-4rem, 5vw, 3rem);
    top: 50%;
    width: 13rem;
    aspect-ratio: 1.25;
    transform: translateY(-50%) rotateX(60deg) rotateZ(-24deg);
    transform-style: preserve-3d;
    opacity: 0.72;
  }

  .clarifier-teaser__stack i {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(201,164,92,0.28);
    background:
      linear-gradient(90deg, rgba(201,164,92,0.14) 1px, transparent 1px),
      linear-gradient(0deg, rgba(91,140,255,0.12) 1px, transparent 1px),
      rgba(15,18,26,0.72);
    background-size: 24px 24px;
    box-shadow: 0 22px 70px rgba(0,0,0,0.35);
  }

  .clarifier-teaser__stack i:nth-child(2) {
    transform: translate(0.75rem, -0.75rem) translateZ(26px);
  }

  .clarifier-teaser__stack i:nth-child(3) {
    transform: translate(1.5rem, -1.5rem) translateZ(52px);
    border-color: rgba(91,140,255,0.34);
  }

  @media (max-width: 768px) {
    .clarifier-teaser {
      border-radius: 1rem;
    }

    .clarifier-teaser__stack {
      right: -5rem;
      width: 10rem;
      opacity: 0.35;
    }

    .clarifier-teaser .btn {
      width: 100%;
      white-space: normal;
    }
  }
</style>
