---
import { site, nav } from '../data/site';
import SiteSearch from './SiteSearch.astro';
import { type Lang, defaultLang, locales, languages, useTranslations, stripLocale, localizePath, ensureTrailingSlash } from '../i18n/ui';

interface Props { lang?: Lang; langUrls?: Partial<Record<Lang, string>> }
const { lang = defaultLang, langUrls } = Astro.props;
const t = useTranslations(lang);

const canonical = stripLocale(Astro.url.pathname);
const home = localizePath('/', lang);
const navItems = nav.map((n) => ({ label: t(n.key), href: localizePath(n.href, lang) }));
const langLinks = locales.map((l) => ({ code: l, name: languages[l], href: ensureTrailingSlash(langUrls?.[l] ?? localizePath(canonical, l)), active: l === lang }));
const langShort: Record<Lang, string> = { ru: 'RU', en: 'EN', uz: 'UZ' };
const verifyHref = '/verify/';
const verifyLabel = lang === 'uz' ? 'Sertifikatni tekshirish' : lang === 'en' ? 'Verify certificate' : 'Проверить сертификат';
---
<header id="site-header" class="site-header fixed top-0 z-[100] w-full border-b border-line/60 bg-ink/70 backdrop-blur-xl transition-all duration-500">
  <span class="site-header__rail" aria-hidden="true"></span>
  <div class="site-header__inner mx-auto flex h-20 w-full max-w-[96rem] items-center justify-between gap-4 px-4 sm:px-5 lg:px-6 xl:px-8">
    <!-- Logo -->
    <a href={home} class="site-logo group relative z-[102] flex shrink-0 items-center gap-3" aria-label={`FIDIC.uz — ${t('header.home')}`}>
      <span class="site-logo__mark flex h-9 w-9 items-center justify-center rounded-md border border-brass/40 bg-ink-2 transition-colors duration-500 group-hover:border-brass">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 6.5C7 4.8 9.5 4.8 12 6.2C14.5 4.8 17 4.8 20 6.5V18C17 16.6 14.5 16.6 12 18C9.5 16.6 7 16.6 4 18V6.5Z" stroke="var(--color-brass)" stroke-width="1.4" stroke-linejoin="round"/>
          <path d="M12 6.2V18" stroke="var(--color-brass)" stroke-width="1.4"/>
        </svg>
      </span>
      <span class="site-logo__text whitespace-nowrap font-display text-xl font-700 tracking-tight text-fg">FIDIC<span class="text-brass">.uz</span></span>
    </a>

    <!-- Desktop nav -->
    <nav class="site-nav hidden min-w-0 flex-1 items-center justify-center gap-4 xl:flex xl:gap-6">
      {navItems.map((item) => (
        <a href={item.href} class="site-nav__link link-underline whitespace-nowrap text-[13px] font-500 text-fg-dim transition-colors hover:text-fg xl:text-sm">{item.label}</a>
      ))}
    </nav>

    <a href={verifyHref} class="site-verify-link hidden shrink-0 items-center gap-2 whitespace-nowrap xl:inline-flex" aria-label={verifyLabel}>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 3.4l6.2 2.25v5.15c0 4.35-2.55 7.75-6.2 9.8-3.65-2.05-6.2-5.45-6.2-9.8V5.65L12 3.4Z" stroke="currentColor" stroke-width="1.55" stroke-linejoin="round"/>
        <path d="M8.9 12.1l2 2 4.4-5" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>{verifyLabel}</span>
    </a>

    <SiteSearch lang={lang} />

    <!-- Right side -->
    <div class="site-actions hidden shrink-0 items-center gap-2 xl:flex xl:gap-3">
      <!-- Language switcher -->
      <div class="site-lang flex items-center gap-1 rounded-full border border-line p-0.5" role="group" aria-label={t('header.lang')}>
        {langLinks.map((l) => (
          <a
            href={l.href}
            data-lang-switch
            aria-current={l.active ? 'true' : undefined}
            class={`rounded-full px-2.5 py-1 font-mono text-xs font-600 transition-colors ${l.active ? 'bg-brass text-[#1a1206]' : 'text-fg-dim hover:text-brass'}`}
          >{langShort[l.code]}</a>
        ))}
      </div>
      <a href={`${home}#contact`} class="btn btn-primary whitespace-nowrap px-4 py-2.5 text-xs xl:px-5">{t('header.consult')}</a>
    </div>

    <!-- Mobile toggle -->
    <button id="menu-btn" class="relative z-[102] flex h-6 w-7 flex-col justify-between xl:hidden" aria-label={t('header.menu')} aria-controls="mobile-menu" aria-expanded="false">
      <span class="burger-1 h-[2px] w-full origin-left bg-fg transition-all duration-300"></span>
      <span class="burger-2 h-[2px] w-full bg-fg transition-all duration-300"></span>
      <span class="burger-3 h-[2px] w-full origin-left bg-fg transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" data-lenis-prevent class="mobile-menu-panel fixed inset-0 z-[101] flex min-h-[100dvh] flex-col overflow-y-auto bg-ink px-6 pt-28 pb-10 xl:hidden sm:px-8" aria-hidden="true">
    <div class="mobile-menu-panel__langs mb-8 flex items-center justify-center gap-2">
      {langLinks.map((l) => (
        <a href={l.href} data-lang-switch class={`rounded-full border px-4 py-2 font-mono text-sm font-600 transition-colors ${l.active ? 'border-brass bg-brass text-[#1a1206]' : 'border-line text-fg-dim'}`}>{langShort[l.code]}</a>
      ))}
    </div>
    <nav class="mobile-menu-panel__nav flex flex-col gap-1">
      {navItems.map((item) => (
        <a href={item.href} class="mobile-link border-b border-line/60 py-4 font-display text-2xl font-600 text-fg">{item.label}</a>
      ))}
      <a href={verifyHref} class="mobile-link border-b border-line/60 py-4 font-display text-2xl font-600 text-fg">{verifyLabel}</a>
    </nav>
    <div class="mobile-menu-panel__cta mt-10 flex flex-col gap-4">
      <a href={`${home}#contact`} class="btn btn-primary justify-center">{t('header.consultFull')}</a>
      <a href={site.contacts.phoneHref} class="text-center text-lg font-600 text-fg-dim">{site.contacts.phone}</a>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var btn = document.getElementById('menu-btn');
    var menu = document.getElementById('mobile-menu');
    if (!header || !btn || !menu || btn.dataset.menuBound === 'true') return;

    btn.dataset.menuBound = 'true';
    var open = false;
    var l1 = btn.querySelector('.burger-1');
    var l2 = btn.querySelector('.burger-2');
    var l3 = btn.querySelector('.burger-3');

    function setOpen(next) {
      open = Boolean(next);
      header.classList.toggle('is-menu-open', open);
      btn.classList.toggle('is-open', open);
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu.setAttribute('aria-hidden', open ? 'false' : 'true');
      document.documentElement.classList.toggle('menu-lock', open);
      document.body.classList.toggle('menu-lock', open);
      if (l1 && l2 && l3) {
        l1.style.transform = open ? 'rotate(45deg) translate(2px,-1px)' : '';
        l2.style.opacity = open ? '0' : '1';
        l3.style.transform = open ? 'rotate(-45deg) translate(2px,1px)' : '';
      }
    }

    btn.addEventListener('click', function () { setOpen(!open); });
    menu.addEventListener('click', function (event) {
      if (event.target.closest('a')) setOpen(false);
    });
    window.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') setOpen(false);
    });
    window.addEventListener('resize', function () {
      if (window.innerWidth >= 1280) setOpen(false);
    }, { passive: true });
  })();
</script>

<style>
  .site-verify-link {
    position: relative;
    isolation: isolate;
    border: 1px solid color-mix(in oklab, var(--color-brass) 42%, var(--color-line));
    border-radius: 999px;
    padding: 0.62rem 0.86rem;
    color: var(--color-fg);
    background:
      radial-gradient(circle at 18% 10%, rgba(201, 164, 92, 0.24), transparent 3.4rem),
      rgba(201, 164, 92, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(201, 164, 92, 0.04);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition:
      border-color 0.25s var(--ease-out-expo),
      background 0.25s var(--ease-out-expo),
      color 0.25s var(--ease-out-expo),
      transform 0.25s var(--ease-out-expo);
  }

  .site-verify-link svg {
    flex: 0 0 auto;
    color: var(--color-brass);
  }

  .site-verify-link:hover {
    border-color: var(--color-brass);
    color: var(--color-brass-bright);
    background:
      radial-gradient(circle at 18% 10%, rgba(201, 164, 92, 0.32), transparent 3.8rem),
      rgba(201, 164, 92, 0.12);
    transform: translateY(-1px);
  }

  @media (max-width: 1420px) {
    .site-verify-link {
      padding-inline: 0.72rem;
      font-size: 0.74rem;
    }
  }

  @media (max-width: 1279px) {
    #site-header {
      isolation: isolate;
    }

    #site-header.is-menu-open {
      background: var(--color-ink);
      border-color: var(--color-line);
    }

    #site-header.is-menu-open .mobile-menu-panel {
      opacity: 1;
      pointer-events: auto;
      transform: translate3d(0, 0, 0);
      visibility: visible;
    }

    .mobile-menu-panel {
      overscroll-behavior: contain;
      box-shadow: inset 0 1px 0 rgba(201, 164, 92, 0.3);
      opacity: 0;
      pointer-events: none;
      transform: translate3d(100%, 0, 0);
      transition:
        opacity 0.32s var(--ease-out-expo),
        transform 0.46s var(--ease-out-expo),
        visibility 0s linear 0.46s;
      visibility: hidden;
    }

    .mobile-menu-panel__langs,
    .mobile-menu-panel__nav,
    .mobile-menu-panel__cta {
      opacity: 1;
      position: relative;
      z-index: 1;
    }

    #site-header.is-menu-open .mobile-menu-panel {
      transition:
        opacity 0.32s var(--ease-out-expo),
        transform 0.46s var(--ease-out-expo),
        visibility 0s;
    }
  }
</style>
