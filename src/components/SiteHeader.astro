---
import { site, nav } from '../data/site';
---
<header id="site-header" class="fixed top-0 z-[100] w-full border-b border-line/60 bg-ink/70 backdrop-blur-xl transition-all duration-500">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 md:px-8">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-3" aria-label="FIDIC.uz — на главную">
      <span class="flex h-9 w-9 items-center justify-center rounded-md border border-brass/40 bg-ink-2 transition-colors duration-500 group-hover:border-brass">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 6.5C7 4.8 9.5 4.8 12 6.2C14.5 4.8 17 4.8 20 6.5V18C17 16.6 14.5 16.6 12 18C9.5 16.6 7 16.6 4 18V6.5Z" stroke="var(--color-brass)" stroke-width="1.4" stroke-linejoin="round"/>
          <path d="M12 6.2V18" stroke="var(--color-brass)" stroke-width="1.4"/>
        </svg>
      </span>
      <span class="font-display text-xl font-700 tracking-tight text-fg">
        FIDIC<span class="text-brass">.uz</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 lg:flex">
      {nav.map((item) => (
        <a href={item.href} class="link-underline text-sm font-500 text-fg-dim transition-colors hover:text-fg">{item.label}</a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="hidden items-center gap-4 lg:flex">
      <a href={site.contacts.telegram} target="_blank" rel="noopener" class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-fg-dim transition-all hover:border-brass hover:text-brass" title="Telegram">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.19-.08-.05-.19-.02-.27 0-.11.03-1.84 1.18-5.2 3.45-.49.33-.94.5-1.35.49-.45-.01-1.3-.25-1.94-.46-.78-.26-1.4-.4-1.34-.84.03-.23.36-.47.98-.72 3.85-1.68 6.42-2.78 7.71-3.32 3.67-1.53 4.43-1.8 4.93-1.81.11 0 .36.03.49.13.11.09.14.22.15.34.01.07.01.18 0 .22z"/></svg>
      </a>
      <a href="/#ask" class="btn btn-ghost py-2.5 text-xs">AI-помощник</a>
      <a href="/#contact" class="btn btn-primary py-2.5 text-xs">Консультация</a>
    </div>

    <!-- Mobile toggle -->
    <button id="menu-btn" class="relative z-[101] flex h-6 w-7 flex-col justify-between lg:hidden" aria-label="Меню">
      <span class="burger-1 h-[2px] w-full origin-left bg-fg transition-all duration-300"></span>
      <span class="burger-2 h-[2px] w-full bg-fg transition-all duration-300"></span>
      <span class="burger-3 h-[2px] w-full origin-left bg-fg transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="fixed inset-0 z-[100] flex translate-x-full flex-col bg-ink px-8 pt-28 transition-transform duration-500 lg:hidden">
    <nav class="flex flex-col gap-1">
      {nav.map((item) => (
        <a href={item.href} class="mobile-link border-b border-line/60 py-4 font-display text-2xl font-600 text-fg">{item.label}</a>
      ))}
    </nav>
    <div class="mt-10 flex flex-col gap-4">
      <a href="/#contact" class="btn btn-primary justify-center">Запросить консультацию</a>
      <a href={site.contacts.phoneHref} class="text-center text-lg font-600 text-fg-dim">{site.contacts.phone}</a>
    </div>
  </div>
</header>
