---
import { site, nav } from '../data/site';
import { type Lang, defaultLang, locales, languages, useTranslations, stripLocale, localizePath } from '../i18n/ui';

interface Props { lang?: Lang; langUrls?: Partial<Record<Lang, string>> }
const { lang = defaultLang, langUrls } = Astro.props;
const t = useTranslations(lang);

const canonical = stripLocale(Astro.url.pathname);
const home = localizePath('/', lang);
const navItems = nav.map((n) => ({ label: t(n.key), href: localizePath(n.href, lang) }));
const langLinks = locales.map((l) => ({ code: l, name: languages[l], href: langUrls?.[l] ?? localizePath(canonical, l), active: l === lang }));
const langShort: Record<Lang, string> = { ru: 'RU', en: 'EN', uz: 'UZ' };
---
<header id="site-header" class="fixed top-0 z-[100] w-full border-b border-line/60 bg-ink/70 backdrop-blur-xl transition-all duration-500">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 md:px-8">
    <!-- Logo -->
    <a href={home} class="group flex items-center gap-3" aria-label={`FIDIC.uz — ${t('header.home')}`}>
      <span class="flex h-9 w-9 items-center justify-center rounded-md border border-brass/40 bg-ink-2 transition-colors duration-500 group-hover:border-brass">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 6.5C7 4.8 9.5 4.8 12 6.2C14.5 4.8 17 4.8 20 6.5V18C17 16.6 14.5 16.6 12 18C9.5 16.6 7 16.6 4 18V6.5Z" stroke="var(--color-brass)" stroke-width="1.4" stroke-linejoin="round"/>
          <path d="M12 6.2V18" stroke="var(--color-brass)" stroke-width="1.4"/>
        </svg>
      </span>
      <span class="font-display text-xl font-700 tracking-tight text-fg">FIDIC<span class="text-brass">.uz</span></span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 lg:flex">
      {navItems.map((item) => (
        <a href={item.href} class="link-underline text-sm font-500 text-fg-dim transition-colors hover:text-fg">{item.label}</a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="hidden items-center gap-4 lg:flex">
      <!-- Language switcher -->
      <div class="flex items-center gap-1 rounded-full border border-line p-0.5" role="group" aria-label={t('header.lang')}>
        {langLinks.map((l) => (
          <a
            href={l.href}
            data-lang-switch
            aria-current={l.active ? 'true' : undefined}
            class={`rounded-full px-2.5 py-1 font-mono text-xs font-600 transition-colors ${l.active ? 'bg-brass text-[#1a1206]' : 'text-fg-dim hover:text-brass'}`}
          >{langShort[l.code]}</a>
        ))}
      </div>
      <a href={`${home}#ask`} class="btn btn-ghost py-2.5 text-xs">{t('header.ai')}</a>
      <a href={`${home}#contact`} class="btn btn-primary py-2.5 text-xs">{t('header.consult')}</a>
    </div>

    <!-- Mobile toggle -->
    <button id="menu-btn" class="relative z-[101] flex h-6 w-7 flex-col justify-between lg:hidden" aria-label={t('header.menu')}>
      <span class="burger-1 h-[2px] w-full origin-left bg-fg transition-all duration-300"></span>
      <span class="burger-2 h-[2px] w-full bg-fg transition-all duration-300"></span>
      <span class="burger-3 h-[2px] w-full origin-left bg-fg transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="fixed inset-0 z-[100] flex translate-x-full flex-col overflow-y-auto bg-ink px-8 pt-28 pb-10 transition-transform duration-500 lg:hidden">
    <div class="mb-8 flex items-center justify-center gap-2">
      {langLinks.map((l) => (
        <a href={l.href} data-lang-switch class={`rounded-full border px-4 py-2 font-mono text-sm font-600 transition-colors ${l.active ? 'border-brass bg-brass text-[#1a1206]' : 'border-line text-fg-dim'}`}>{langShort[l.code]}</a>
      ))}
    </div>
    <nav class="flex flex-col gap-1">
      {navItems.map((item) => (
        <a href={item.href} class="mobile-link border-b border-line/60 py-4 font-display text-2xl font-600 text-fg">{item.label}</a>
      ))}
    </nav>
    <div class="mt-10 flex flex-col gap-4">
      <a href={`${home}#contact`} class="btn btn-primary justify-center">{t('header.consultFull')}</a>
      <a href={site.contacts.phoneHref} class="text-center text-lg font-600 text-fg-dim">{site.contacts.phone}</a>
    </div>
  </div>
</header>
