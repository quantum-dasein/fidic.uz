---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { type Lang, defaultLang, localizePath } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;

const copy = {
  ru: {
    title: 'Чеклист готовности claim по FIDIC',
    h1: 'Проверьте готовность claim по FIDIC',
    sub: 'Короткая самодиагностика: notices, records, causation, quantum и стратегия подачи. Это не юридическое заключение, а быстрый способ понять, насколько claim готов к проверке Инженером, DAAB или заказчиком.',
    meta: 'FIDIC claim readiness checklist: проверьте notices, contemporary records, delay/disruption evidence, quantum и contract administration перед подачей claim.',
    badge: 'Интерактивный инструмент',
    how: 'Как считать результат',
    howText: 'Отвечайте честно. “Да” даёт полный балл, “частично” - половину, “нет” - ноль. В конце вы получите уровень риска и практические следующие шаги.',
    yes: 'Да',
    partial: 'Частично',
    no: 'Нет',
    result: 'Результат',
    score: 'готовность',
    highTitle: 'Сильная позиция',
    highText: 'Claim выглядит подготовленным: есть процедура, доказательства и связка entitlement-causation-quantum. Перед подачей стоит сделать независимую review-проверку слабых мест.',
    midTitle: 'Средний уровень готовности',
    midText: 'Основание может быть, но доказательная архитектура ещё не закрыта. Лучше усилить records, расчёт и причинную связь до формальной подачи.',
    lowTitle: 'Высокий риск отказа',
    lowText: 'Claim пока уязвим: вероятно, не хватает notice discipline, contemporary records или расчёта. Сначала восстановите evidence file и уточните договорное основание.',
    next: 'Что сделать дальше',
    cta: 'Запросить экспертную проверку',
    copyBtn: 'Скопировать результат',
    exportPdf: 'Export PDF report',
    copied: 'Скопировано',
    disclaimer: 'Материал носит справочный характер и не является юридической консультацией. Итог зависит от текста контракта, Particular Conditions, применимого права и фактов проекта.',
    linksTitle: 'Полезно прочитать перед подачей claim',
    questions: [
      ['notice', 'Уведомление', 'Notice о claim направлен в договорный срок и по правильному каналу связи?'],
      ['entitlement', 'Договорное основание', 'В claim прямо указаны пункты контракта, Particular Conditions и требуемый вид relief?'],
