      ['programme', 'Программа', 'Влияние на сроки связано с activity IDs, обновлениями программы и critical path analysis?'],
      ['causation', 'Причинная связь', 'Claim объясняет цепочку событие -> влияние -> право -> сумма, без “global claim” логики?'],
      ['quantum', 'Расчёт суммы', 'Сумма подтверждена invoices, timesheets, payroll, equipment logs или другими actual cost records?'],
      ['disruption', 'Disruption / productivity', 'Если заявлено падение производительности, выбран метод оценки и отделены unrelated causes?'],
      ['prolongation', 'Prolongation costs', 'Если заявлены prolongation costs, определён affected period и подтверждены preliminaries/overheads?'],
      ['mitigation', 'Mitigation', 'Есть доказательства разумных мер по снижению последствий и объяснение, что нельзя было избежать?'],
      ['submission', 'Claim narrative', 'Подготовлен понятный claim narrative с приложениями, records matrix и итоговым требованием?'],
      ['review', 'Independent review', 'Перед подачей позицию проверил человек, не вовлечённый в ежедневную переписку по проекту?'],
