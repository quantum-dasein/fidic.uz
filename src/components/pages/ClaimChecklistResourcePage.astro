    leadMessage: 'Bepul FIDIC claim tayyorgarligi cheklistini so‘radi.',
    items: [
      ['Notice o‘z vaqtida', 'Notice shartnomaviy muddatda, odatda voqea ma’lum bo‘lgan kundan 28 kun ichida yuborilgan.'],
      ['Notice formasi', 'Rasmiy tartib bajarilgan: to‘g‘ri adresat, yozma shakl va tegishli clausega havola.'],
      ['Alohida event file', 'Voqea bo‘yicha alohida fayl ochilgan: chronology, letters, instructions, RFI, meeting minutes va photos.'],
      ['Contemporary records', 'Yozuvlar voqea davomida kunlik yoki haftalik yuritilgan, keyin qayta tiklanmagan.'],
      ['Causation', 'Zanjir ko‘rsatilgan: event → consequence → delay va/yoki cost.'],
      ['Oqibatlarni ajratish', 'Delay, disruption va prolongation costs bitta summaga qo‘shilmay, alohida ko‘rsatilgan.'],
      ['Contractual entitlement', 'Claim huquqini beruvchi contract clauses va Particular Conditions aniqlangan.'],
      ['Relief turi', 'Talab aniq: EOT, additional payment yoki ikkalasi.'],
      ['Delay analysis', 'EOT uchun programme impact va critical path logic tahlil qilingan.'],
      ['Cost evidence', 'Summalar invoices, timesheets, calculations va quotations bilan tasdiqlangan.'],
      ['Oraliq muddatlar', 'Fully detailed claim va keyingi submissions muddatlari tekshirilgan.'],
      ['Amaldagi versiya', 'Contract va appendices amaldagi versiyasi tekshirilgan; matn loyiha uchun moslashtirilgan.'],
    ],
  },
}[lang];

const contactHref = localizePath('/#contact', lang);
const pageUrl = `${site.url}${langUrls[lang]}`;
const checklistSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DigitalDocument',
      '@id': `${pageUrl}#claim-checklist`,
      url: pageUrl,
      name: copy.title,
      description: copy.description,
      inLanguage: lang,
      publisher: { '@id': `${site.url}/#organization` },
      about: [
        { '@type': 'Thing', name: 'FIDIC claims' },
        { '@type': 'Thing', name: 'Contemporary records' },
        { '@type': 'Thing', name: 'Delay analysis' },
        { '@type': 'Thing', name: 'Construction claim evidence' },
      ],
    },
    {
      '@type': 'ItemList',
      '@id': `${pageUrl}#checklist-items`,
      name: copy.h1,
      itemListElement: copy.items.map(([title, desc], index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: title,
        description: desc,
      })),
    },
  ],
};
---

<Layout
  lang={lang}
  langUrls={langUrls}
  title={`${copy.title} — FIDIC.uz`}
  description={copy.description}
  alwaysOpen
  bare={comingSoon}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(checklistSchema)} />
  </Fragment>

  <div class="lm">
  {comingSoon && (
    <a class="lm-back" href="/" data-back>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Назад · Back</span>
    </a>
  )}
  <section class="lm-hero">
    <div class="mx-auto max-w-3xl px-5 pt-16 pb-8 text-center md:px-8 md:pt-24 md:pb-10">
      <p class="lm-eyebrow">{copy.eyebrow}</p>
      <h1 class="lm-title">{copy.h1}</h1>
      <p class="lm-lead">{copy.lead}</p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-24 md:px-8">
    <div class="lm-card">
      <form id="lm-form" class="lm-form">
        <p class="lm-form__title">{copy.formTitle}</p>
        <div class="lm-field">
          <label for="lm-name">{copy.name}</label>
          <input id="lm-name" name="name" type="text" autocomplete="name" placeholder={copy.namePh} required />
        </div>
        <div class="lm-field">
          <label for="lm-contact">{copy.contact}</label>
          <input id="lm-contact" name="contact" type="text" autocomplete="email" placeholder={copy.contactPh} required />
        </div>
        <button type="submit" class="btn btn-primary w-full justify-center">{copy.submit}</button>
        <p class="lm-note">{copy.note}</p>
      </form>

      <div id="lm-result" class="lm-result" hidden>
        <div class="lm-result__head no-print">
          <p class="lm-result__ok">{copy.ok}</p>
          <button type="button" class="btn btn-ghost" data-lm-print>{copy.print}</button>
        </div>

        <article class="lm-doc">
          <header class="lm-doc__head">
            <p class="lm-doc__brand">FIDIC<span>.uz</span> · Bridge Consult</p>
            <h2>{copy.h1}</h2>
            <p class="lm-doc__sub">{copy.docSub}</p>
          </header>
          <ol class="lm-list">
            {copy.items.map(([title, desc]) => (
              <li>
                <span class="lm-list__check" aria-hidden="true"></span>
                <div>
                  <p class="lm-list__title">{title}</p>
                  <p class="lm-list__desc">{desc}</p>
                </div>
              </li>
            ))}
          </ol>
          <footer class="lm-doc__foot">
            <p>{copy.cta} <a href={contactHref}>{copy.ctaLink}</a> · Telegram {site.contacts.telegramHandle}</p>
            <p class="lm-doc__disc">{copy.disclaimer} © {new Date().getFullYear()} {site.poweredBy}.</p>
          </footer>
        </article>
      </div>
    </div>
  </section>
  </div>
</Layout>

<script define:vars={{ leadTopic: copy.leadTopic, leadMessage: copy.leadMessage }}>
  (function () {
    var back = document.querySelector('[data-back]');
    if (back) back.addEventListener('click', function (e) {
      if (window.history.length > 1) { e.preventDefault(); window.history.back(); }
    });

    var form = document.getElementById('lm-form');
    var result = document.getElementById('lm-result');
    if (!form || !result) return;

    var printBtn = document.querySelector('[data-lm-print]');
    if (printBtn) printBtn.addEventListener('click', function () { window.print(); });

    function reveal() {
      form.setAttribute('hidden', '');
      result.removeAttribute('hidden');
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (window.gtag) window.gtag('event', 'lead_magnet_unlock', { event_category: 'lead', magnet: 'claim-checklist' });
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var name = (document.getElementById('lm-name').value || '').trim();
      var contact = (document.getElementById('lm-contact').value || '').trim();
      if (!name || !contact) return;

      fetch('/api/lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          name: name,
          contact: contact,
          topic: leadTopic,
          message: leadMessage,
          source: 'lead-magnet/claim-checklist',
        }),
      }).then(reveal, reveal);
    });
  })();
</script>

<style>
  .lm {
    background:
      radial-gradient(circle at 78% 4%, rgba(201, 164, 92, 0.14), transparent 34rem),
      radial-gradient(circle at 10% 70%, rgba(91, 140, 255, 0.1), transparent 36rem),
      var(--color-ink);
  }
  .lm-hero { background: transparent; }
  .lm-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: clamp(1.1rem, 3vw, 1.6rem) 0 0 clamp(1rem, 4vw, 2rem);
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: rgba(4, 6, 10, 0.5);
    color: var(--color-fg-dim);
    font-size: 0.82rem;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
  }
  .lm-back:hover { color: var(--color-brass-bright); border-color: var(--color-brass); }
  .lm-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brass);
  }
  .lm-title {
    margin-top: 0.7rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 3.4rem);
    line-height: 1.05;
    color: var(--color-fg);
  }
  .lm-lead {
    margin: 1.1rem auto 0;
    max-width: 42rem;
    color: var(--color-fg-dim);
    line-height: 1.65;
  }
  .lm-card {
    border: 1px solid var(--color-line);
    border-radius: 1.1rem;
    padding: clamp(1.4rem, 4vw, 2.4rem);
    background: rgba(255, 255, 255, 0.022);
    backdrop-filter: blur(2px);
  }
  .lm-form__title {
    margin-bottom: 1.1rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-fg);
  }
  .lm-field { display: grid; gap: 0.4rem; margin-bottom: 0.9rem; }
  .lm-field label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .lm-field input {
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: 0.7rem;
    padding: 0.85rem 0.95rem;
    background: rgba(4, 6, 10, 0.62);
    color: var(--color-fg);
    outline: none;
  }
  .lm-field input:focus { border-color: var(--color-brass); }
  .lm-note { margin-top: 0.8rem; font-size: 0.78rem; color: var(--color-muted); line-height: 1.5; }
  .lm-result__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1.4rem;
  }
  .lm-result__ok { color: var(--color-brass-bright); font-weight: 600; }
  .lm-doc__head { border-bottom: 1px solid var(--color-line); padding-bottom: 1rem; }
  .lm-doc__brand {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }
  .lm-doc__brand span { color: var(--color-brass); }
  .lm-doc__head h2 {
    margin-top: 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    font-weight: 700;
    color: var(--color-fg);
  }
  .lm-doc__sub { margin-top: 0.4rem; color: var(--color-fg-dim); font-size: 0.92rem; }
  .lm-list { margin-top: 1.4rem; display: grid; gap: 1rem; counter-reset: lm; }
  .lm-list li { display: grid; grid-template-columns: auto 1fr; gap: 0.8rem; align-items: start; }
  .lm-list__check {
    counter-increment: lm;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border: 1px solid color-mix(in oklab, var(--color-brass) 45%, var(--color-line));
    border-radius: 999px;
    color: var(--color-brass-bright);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .lm-list__check::before { content: counter(lm); }
  .lm-list__title { font-weight: 600; color: var(--color-fg); }
  .lm-list__desc { margin-top: 0.2rem; color: var(--color-fg-dim); font-size: 0.92rem; line-height: 1.55; }
  .lm-doc__foot { margin-top: 1.6rem; border-top: 1px solid var(--color-line); padding-top: 1rem; }
  .lm-doc__foot p { font-size: 0.85rem; color: var(--color-fg-dim); line-height: 1.6; }
  .lm-doc__foot a { color: var(--color-brass); }
  .lm-doc__disc { margin-top: 0.5rem; font-size: 0.74rem; color: var(--color-muted); }

  @media print {
    .no-print { display: none !important; }
    .lm-hero, .site-header, .site-footer, #scroll-progress, #cursor-dot, #cursor-ring { display: none !important; }
    .lm-card { border: none !important; background: #fff !important; padding: 0 !important; }
    .lm-doc, .lm-doc * { color: #111 !important; }
    .lm-doc__sub, .lm-list__desc, .lm-doc__foot p { color: #444 !important; }
    .lm-list__check { color: #6b4e16 !important; border-color: #b9892f !important; }
  }
</style>
