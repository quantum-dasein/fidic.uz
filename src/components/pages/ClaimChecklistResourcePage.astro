---
import Layout from '../../layouts/Layout.astro';
import { site, comingSoon } from '../../data/site';
import { type Lang, defaultLang, localizePath } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;

const langUrls = {
  ru: '/resources/claim-checklist/',
  en: '/en/resources/claim-checklist/',
  uz: '/uz/resources/claim-checklist/',
