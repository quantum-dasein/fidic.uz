      ['Анализ задержки', 'Для EOT выполнен delay analysis по программе работ с оценкой влияния на критический путь.'],
      ['Обоснование затрат', 'Суммы подтверждены первичными документами: счета, табели, расчеты, котировки.'],
      ['Промежуточные сроки', 'Проверены сроки fully detailed claim и последующих submissions по контракту.'],
      ['Актуальная версия', 'Проверена действующая редакция контракта и приложений; формулировки адаптированы под проект.'],
    ],
  },
  en: {
    title: 'Free FIDIC claim readiness checklist',
    description: 'Download a free 12-point checklist for preparing a FIDIC claim before expert review.',
    eyebrow: 'Free resource · PDF',
    h1: 'FIDIC claim readiness checklist',
    lead: '12 checkpoints an expert will test before a claim is submitted: notices, deadlines, contemporary records, causation, delay analysis and cost evidence.',
    formTitle: 'Get the checklist free',
    name: 'Name',
    namePh: 'Your name',
    contact: 'Phone / Telegram / email',
    contactPh: '+998 ... / @username',
    submit: 'Open checklist →',
    note: 'By submitting the form, you agree that Bridge Consult may contact you.',
    ok: '✓ Done. The checklist is open below.',
    print: 'Print / Save PDF',
    docSub: '12 review points before submitting a claim under FIDIC contracts.',
    cta: 'Need an expert review of your claim?',
    ctaLink: 'Send a request',
    disclaimer: 'For reference only; this is not legal advice.',
    leadTopic: 'Lead magnet: FIDIC claim readiness checklist',
    leadMessage: 'Requested the free FIDIC claim readiness checklist.',
    items: [
      ['Notice on time', 'The notice was submitted within the contractual time limit, commonly 28 days from awareness of the event.'],
      ['Notice form', 'The formal route is respected: correct addressee, written notice and reference to the relevant clause.'],
      ['Separate event file', 'The event has its own file: chronology, letters, instructions, RFI, meeting minutes and photographs.'],
      ['Contemporary records', 'Daily or weekly records are kept during the event, not reconstructed later.'],
      ['Causation', 'The chain is shown: event → consequence → delay and/or cost.'],
      ['Separated consequences', 'Delay, disruption and prolongation costs are separated instead of being merged into one figure.'],
      ['Contractual entitlement', 'The claim identifies the contract clauses and Particular Conditions that create entitlement.'],
      ['Relief sought', 'The requested relief is clear: EOT, additional payment, or both.'],
      ['Delay analysis', 'For EOT, the programme impact and critical path logic have been analysed.'],
      ['Cost evidence', 'Amounts are supported by source documents: invoices, timesheets, calculations and quotations.'],
      ['Interim deadlines', 'Deadlines for the fully detailed claim and later submissions have been checked.'],
      ['Current version', 'The applicable contract and appendices are checked; wording is adapted to the project.'],
    ],
  },
  uz: {
    title: 'Bepul FIDIC claim tayyorgarligi cheklisti',
    description: 'Ekspert tekshiruvidan oldin FIDIC claim tayyorlash uchun 12 punktli bepul cheklist.',
    eyebrow: 'Bepul material · PDF',
    h1: 'FIDIC claim tayyorgarligi cheklisti',
    lead: 'Claim topshirishdan oldin ekspert tekshiradigan 12 punkt: notice, muddatlar, contemporary records, causation, delay analysis va cost evidence.',
    formTitle: 'Cheklistni bepul olish',
    name: 'Ism',
    namePh: 'Ismingiz',
    contact: 'Telefon / Telegram / email',
    contactPh: '+998 ... / @username',
    submit: 'Cheklistni ochish →',
    note: 'Formani yuborish orqali Bridge Consult jamoasi siz bilan bog‘lanishi mumkinligiga rozilik bildirasiz.',
    ok: '✓ Tayyor. Cheklist quyida ochildi.',
    print: 'Chop etish / PDF saqlash',
    docSub: 'FIDIC shartnomalari bo‘yicha claim topshirishdan oldingi 12 tekshiruv punkti.',
