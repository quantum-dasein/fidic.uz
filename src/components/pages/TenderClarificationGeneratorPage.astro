---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { type Lang, defaultLang, localizePath } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;

const copy = {
  ru: {
    title: 'Tender Clarification Generator',
    meta: 'Генератор вопросов для clarification stage по тендерам FIDIC: scope, Contract Data, payment, securities, ESHS, notices, DAAB и claims.',
    badge: 'Pre-bid clarification tool',
    h1: 'Tender Clarification Generator',
    sub: 'Отметьте слабые места tender package, а инструмент соберет структурированный список вопросов для clarification stage: что уточнить у Employer, где зафиксировать assumptions и какие темы вынести на pre-bid review.',
    start: 'Собрать вопросы',
    consult: 'Обсудить тендер',
    panelTitle: 'Clarification pack',
    selected: 'выбрано',
    priority: 'Приоритет',
    questions: 'Вопросы для clarification',
    assumptions: 'Commercial assumptions',
    copy: 'Скопировать список',
    copied: 'Скопировано',
    reset: 'Сбросить',
    empty: 'Выберите риски слева. Здесь появится список вопросов, который можно отправить команде тендера или включить в clarification request.',
    disclaimer: 'Инструмент не заменяет анализ тендерной документации. Формулировки нужно адаптировать под конкретные Instructions to Bidders, Particular Conditions, Contract Data и правила закупки.',
    ctaText: 'Bridge Consult может подготовить pre-bid review: карту рисков, список clarification questions, коммерческие assumptions и go/no-go memo.',
    ctaButton: 'Запросить pre-bid review',
    categories: {
      scope: 'Scope & design',
      commercial: 'Price & securities',
      time: 'Time & claims',
      governance: 'ESHS & disputes',
    },
    risks: [
      {
        id: 'scope-hierarchy',
        category: 'scope',
        priority: 'High',
        title: 'Конфликт документов или неясная иерархия',
        note: 'Contract Data, Particular Conditions, specifications, drawings или Employer’s Requirements ссылаются друг на друга неочевидно.',
        questions: [
          'Please confirm the order of precedence between Contract Data, Particular Conditions, Employer’s Requirements, drawings, specifications and schedules.',
          'Please identify the controlling version/date of each tender document and confirm whether later addenda supersede earlier documents.',
        ],
        assumptions: ['Do not price conflicting requirements twice unless the Employer confirms cumulative scope.'],
      },
      {
        id: 'design-boundary',
        category: 'scope',
        priority: 'High',
        title: 'Неясная граница design responsibility',
        note: 'Непонятно, где заканчивается Employer design и где начинается Contractor design, review и fitness-for-purpose exposure.',
        questions: [
          'Please clarify the boundary between Employer-provided design, Contractor design development and design verification responsibilities.',
          'Please confirm whether the Particular Conditions modify design liability, fitness-for-purpose obligations or review/approval consequences.',
        ],
        assumptions: ['Price design development only to the extent expressly allocated to the Contractor.'],
      },
      {
        id: 'quantities',
        category: 'scope',
        priority: 'Medium',
        title: 'BoQ, quantities или measurement basis вызывают вопросы',
        note: 'Количество, method of measurement или lump-sum/remeasurement logic не сходятся с техническим scope.',
        questions: [
          'Please clarify whether the contract price is lump-sum, remeasurement, milestone-based or a hybrid mechanism.',
          'Please confirm whether quantities in the BoQ are binding, indicative or subject to remeasurement under the contract.',
        ],
        assumptions: ['Maintain a pricing assumption log for quantities that cannot be verified before submission.'],
      },
      {
        id: 'payment-cycle',
        category: 'commercial',
        priority: 'High',
        title: 'Cash-flow risk в платежном механизме',
        note: 'Есть задержки certification, сложный IPC pack, удержания, advance payment gaps или unclear deductions.',
        questions: [
          'Please confirm the required documents, review period and certification period for each interim payment application.',
          'Please clarify the triggers, caps and timing for retention, deductions, advance payment recovery and release of retention.',
        ],
        assumptions: ['Model working capital exposure under conservative certification and payment timing.'],
      },
      {
        id: 'securities',
        category: 'commercial',
        priority: 'High',
        title: 'Securities и guarantees выглядят жестко',
        note: 'Performance Security, advance guarantee, parent guarantee или extended validity могут создать disproportionate exposure.',
        questions: [
          'Please confirm the form, amount, expiry date, extension mechanism and release trigger for each required security.',
          'Please clarify whether securities are on-demand, conditional or subject to any prior determination/certification requirement.',
        ],
        assumptions: ['Check bankability of guarantee forms before final bid approval.'],
      },
      {
        id: 'price-adjustment',
        category: 'commercial',
        priority: 'Medium',
        title: 'Inflation, currency и tax assumptions не закрыты',
        note: 'Нет ясности по price adjustment, currency split, exchange risk, tax-inclusive pricing или import assumptions.',
        questions: [
          'Please confirm whether price adjustment applies and identify the applicable indices, formula and base date.',
          'Please clarify the currency split, payment currency, exchange-rate mechanism and tax/import assumptions required for pricing.',
        ],
        assumptions: ['Avoid legal conclusions on tax/permanent establishment in the bid; flag them for specialist review.'],
      },
      {
        id: 'access-permits',
        category: 'time',
        priority: 'High',
        title: 'Access, permits и interfaces влияют на critical path',
        note: 'Сроки зависят от site access, permits, utilities, third parties или Employer-supplied information.',
        questions: [
          'Please confirm the dates, conditions and limits for site access, possession and handover of work fronts.',
          'Please clarify responsibility for permits, approvals, utilities, third-party interfaces and consequences of delay in those items.',
        ],
        assumptions: ['Treat uncontrolled access and permit dependencies as schedule qualifications or risk allowances.'],
      },
      {
        id: 'notices',
        category: 'time',
        priority: 'High',
        title: 'Notice procedure и time-bars неочевидны',
        note: 'Не ясно, куда направлять notices, кто authorised representative и как считать 28/84-day deadlines.',
        questions: [
          'Please confirm the official communication channels, authorised representatives and service rules for notices.',
          'Please clarify all claim notice and fully detailed claim deadlines, including any amendments in Particular Conditions.',
        ],
        assumptions: ['Set up a notice register from day one if awarded.'],
      },
      {
        id: 'records',
        category: 'time',
        priority: 'Medium',
        title: 'Records для claims не описаны достаточно практично',
        note: 'Требования к programme updates, daily records, cost records и substantiation неочевидны.',
        questions: [
          'Please confirm the required format and frequency for programme updates, progress records and cost records.',
          'Please clarify what records are required to substantiate EOT, disruption, variations and prolongation costs.',
        ],
        assumptions: ['Include claim administration resources in preliminaries where record burden is material.'],
      },
      {
        id: 'eshs',
        category: 'governance',
        priority: 'Medium',
        title: 'ESHS obligations могут быть недооценены',
        note: 'MDB-funded projects often include reporting, staffing, plans, remedies and payment consequences that affect price.',
        questions: [
          'Please clarify ESHS staffing, reporting, plan approval, monitoring and non-compliance consequences.',
          'Please confirm whether ESHS deliverables affect payment certification, suspension, termination or bid evaluation.',
        ],
        assumptions: ['Price ESHS as an operational workstream, not as a generic compliance note.'],
      },
      {
        id: 'daab',
        category: 'governance',
        priority: 'Medium',
        title: 'Engineer / DAAB / dispute pathway неполный',
        note: 'Не ясно, standing or ad hoc DAAB, кто платит, когда appoint, какие procedural rules и timelines.',
        questions: [
          'Please confirm whether the DAAB is standing or ad hoc, the appointment timing, member selection mechanism and cost sharing.',
          'Please clarify Engineer determination timelines and the escalation path from claim to dispute and arbitration.',
        ],
        assumptions: ['Include dispute administration cost and time where DAAB structure is complex.'],
      },
      {
        id: 'evaluation',
        category: 'governance',
        priority: 'High',
        title: 'Evaluation criteria и deviations policy могут повлиять на responsiveness',
        note: 'Bid can lose not because of price, but because of non-compliance, missing evidence or impermissible qualifications.',
        questions: [
          'Please clarify the treatment of deviations, qualifications, alternative offers and assumptions in bid evaluation.',
          'Please confirm the evidence required for technical merit, experience, financial capacity and key personnel scoring.',
        ],
        assumptions: ['Separate commercial risk qualifications from compliance-critical bid statements.'],
      },
    ],
  },
  en: {
    title: 'Tender Clarification Generator',
    meta: 'Generate clarification-stage questions for FIDIC tenders: scope, Contract Data, payment, securities, ESHS, notices, DAAB and claims.',
    badge: 'Pre-bid clarification tool',
    h1: 'Tender Clarification Generator',
    sub: 'Select weak points in a tender package and generate a structured clarification list: what to ask the Employer, where to record assumptions and what needs pre-bid review.',
    start: 'Generate questions',
    consult: 'Discuss a tender',
    panelTitle: 'Clarification pack',
    selected: 'selected',
    priority: 'Priority',
    questions: 'Clarification questions',
    assumptions: 'Commercial assumptions',
    copy: 'Copy list',
    copied: 'Copied',
    reset: 'Reset',
    empty: 'Select risks on the left. Your clarification request list will appear here.',
    disclaimer: 'This tool does not replace review of the tender documents. Adapt wording to the Instructions to Bidders, Particular Conditions, Contract Data and procurement rules.',
    ctaText: 'Bridge Consult can prepare a pre-bid review: risk map, clarification questions, commercial assumptions and a go/no-go memo.',
    ctaButton: 'Request pre-bid review',
    categories: {
      scope: 'Scope & design',
      commercial: 'Price & securities',
      time: 'Time & claims',
      governance: 'ESHS & disputes',
    },
    risks: [] as any[],
  },
  uz: {
    title: 'Tender Clarification Generator',
    meta: 'FIDIC tenderlari uchun clarification savollarini tuzish: scope, Contract Data, payment, securities, ESHS, notices, DAAB va claims.',
    badge: 'Pre-bid clarification tool',
    h1: 'Tender Clarification Generator',
    sub: 'Tender paketidagi zaif joylarni tanlang va Employerga beriladigan savollar, pricing assumptions va pre-bid review uchun mavzular ro‘yxatini oling.',
    start: 'Savollarni tuzish',
    consult: 'Tenderni muhokama qilish',
    panelTitle: 'Clarification pack',
    selected: 'tanlandi',
    priority: 'Ustuvorlik',
    questions: 'Clarification savollari',
    assumptions: 'Commercial assumptions',
    copy: 'Ro‘yxatni nusxalash',
    copied: 'Nusxalandi',
    reset: 'Tozalash',
    empty: 'Chap tomondagi risklarni tanlang. Bu yerda clarification request ro‘yxati paydo bo‘ladi.',
    disclaimer: 'Bu vosita tender hujjatlarini tahlil qilishni almashtirmaydi. Matnni Instructions to Bidders, Particular Conditions, Contract Data va xarid qoidalariga moslang.',
    ctaText: 'Bridge Consult pre-bid review tayyorlashi mumkin: risk map, clarification questions, commercial assumptions va go/no-go memo.',
    ctaButton: 'Pre-bid review so‘rash',
    categories: {
      scope: 'Scope & design',
      commercial: 'Price & securities',
      time: 'Time & claims',
      governance: 'ESHS & disputes',
    },
    risks: [] as any[],
  },
} as const;

const localizedRiskText: Record<'en' | 'uz', Record<string, { title: string; note: string }>> = {
  en: {
    'scope-hierarchy': {
      title: 'Conflicting documents or unclear hierarchy',
      note: 'Contract Data, Particular Conditions, specifications, drawings or Employer’s Requirements cross-refer in a way that is hard to price.',
    },
    'design-boundary': {
      title: 'Unclear design responsibility boundary',
      note: 'It is not clear where Employer design ends and Contractor design, review and fitness-for-purpose exposure begin.',
    },
    quantities: {
      title: 'BoQ, quantities or measurement basis need clarification',
      note: 'Quantities, method of measurement or lump-sum/remeasurement logic do not align cleanly with the technical scope.',
    },
    'payment-cycle': {
      title: 'Cash-flow risk in the payment mechanism',
      note: 'Certification periods, IPC documents, retention, advance payment recovery or deductions may create a working-capital gap.',
    },
    securities: {
      title: 'Securities and guarantees look heavy',
      note: 'Performance Security, advance guarantee, parent guarantee or extended validity may create disproportionate exposure.',
    },
    'price-adjustment': {
      title: 'Inflation, currency and tax assumptions are open',
      note: 'Price adjustment, currency split, exchange risk, tax-inclusive pricing or import assumptions are not settled.',
    },
    'access-permits': {
      title: 'Access, permits and interfaces affect the critical path',
      note: 'Programme depends on site access, permits, utilities, third parties or Employer-supplied information.',
    },
    notices: {
      title: 'Notice procedure and time-bars are not clear',
      note: 'The tender does not clearly state where notices go, who is authorised and how 28/84-day deadlines are counted.',
    },
    records: {
      title: 'Claim records are not described practically enough',
      note: 'Requirements for programme updates, daily records, cost records and substantiation are not clear enough for administration.',
    },
    eshs: {
      title: 'ESHS obligations may be underpriced',
      note: 'MDB-funded projects often include reporting, staffing, plans, remedies and payment consequences that affect price.',
    },
    daab: {
      title: 'Engineer / DAAB / dispute pathway is incomplete',
      note: 'Standing or ad hoc DAAB, appointment timing, costs, procedural rules and timelines need confirmation.',
    },
    evaluation: {
      title: 'Evaluation criteria and deviations policy may affect responsiveness',
      note: 'A bid can lose not because of price, but because of non-compliance, missing evidence or impermissible qualifications.',
    },
  },
  uz: {
    'scope-hierarchy': {
      title: 'Hujjatlar ziddiyati yoki noaniq ustuvorlik tartibi',
      note: 'Contract Data, Particular Conditions, specifications, drawings yoki Employer’s Requirements o‘zaro noaniq bog‘langan.',
    },
    'design-boundary': {
      title: 'Design responsibility chegarasi noaniq',
      note: 'Employer design qayerda tugashi va Contractor design, review hamda fitness-for-purpose exposure qayerda boshlanishi aniq emas.',
    },
    quantities: {
      title: 'BoQ, quantities yoki measurement basis aniqlashtirilishi kerak',
      note: 'Miqdorlar, measurement usuli yoki lump-sum/remeasurement mantig‘i technical scope bilan to‘liq mos emas.',
    },
    'payment-cycle': {
      title: 'Payment mechanism ichida cash-flow riski bor',
      note: 'Certification, IPC hujjatlari, retention, advance payment recovery yoki deductions working-capital bosimini yaratishi mumkin.',
    },
    securities: {
      title: 'Securities va guarantees juda og‘ir ko‘rinadi',
      note: 'Performance Security, advance guarantee, parent guarantee yoki extended validity nomutanosib risk yaratishi mumkin.',
    },
    'price-adjustment': {
      title: 'Inflation, currency va tax assumptions ochiq qolgan',
      note: 'Price adjustment, currency split, exchange risk, tax-inclusive pricing yoki import assumptions aniq emas.',
    },
    'access-permits': {
      title: 'Access, permits va interfaces critical pathga ta’sir qiladi',
      note: 'Jadval site access, permits, utilities, third parties yoki Employer-supplied informationga bog‘liq.',
    },
    notices: {
      title: 'Notice procedure va time-bars noaniq',
      note: 'Notices qayerga yuborilishi, authorised representative kimligi va 28/84-day deadlines qanday hisoblanishi aniq emas.',
    },
    records: {
      title: 'Claims uchun records yetarlicha amaliy tasvirlanmagan',
      note: 'Programme updates, daily records, cost records va substantiation talablari boshqaruv uchun yetarlicha aniq emas.',
    },
    eshs: {
      title: 'ESHS obligations narxda yetarlicha hisobga olinmasligi mumkin',
      note: 'MDB loyihalarida reporting, staffing, plans, remedies va payment consequences narxga ta’sir qiladi.',
    },
    daab: {
      title: 'Engineer / DAAB / dispute pathway to‘liq emas',
      note: 'Standing yoki ad hoc DAAB, appointment timing, costs, procedural rules va timelines tasdiqlanishi kerak.',
    },
    evaluation: {
      title: 'Evaluation criteria va deviations policy responsivenessga ta’sir qilishi mumkin',
      note: 'Bid narx tufayli emas, non-compliance, missing evidence yoki ruxsat etilmagan qualifications tufayli yutqazishi mumkin.',
    },
  },
};

const localizedRisks = lang === 'ru'
  ? copy.ru.risks
  : copy.ru.risks.map((risk) => ({ ...risk, ...(localizedRiskText[lang][risk.id] ?? {}) }));

const c = {
  ...copy[lang],
  risks: localizedRisks,
};
const categoryIds = ['scope', 'commercial', 'time', 'governance'] as const;
const contactHref = `${localizePath('/', lang)}#contact`;
const riskLabHref = localizePath('/tools/tender-risk-lab', lang);
const pagePath = localizePath('/tools/tender-clarification-generator', lang);
---

<Layout
  lang={lang}
  title={`${c.title} — ${site.name}`}
  description={c.meta}
  keywords="FIDIC tender clarification questions, FIDIC tender review, pre-bid review, Contract Data, Particular Conditions, FIDIC claims, ESHS, DAAB"
>
  <section class="clarifier-hero relative overflow-hidden border-b border-line bg-ink pt-32">
    <div class="absolute inset-0 bp-grid opacity-50"></div>
    <div class="mx-auto grid max-w-7xl gap-10 px-5 pb-12 md:px-8 lg:grid-cols-12 lg:items-center lg:pb-16">
      <div class="relative z-10 lg:col-span-7">
        <p class="eyebrow">{c.badge}</p>
        <h1 class="mt-5 font-display text-5xl font-700 leading-[0.96] text-fg md:text-7xl">{c.h1}</h1>
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-fg-dim md:text-lg">{c.sub}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#generator" class="btn btn-primary justify-center">{c.start}</a>
          <a href={contactHref} class="btn btn-ghost justify-center">{c.consult}</a>
        </div>
      </div>

      <div class="clarifier-visual relative z-10 lg:col-span-5" aria-hidden="true">
        <div class="clarifier-stack">
          <span></span>
          <span></span>
          <span></span>
          <strong>FIDIC</strong>
        </div>
      </div>
    </div>
  </section>

  <section id="generator" class="mx-auto max-w-7xl px-5 py-12 md:px-8 md:py-16">
    <div class="grid gap-8 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <div class="mb-5 flex flex-wrap gap-2">
          {categoryIds.map((id) => (
            <button type="button" class="clarifier-filter" data-clarifier-filter={id}>{c.categories[id]}</button>
          ))}
          <button type="button" class="clarifier-filter is-active" data-clarifier-filter="all">All</button>
        </div>

        <form id="clarifier-form" class="grid gap-3">
          {c.risks.map((risk) => (
            <label class="clarifier-risk" data-risk-card data-category={risk.category}>
              <input type="checkbox" value={risk.id} />
              <span class="clarifier-risk__body">
                <span class="clarifier-risk__meta">
                  <span>{c.categories[risk.category as keyof typeof c.categories]}</span>
                  <strong>{risk.priority}</strong>
                </span>
                <span class="clarifier-risk__title">{risk.title}</span>
                <span class="clarifier-risk__note">{risk.note}</span>
              </span>
            </label>
          ))}
        </form>
      </div>

      <aside class="lg:col-span-5">
        <div class="clarifier-panel sticky top-28">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.panelTitle}</p>
              <h2 class="mt-3 font-display text-2xl font-700 text-fg">{c.questions}</h2>
            </div>
            <div class="clarifier-count"><span id="clarifier-count">0</span><small>{c.selected}</small></div>
          </div>

          <div id="clarifier-empty" class="mt-6 rounded-xl border border-line bg-ink-2/70 p-4 text-sm leading-relaxed text-fg-dim">{c.empty}</div>

          <div id="clarifier-output" class="hidden">
            <div class="clarifier-block">
              <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.priority}</p>
              <ul id="clarifier-priority" class="mt-3 space-y-2 text-sm leading-relaxed text-fg-dim"></ul>
            </div>

            <div class="clarifier-block">
              <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.questions}</p>
              <ol id="clarifier-questions" class="mt-3 space-y-2 text-sm leading-relaxed text-fg-dim"></ol>
            </div>

            <div class="clarifier-block">
              <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.assumptions}</p>
              <ul id="clarifier-assumptions" class="mt-3 space-y-2 text-sm leading-relaxed text-fg-dim"></ul>
            </div>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <button id="clarifier-copy" type="button" class="btn btn-ghost justify-center">{c.copy}</button>
            <button id="clarifier-reset" type="button" class="btn btn-ghost justify-center">{c.reset}</button>
          </div>
          <a href={contactHref} class="btn btn-primary mt-3 w-full justify-center">{c.ctaButton}</a>
          <p class="mt-5 text-xs leading-relaxed text-muted">{c.ctaText}</p>
          <p class="mt-4 text-xs leading-relaxed text-muted">{c.disclaimer}</p>
        </div>
      </aside>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <a class="clarifier-related" href={riskLabHref}>FIDIC Tender Risk Lab</a>
      <a class="clarifier-related" href={localizePath('/knowledge/claims-substantiation-records', lang)}>Claims substantiation and evidence architecture</a>
    </div>
  </section>

  <script is:inline define:vars={{ c, pagePath }}>
    (function () {
      var form = document.getElementById('clarifier-form');
      if (!form) return;
      var cards = Array.from(document.querySelectorAll('[data-risk-card]'));
      var filters = Array.from(document.querySelectorAll('[data-clarifier-filter]'));
      var countEl = document.getElementById('clarifier-count');
      var emptyEl = document.getElementById('clarifier-empty');
      var outputEl = document.getElementById('clarifier-output');
      var priorityEl = document.getElementById('clarifier-priority');
      var questionsEl = document.getElementById('clarifier-questions');
      var assumptionsEl = document.getElementById('clarifier-assumptions');
      var copyBtn = document.getElementById('clarifier-copy');
      var resetBtn = document.getElementById('clarifier-reset');

      function selectedRisks() {
        return c.risks.filter(function (risk) {
          var input = form.querySelector('input[value="' + risk.id + '"]');
          return input && input.checked;
        });
      }

      function unique(items) {
        return Array.from(new Set(items.filter(Boolean)));
      }

      function render() {
        var selected = selectedRisks();
        if (countEl) countEl.textContent = String(selected.length);

        cards.forEach(function (card) {
          var input = card.querySelector('input');
          card.classList.toggle('is-selected', Boolean(input && input.checked));
        });

        if (!selected.length) {
          emptyEl.classList.remove('hidden');
          outputEl.classList.add('hidden');
          return { selected: [], questions: [], assumptions: [] };
        }

        emptyEl.classList.add('hidden');
        outputEl.classList.remove('hidden');

        var high = selected.filter(function (risk) { return risk.priority === 'High'; });
        var priority = high.length ? high : selected.slice(0, 3);
        var questions = unique(selected.flatMap(function (risk) { return risk.questions; }));
        var assumptions = unique(selected.flatMap(function (risk) { return risk.assumptions; }));

        priorityEl.innerHTML = '';
        priority.forEach(function (risk) {
          var li = document.createElement('li');
          li.textContent = risk.priority + ': ' + risk.title;
          priorityEl.appendChild(li);
        });

        questionsEl.innerHTML = '';
        questions.forEach(function (item) {
          var li = document.createElement('li');
          li.textContent = item;
          questionsEl.appendChild(li);
        });

        assumptionsEl.innerHTML = '';
        assumptions.forEach(function (item) {
          var li = document.createElement('li');
          li.textContent = item;
          assumptionsEl.appendChild(li);
        });

        return { selected: selected, questions: questions, assumptions: assumptions };
      }

      filters.forEach(function (button) {
        button.addEventListener('click', function () {
          var filter = button.getAttribute('data-clarifier-filter');
          filters.forEach(function (btn) { btn.classList.toggle('is-active', btn === button); });
          cards.forEach(function (card) {
            var show = filter === 'all' || card.getAttribute('data-category') === filter;
            card.classList.toggle('hidden', !show);
          });
        });
      });

      form.addEventListener('change', render);
      render();

      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          form.querySelectorAll('input[type="checkbox"]').forEach(function (input) { input.checked = false; });
          render();
        });
      }

      if (copyBtn) {
        copyBtn.addEventListener('click', async function () {
          var result = render();
          var lines = [
            c.title,
            location.origin + pagePath,
            '',
            c.priority + ':',
          ].concat(
            result.selected.map(function (risk) { return '- ' + risk.priority + ': ' + risk.title; }),
            [''],
            [c.questions + ':'],
            result.questions.map(function (item) { return '- ' + item; }),
            [''],
            [c.assumptions + ':'],
            result.assumptions.map(function (item) { return '- ' + item; })
          );
          try {
            await navigator.clipboard.writeText(lines.join('\n'));
            var old = copyBtn.textContent;
            copyBtn.textContent = c.copied;
            setTimeout(function () { copyBtn.textContent = old; }, 1400);
          } catch (_) {
            window.prompt(c.copy, lines.join('\n'));
          }
        });
      }
    })();
  </script>

