---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleToolCta from '../ArticleToolCta.astro';
import ArticleConversionPanel from '../ArticleConversionPanel.astro';
import { site } from '../../data/site';
import { type Lang, defaultLang, locales, useTranslations, localizePath, dateLocale, categoryLabel } from '../../i18n/ui';

interface Props { article: CollectionEntry<'articles'>; lang?: Lang }
const { article, lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(article);

const slug = article.id.slice(lang.length + 1);

// Language switcher targets for this article: link to the translated article if it
// exists in that language, otherwise fall back to that language's knowledge index.
const allIds = new Set((await getCollection('articles')).map((a) => a.id));
const langUrls: Partial<Record<Lang, string>> = {};
for (const l of locales) {
  langUrls[l] = allIds.has(`${l}/${slug}`) ? localizePath(`/knowledge/${slug}`, l) : localizePath('/knowledge', l);
}
const dateStr = new Intl.DateTimeFormat(dateLocale(lang), { day: 'numeric', month: 'long', year: 'numeric' }).format(article.data.date);
const iso = article.data.date.toISOString();
const url = `${site.url}${localizePath(`/knowledge/${slug}`, lang)}`;
const knowledgeHref = localizePath('/knowledge', lang);
const contactHref = localizePath('/', lang) + '#contact';

const currentTags = new Set(article.data.tags.map((tag) => tag.toLowerCase()));
const related = (await getCollection('articles'))
  .filter((a) => a.id.startsWith(`${lang}/`) && a.id !== article.id)
  .map((a) => {
    const sharedTags = a.data.tags.filter((tag) => currentTags.has(tag.toLowerCase())).length;
    const categoryScore = a.data.category === article.data.category ? 4 : 0;
    return { article: a, score: categoryScore + sharedTags };
  })
  .filter((entry) => entry.score > 0)
  .sort((a, b) => b.score - a.score || b.article.data.date.getTime() - a.article.data.date.getTime())
  .slice(0, 3)
  .map((entry) => entry.article);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: iso,
  dateModified: iso,
  inLanguage: lang,
  articleSection: categoryLabel(article.data.category, lang),
  keywords: article.data.tags.join(', '),
  mainEntityOfPage: url,
  author: { '@type': 'Organization', name: article.data.author, url: site.poweredByUrl },
  publisher: { '@type': 'Organization', name: site.poweredBy, logo: { '@type': 'ImageObject', url: `${site.url}/favicon.svg` } },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('header.home'), item: `${site.url}${localizePath('/', lang)}` },
    { '@type': 'ListItem', position: 2, name: t('art.back'), item: `${site.url}${knowledgeHref}` },
    { '@type': 'ListItem', position: 3, name: article.data.title, item: url },
  ],
};

const visualCopy = {
  ru: {
    brief: 'Практическая карта статьи',
    lens: 'Контрактная оптика',
    clauses: 'Ключевые точки',
    path: 'Как читать материал',
    risk: 'Risk note',
    flow: ['Проблема', 'Доказательства', 'Решение'],
    defaultRisk: 'Проверьте текст договора, Particular Conditions и фактическую переписку проекта перед тем, как переносить выводы в позицию по claim, tender или dispute.',
    claimsRisk: 'Для claims главное не “сильная формулировка”, а цепочка: notice, contemporary records, причинность, программа и расчет.',
    tenderRisk: 'В tender risk важны не только цена и форма контракта, но и то, можно ли доказать assumptions до submission.',
    paymentRisk: 'В платежных вопросах всегда сверяйте механизм IPC, сроки сертификации, удержания и фактические cash-flow последствия.',
    disputeRisk: 'DAAB и dispute pathway работают только тогда, когда notice discipline, records и escalation steps собраны заранее.',
    read: 'Сначала определите контрактную проблему, затем проверьте доказательства и только после этого формулируйте практический шаг.',
  },
  en: {
    brief: 'Practical article map',
    lens: 'Contract lens',
    clauses: 'Key points',
    path: 'How to use this article',
    risk: 'Risk note',
    flow: ['Issue', 'Evidence', 'Action'],
    defaultRisk: 'Check the contract text, Particular Conditions and project correspondence before turning this article into a claim, tender or dispute position.',
    claimsRisk: 'For claims, the strength is not wording alone: it is notice, contemporary records, causation, programme evidence and quantum.',
    tenderRisk: 'Tender risk is not only price and contract form; it is whether assumptions can be proved before submission.',
    paymentRisk: 'For payment issues, always test the IPC mechanism, certification timing, deductions and actual cash-flow impact.',
    disputeRisk: 'DAAB and dispute pathways work only when notice discipline, records and escalation steps are prepared early.',
    read: 'Start with the contract issue, test the evidence, then define the practical next step.',
  },
  uz: {
    brief: 'Maqolaning amaliy xaritasi',
    lens: 'Shartnoma fokusi',
    clauses: 'Asosiy nuqtalar',
    path: 'Maqoladan qanday foydalanish',
    risk: 'Risk eslatmasi',
    flow: ['Muammo', 'Dalillar', 'Amal'],
    defaultRisk: 'Xulosalarni claim, tender yoki dispute pozitsiyasiga aylantirishdan oldin shartnoma matni, Particular Conditions va loyiha yozishmalarini tekshiring.',
    claimsRisk: 'Claims uchun kuchli pozitsiya faqat matn emas: notice, contemporary records, sababiy bogliqlik, programme evidence va quantum kerak.',
    tenderRisk: 'Tender risk faqat narx va contract form emas; assumptions submissiondan oldin isbotlana oladimi, shuni tekshiring.',
    paymentRisk: 'Payment masalalarida IPC mexanizmi, certification muddati, deductions va cash-flow ta’sirini tekshiring.',
    disputeRisk: 'DAAB va dispute pathway faqat notice discipline, records va escalation steps oldindan tayyor bo‘lsa ishlaydi.',
    read: 'Avval shartnomaviy muammoni aniqlang, keyin dalillarni tekshiring va amaliy keyingi qadamni belgilang.',
  },
}[lang];

const topicText = `${article.data.title} ${article.data.description} ${article.data.category} ${article.data.tags.join(' ')}`.toLowerCase();
const articleRiskNote = topicText.includes('claim') || topicText.includes('eot') || topicText.includes('delay') || topicText.includes('disruption') || topicText.includes('prolongation')
  ? visualCopy.claimsRisk
  : topicText.includes('tender') || topicText.includes('procurement') || topicText.includes('bid')
    ? visualCopy.tenderRisk
    : topicText.includes('payment') || topicText.includes('security') || topicText.includes('guarantee') || topicText.includes('performance')
      ? visualCopy.paymentRisk
      : topicText.includes('daab') || topicText.includes('dispute') || topicText.includes('exceptional')
        ? visualCopy.disputeRisk
        : visualCopy.defaultRisk;
const clauseTags = article.data.tags
  .filter((tag) => /(clause|sub-clause|daab|eot|ipc|contract data|particular conditions|28|84|13|14|20|21|8\.|узел|пункт)/i.test(tag))
  .slice(0, 5);
const briefTags = (clauseTags.length ? clauseTags : article.data.tags).slice(0, 5);
const articleLens = categoryLabel(article.data.category, lang);
---
<Layout title={`${article.data.title} | ${site.name}`} description={article.data.description} type="article" keywords={article.data.tags.join(', ')} published={iso} lang={lang} langUrls={langUrls}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <article class="mx-auto max-w-3xl px-5 py-16 md:px-8 md:py-24">
    <a href={knowledgeHref} class="link-underline mb-10 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-muted hover:text-brass">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M11 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {t('art.back')}
    </a>

    <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-muted">
      <span class="text-brass uppercase tracking-widest">{categoryLabel(article.data.category, lang)}</span>
      <span>·</span><span>{dateStr}</span>
      <span>·</span><span>{article.data.readingTime} {t('card.min')}</span>
    </div>

    <h1 class="mt-5 font-display font-700 leading-[1.08] tracking-tight text-fg" style="font-size: clamp(1.8rem, 6vw, 3rem)">{article.data.title}</h1>
    <p class="mt-5 text-xl leading-relaxed text-fg-dim">{article.data.description}</p>

    {article.data.tags.length > 0 && (
      <div class="mt-7 flex flex-wrap gap-2">
        {article.data.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}

    <section class="article-visual-system mt-9" aria-label={visualCopy.brief}>
      <div class="article-visual-system__head">
        <p class="eyebrow">{visualCopy.brief}</p>
        <div class="article-visual-system__lens">
          <span>{visualCopy.lens}</span>
          <strong>{articleLens}</strong>
        </div>
      </div>

      <div class="article-visual-system__grid">
        <div class="article-visual-system__panel">
          <span class="article-visual-system__label">{visualCopy.clauses}</span>
          <div class="article-clause-chips">
            {briefTags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>

        <div class="article-visual-system__panel article-flow-card">
          <span class="article-visual-system__label">{visualCopy.path}</span>
          <div class="article-flow">
            {visualCopy.flow.map((step, index) => (
              <span>
                <small>{String(index + 1).padStart(2, '0')}</small>
                {step}
              </span>
            ))}
          </div>
          <p>{visualCopy.read}</p>
        </div>
      </div>

      <aside class="article-risk-note">
        <span>{visualCopy.risk}</span>
        <p>{articleRiskNote}</p>
      </aside>
    </section>

    <hr class="my-10 border-line" />

    <div class="prose-fidic">
      <Content />
    </div>

    <ArticleToolCta lang={lang} category={article.data.category} tags={article.data.tags} slug={slug} />
    <ArticleConversionPanel lang={lang} category={article.data.category} tags={article.data.tags} slug={slug} />

    <div class="mt-14 card p-7">
      <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{article.data.author}</p>
      <p class="mt-2 leading-relaxed text-fg-dim">{t('art.authorNote')}</p>
      <a
        href={contactHref}
        class="btn btn-primary mt-5"
        data-analytics-event="article_cta_click"
        data-analytics-cta-type="author_note"
        data-analytics-cta-rank="1"
        data-analytics-label={t('art.consult')}
        data-analytics-destination={contactHref}
        data-analytics-article-slug={slug}
        data-analytics-article-category={article.data.category}
        data-analytics-lang={lang}
      >{t('art.consult')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </article>

  {related.length > 0 && (
    <section class="border-t border-line">
      <div class="mx-auto max-w-3xl px-5 py-14 md:px-8">
        <p class="eyebrow mb-6">{t('art.related')}</p>
        <div class="grid gap-4 md:grid-cols-3">
          {related.map((a) => (
            <a href={localizePath(`/knowledge/${a.id.slice(lang.length + 1)}`, lang)} class="card group p-5">
              <span class="font-mono text-[11px] uppercase tracking-widest text-brass">{categoryLabel(a.data.category, lang)}</span>
              <h3 class="mt-2 font-display text-lg font-700 text-fg transition-colors group-hover:text-brass-bright">{a.data.title}</h3>
              <p class="mt-2 text-xs leading-relaxed text-muted">{a.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
