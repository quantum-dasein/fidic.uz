    ctaSuite: 'Open Rainbow Suite',
    ctaConsult: 'Check with an expert',
    exportPdf: 'Export PDF report',
    disclaimer: 'This is a preliminary guide, not legal advice. Always check MDB requirements, Particular Conditions, applicable law, procurement documents and the actual project scope.',
    options: {
      project: [['civil','Roads, bridges, buildings, civil works'],['plant','Plants, equipment, design-build'],['epc','IPP / PPP / EPC turnkey'],['small','Small or simple works']],
      design: [['employer','Employer / Engineer'],['contractor','Contractor'],['shared','Shared responsibility']],
      price: [['remeasure','Re-measurement / BoQ'],['lump','Lump sum'],['fixed','Maximum price/time certainty'],['flexible','Flexibility over fixed price']],
      funding: [['mdb','World Bank / ADB / EBRD / other MDB'],['private','Private investor / project finance'],['public','Public or corporate employer']],
      risk: [['balanced','Balanced risk allocation'],['employerCertainty','Employer needs price/time certainty'],['contractorControl','Contractor can take more risk for control']],
      ground: [['normal','No, ordinary conditions'],['underground','Yes, tunnels / metro / underground works'],['uncertain','Material geological uncertainty']],
    },
    books: {
      red: ['Red Book', 'Employer-designed construction with re-measurement. Strong when the Employer provides the design and payment follows actual quantities.'],
      yellow: ['Yellow Book', 'Plant and Design-Build. The Contractor designs and builds, usually lump sum, with an Engineer still administering the contract.'],
      silver: ['Silver Book', 'EPC/Turnkey. Maximum price and time certainty for the Employer, with high Contractor risk.'],
      pink: ['Pink Book', 'MDB Harmonised. Practical for World Bank, ADB, EBRD and other MDB-financed projects.'],
      emerald: ['Emerald Book', 'Underground Works. A specialised form for tunnels and underground works with geo-risk management.'],
      green: ['Green Book', 'Short Form. Compact form for small, simple or repetitive works.'],
    },
    reasons: {
      red: ['design stays with the Employer', 'payment by measured quantities', 'risk allocation is comparatively balanced'],
      yellow: ['the Contractor designs', 'suitable for plant/design-build', 'lump-sum logic without full EPC risk transfer'],
      silver: ['high price/time certainty is required', 'the Contractor controls design and procurement', 'suitable for project finance, IPP and PPP'],
      pink: ['the project is MDB-financed', 'bank-specific procurement and integrity provisions matter', 'based on Red Book logic with MDB requirements'],
      emerald: ['tunnels or underground works are involved', 'geo-risk needs a dedicated mechanism', 'GBR/ground conditions are central'],
      green: ['the project is small or simple', 'a short form is enough', 'full FIDIC administration would be excessive'],
    },
  },
  uz: {
    title: 'FIDIC kitobini tanlash',
    h1: 'Mos FIDIC kitobini tanlang',
    sub: 'Bir nechta amaliy savolga javob bering: kim loyihalashtiradi, to‘lov qanday bo‘ladi, narx aniqligi qanchalik muhim, XTB moliyalashtirishi yoki georisk bormi. Natija dastlabki yo‘nalish beradi.',
    meta: 'FIDIC Book Selector: infratuzilma loyihasi uchun Red Book, Yellow Book, Silver Book, Pink Book yoki Emerald Book tanlashga yordam beruvchi interaktiv vosita.',
    badge: 'Interaktiv tanlov vositasi',
    project: 'Loyiha turi',
    design: 'Kim loyihalashtiradi',
    price: 'Narx bo‘yicha ustuvorlik',
    funding: 'Moliyalashtirish',
    risk: 'Buyurtmachining risk profili',
    ground: 'Muhim georisk / yer osti ishlari',
    result: 'Tavsiya',
    match: 'moslik',
    riskShare: 'pudratchi riski',
    why: 'Nega shu shakl',
    alternatives: 'Alternativalar',
    ctaSuite: 'Rainbow Suite ochish',
    ctaConsult: 'Ekspert bilan tekshirish',
    exportPdf: 'PDF report export',
    disclaimer: 'Bu dastlabki yo‘riqnoma, yuridik maslahat emas. Har doim XTB talablari, Particular Conditions, qo‘llaniladigan huquq, procurement documents va loyiha scope’ini tekshiring.',
    options: {
      project: [['civil','Yo‘llar, ko‘priklar, binolar, civil works'],['plant','Zavodlar, uskunalar, design-build'],['epc','IPP / PPP / EPC kalit'],['small','Kichik yoki oddiy ishlar']],
      design: [['employer','Buyurtmachi / Muhandis'],['contractor','Pudratchi'],['shared','Birgalikdagi javobgarlik']],
      price: [['remeasure','O‘lchanadigan hajmlar / BoQ'],['lump','Lump sum'],['fixed','Narx/muddat aniqligi maksimal'],['flexible','Moslashuvchanlik muhimroq']],
      funding: [['mdb','World Bank / ADB / EBRD / boshqa XTB'],['private','Xususiy investor / project finance'],['public','Davlat yoki korporativ buyurtmachi']],
      risk: [['balanced','Muvozanatli risk taqsimoti'],['employerCertainty','Buyurtmachiga narx/muddat aniqligi kerak'],['contractorControl','Pudratchi ko‘proq risk olishga tayyor']],
      ground: [['normal','Yo‘q, oddiy sharoit'],['underground','Ha, tunnel / metro / yer osti ishlari'],['uncertain','Muhim geologik noaniqlik bor']],
    },
    books: {
      red: ['Red Book', 'Buyurtmachi loyihalashtiradigan qurilish va re-measurement. Loyiha Buyurtmachida bo‘lsa va to‘lov hajmlar bo‘yicha bo‘lsa mos.'],
      yellow: ['Yellow Book', 'Plant and Design-Build. Pudratchi loyihalashtiradi va quradi, odatda lump sum, Muhandis roli saqlanadi.'],
      silver: ['Silver Book', 'EPC/Turnkey. Buyurtmachi uchun narx va muddat aniqligi maksimal, Pudratchi riski yuqori.'],
      pink: ['Pink Book', 'MDB Harmonised. World Bank, ADB, EBRD va boshqa XTB loyihalari uchun amaliy tanlov.'],
      emerald: ['Emerald Book', 'Underground Works. Tunnel va yer osti ishlari uchun georisk boshqaruviga ega maxsus shakl.'],
      green: ['Green Book', 'Short Form. Kichik, oddiy yoki takrorlanuvchi ishlar uchun ixcham shakl.'],
    },
    reasons: {
      red: ['loyihalash Buyurtmachida qoladi', 'to‘lov o‘lchanadigan hajmlar bo‘yicha', 'risk nisbatan muvozanatli taqsimlanadi'],
      yellow: ['Pudratchi loyihalashtiradi', 'plant/design-build uchun mos', 'to‘liq EPC risk transfer emas'],
      silver: ['narx/muddat aniqligi yuqori kerak', 'Pudratchi design va procurement’ni nazorat qiladi', 'project finance, IPP va PPP uchun mos'],
      pink: ['loyiha XTB tomonidan moliyalashtiriladi', 'bank talablari va integrity provisions muhim', 'Red Book mantig‘i + XTB talablari'],
      emerald: ['tunnel yoki yer osti ishlari bor', 'georisk alohida mexanizm talab qiladi', 'GBR/ground conditions markaziy ahamiyatda'],
      green: ['loyiha kichik yoki oddiy', 'qisqa shakl yetarli', 'to‘liq FIDIC administratsiyasi ortiqcha bo‘lishi mumkin'],
    },
  },
} as const;

const books = [
  { id: 'red', hex: '#c0362c', risk: 40 },
  { id: 'yellow', hex: '#e0a82e', risk: 60 },
  { id: 'silver', hex: '#b9bcc4', risk: 85 },
  { id: 'pink', hex: '#d36a86', risk: 42 },
  { id: 'emerald', hex: '#0f8a6d', risk: 55 },
  { id: 'green', hex: '#2f8f5b', risk: 50 },
] as const;

const c = copy[lang];
const suiteHref = localizePath('/', lang) + '#suite';
const contactHref = localizePath('/', lang) + '#contact';
const pagePath = localizePath('/tools/book-selector', lang);
---

<Layout
  title={`${c.title} | ${site.name}`}
  description={c.meta}
  lang={lang}
  langUrls={{
    ru: '/tools/book-selector',
    en: '/en/tools/book-selector',
    uz: '/uz/tools/book-selector',
  }}
>
  <section class="relative border-b border-line">
    <div class="absolute inset-0 bp-grid opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
      <p class="eyebrow mb-4">{c.badge}</p>
      <div class="grid gap-10 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <h1 class="max-w-4xl font-display font-700 leading-[1.05] tracking-tight text-fg" style="font-size: clamp(2rem, 6vw, 4rem)">{c.h1}</h1>
          <p class="mt-5 max-w-3xl text-lg leading-relaxed text-fg-dim">{c.sub}</p>
        </div>
        <aside class="card overflow-hidden p-0 lg:col-span-4">
          <div class="h-2 bg-gradient-to-r from-fidic-red via-fidic-yellow to-fidic-emerald"></div>
          <div class="p-5">
            <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.result}</p>
            <p class="mt-3 text-sm leading-relaxed text-fg-dim">{c.disclaimer}</p>
            <div class="book-selector-stage mt-6" aria-hidden="true">
              <div class="book-selector-stack">
                {books.map((book, index) => (
                  <span class="book-selector-spine" style={`--book:${book.hex};--i:${index}`}></span>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-12 md:px-8 md:py-16">
    <div class="grid gap-8 lg:grid-cols-12">
      <form id="book-selector-form" class="space-y-5 lg:col-span-7">
        {[
          ['project', c.project, c.options.project],
          ['design', c.design, c.options.design],
          ['price', c.price, c.options.price],
          ['funding', c.funding, c.options.funding],
          ['risk', c.risk, c.options.risk],
          ['ground', c.ground, c.options.ground],
        ].map((group) => (
          <fieldset class="card p-5">
            <legend class="font-mono text-[11px] uppercase tracking-widest text-brass">{group[1]}</legend>
            <div class="mt-4 grid gap-2 sm:grid-cols-2">
              {(group[2] as readonly (readonly [string, string])[]).map((opt, index) => (
                <label class="book-selector-option flex cursor-pointer items-start gap-3 rounded-lg border border-line bg-ink-2/60 px-3 py-3 text-sm text-fg-dim transition-colors hover:border-brass hover:text-fg">
                  <input class="mt-1 accent-[var(--color-brass)]" type="radio" name={group[0] as string} value={opt[0]} checked={index === 0} />
                  <span>{opt[1]}</span>
                </label>
              ))}
            </div>
          </fieldset>
        ))}
      </form>

      <aside class="lg:col-span-5">
        <div class="sticky top-28 space-y-5">
          <div id="selector-card" class="card overflow-hidden">
            <div id="selector-accent" class="h-2" style="background:#c0362c"></div>
            <div class="p-6 md:p-8">
              <div class="flex items-start justify-between gap-5">
                <div>
                  <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.result}</p>
                  <h2 id="selector-title" class="mt-3 font-display text-4xl font-700 text-fg">Red Book</h2>
                </div>
                <div id="selector-swatch" class="h-16 w-12 rounded-md border border-line shadow-xl" style="background:#c0362c"></div>
              </div>
              <p id="selector-desc" class="mt-5 leading-relaxed text-fg-dim"></p>

              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <div class="rounded-lg border border-line bg-ink-2 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-muted">{c.match}</p>
                  <p class="mt-2"><span id="selector-score" class="font-display text-3xl font-700 text-fg">0</span><span class="text-muted">%</span></p>
                </div>
                <div class="rounded-lg border border-line bg-ink-2 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-muted">{c.riskShare}</p>
                  <div class="mt-3 h-2 rounded-full bg-line">
                    <div id="selector-risk" class="h-full rounded-full bg-brass" style="width:40%"></div>
                  </div>
                </div>
              </div>

              <div class="mt-6">
                <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.why}</p>
                <ul id="selector-reasons" class="mt-3 space-y-2 text-sm leading-relaxed text-fg-dim"></ul>
              </div>

              <div class="mt-6">
                <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.alternatives}</p>
                <div id="selector-alternatives" class="mt-3 flex flex-wrap gap-2"></div>
              </div>

              <div class="tool-action-dock mt-7">
                <div class="tool-action-dock__row">
                  <a href={suiteHref} class="btn btn-ghost">{c.ctaSuite}</a>
                  <a href={contactHref} class="btn btn-primary">{c.ctaConsult}</a>
                </div>
                <button id="export-book-report" type="button" class="btn btn-ghost">{c.exportPdf}</button>
              </div>
            </div>
          </div>
          <p class="text-xs leading-relaxed text-muted">{c.disclaimer}</p>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline define:vars={{ c, books, pagePath }}>
    (function () {
      var form = document.getElementById('book-selector-form');
      if (!form) return;

      var title = document.getElementById('selector-title');
      var desc = document.getElementById('selector-desc');
      var accent = document.getElementById('selector-accent');
      var swatch = document.getElementById('selector-swatch');
      var scoreEl = document.getElementById('selector-score');
      var riskEl = document.getElementById('selector-risk');
      var reasonsEl = document.getElementById('selector-reasons');
      var alternativesEl = document.getElementById('selector-alternatives');
      var exportBtn = document.getElementById('export-book-report');

      var weights = {
        project: {
          civil: { red: 4, pink: 3 },
          plant: { yellow: 5, silver: 2 },
          epc: { silver: 5, yellow: 2 },
          small: { green: 5, red: 1 },
        },
        design: {
          employer: { red: 4, pink: 4 },
          contractor: { yellow: 4, silver: 4 },
          shared: { emerald: 3, green: 2, yellow: 1 },
        },
        price: {
          remeasure: { red: 4, pink: 4 },
          lump: { yellow: 4, silver: 2 },
          fixed: { silver: 5, yellow: 1 },
          flexible: { green: 4, emerald: 2 },
        },
        funding: {
          mdb: { pink: 6, red: 1 },
          private: { silver: 4, yellow: 2 },
          public: { red: 3, yellow: 2, pink: 1 },
        },
        risk: {
          balanced: { red: 3, pink: 3, yellow: 1 },
          employerCertainty: { silver: 5, yellow: 2 },
          contractorControl: { yellow: 3, silver: 3 },
        },
        ground: {
          normal: { red: 1, yellow: 1 },
          underground: { emerald: 6 },
          uncertain: { emerald: 5, red: 1 },
        },
      };

      function selected(name) {
        var input = form.querySelector('input[name="' + name + '"]:checked');
        return input ? input.value : null;
      }

      function calculate() {
        var scores = {};
        books.forEach(function (b) { scores[b.id] = 0; });
        Object.keys(weights).forEach(function (group) {
          var val = selected(group);
          var add = weights[group][val] || {};
          Object.keys(add).forEach(function (id) { scores[id] += add[id]; });
        });

        var ranked = books.map(function (b) {
          return Object.assign({}, b, { score: scores[b.id] || 0 });
        }).sort(function (a, b) { return b.score - a.score; });

        var top = ranked[0];
        var maxPossible = 28;
        var match = Math.max(35, Math.min(98, Math.round((top.score / maxPossible) * 100)));
        var book = c.books[top.id];

        title.textContent = book[0];
        desc.textContent = book[1];
        accent.style.background = top.hex;
        swatch.style.background = top.hex;
        scoreEl.textContent = String(match);
        riskEl.style.width = top.risk + '%';

        reasonsEl.innerHTML = '';
        (c.reasons[top.id] || []).forEach(function (r) {
          var li = document.createElement('li');
          li.textContent = r;
          reasonsEl.appendChild(li);
        });

        alternativesEl.innerHTML = '';
        ranked.slice(1, 4).forEach(function (b) {
          var chip = document.createElement('span');
          chip.className = 'chip';
          chip.textContent = c.books[b.id][0];
          chip.style.borderColor = b.hex;
          alternativesEl.appendChild(chip);
        });

        return { top: top, ranked: ranked, match: match, book: book };
      }

      form.addEventListener('change', calculate);
      calculate();

      if (exportBtn) {
        exportBtn.addEventListener('click', function () {
          var result = calculate();
          if (!result || typeof window.FidicReportExport !== 'function') return;
          var groups = [
            ['project', c.project],
            ['design', c.design],
            ['price', c.price],
            ['funding', c.funding],
            ['risk', c.risk],
            ['ground', c.ground],
          ];
          var choiceRows = groups.map(function (group) {
            var checked = form.querySelector('input[name="' + group[0] + '"]:checked');
            var label = checked ? checked.closest('label').textContent.trim() : '-';
            return [group[1], label];
          });
          window.FidicReportExport({
            title: c.title,
            subtitle: location.origin + pagePath,
            sourceUrl: location.origin + pagePath,
            status: result.book[0],
            summary: c.result + ': ' + result.book[0] + ' · ' + c.match + ': ' + result.match + '%',
            nextActions: c.reasons[result.top.id] || [],
            sections: [
              { heading: c.result, rows: [[c.result, result.book[0]], [c.match, result.match + '%'], [c.riskShare, result.top.risk + '%']] },
              { heading: c.why, items: c.reasons[result.top.id] || [] },
              { heading: c.alternatives, items: result.ranked.slice(1, 4).map(function (b) { return c.books[b.id][0]; }) },
              { heading: 'Inputs', rows: choiceRows },
            ],
          });
        });
      }
    })();
  </script>

