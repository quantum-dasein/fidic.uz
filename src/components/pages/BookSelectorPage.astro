      ground: [
        ['normal', 'Нет, обычные условия'],
        ['underground', 'Да, тоннели / метро / подземные работы'],
        ['uncertain', 'Есть существенная геологическая неопределённость'],
      ],
    },
    books: {
      red: ['Red Book', 'Employer-designed construction with re-measurement. Хорошо подходит, когда проект готовит Заказчик, а оплата идёт по фактическим объёмам.'],
      yellow: ['Yellow Book', 'Plant and Design-Build. Подрядчик проектирует и строит, цена чаще lump sum, но роль Инженера сохраняется.'],
      silver: ['Silver Book', 'EPC/Turnkey. Максимальная определённость цены и срока для Заказчика, высокий риск Подрядчика.'],
      pink: ['Pink Book', 'MDB Harmonised. Практичный выбор для проектов Всемирного банка, ADB, EBRD и других МФО.'],
      emerald: ['Emerald Book', 'Underground Works. Специальная форма для тоннелей и подземных работ с управлением геориском.'],
      green: ['Green Book', 'Short Form. Компактная форма для небольших, простых или повторяющихся работ.'],
    },
    reasons: {
      red: ['проектирование остаётся у Заказчика', 'оплата по измеряемым объёмам', 'риск распределён более сбалансированно'],
      yellow: ['Подрядчик отвечает за проектирование', 'подходит для plant/design-build', 'lump sum логика без полного EPC risk transfer'],
      silver: ['нужна высокая price/time certainty', 'Подрядчик контролирует проектирование и поставки', 'подходит для project finance, IPP, PPP'],
      pink: ['проект финансируется МФО', 'нужны bank-specific procurement and integrity provisions', 'база близка к Red Book, но с требованиями банков'],
      emerald: ['есть тоннели или подземные работы', 'геориск нужно выделить отдельно', 'GBR/ground conditions становятся центральной темой'],
      green: ['проект небольшой или простой', 'нужна короткая форма', 'сложная FIDIC-администрация была бы избыточной'],
    },
  },
  en: {
    title: 'FIDIC Book Selector',
    h1: 'Choose the right FIDIC book',
    sub: 'Answer a few practical questions: who designs, how the works are paid, how much price certainty is needed, whether MDB financing or geo-risk is involved. The result is a first orientation, not a substitute for reviewing the tender package.',
    meta: 'FIDIC Book Selector: an interactive helper for choosing Red Book, Yellow Book, Silver Book, Pink Book or Emerald Book for an infrastructure project.',
    badge: 'Interactive form selector',
    project: 'Project type',
    design: 'Who should design',
    price: 'Pricing priority',
    funding: 'Funding',
    risk: 'Employer risk profile',
    ground: 'Significant geo-risk / underground works',
    result: 'Recommendation',
    match: 'match',
    riskShare: 'contractor risk',
    why: 'Why this form',
