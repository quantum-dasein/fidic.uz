---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { type Lang, defaultLang, localizePath } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;

const copy = {
  ru: {
    title: 'Подбор книги FIDIC',
    h1: 'Подберите подходящую книгу FIDIC',
    sub: 'Ответьте на несколько практических вопросов: кто проектирует, как оплачиваются работы, насколько нужна фиксированная цена, есть ли финансирование МФО или геориски. Инструмент даст ориентир, но финальный выбор всегда зависит от Particular Conditions и тендерного пакета.',
    meta: 'FIDIC Book Selector: интерактивный помощник для выбора Red Book, Yellow Book, Silver Book, Pink Book или Emerald Book под инфраструктурный проект.',
    badge: 'Интерактивный выбор формы',
    project: 'Тип проекта',
    design: 'Кто должен проектировать',
    price: 'Что важнее по цене',
    funding: 'Финансирование',
    risk: 'Риск-профиль заказчика',
    ground: 'Есть ли существенный геориск / подземные работы',
    result: 'Рекомендация',
    match: 'совпадение',
    riskShare: 'риск подрядчика',
    why: 'Почему эта форма',
    alternatives: 'Альтернативы',
    ctaSuite: 'Открыть Rainbow Suite',
    ctaConsult: 'Проверить выбор с экспертом',
    exportPdf: 'Export PDF report',
    disclaimer: 'Это предварительный ориентир, не юридическое заключение. Проверяйте требования МФО, Particular Conditions, применимое право, procurement documents и фактический scope проекта.',
    options: {
      project: [
        ['civil', 'Дороги, мосты, здания, civil works'],
        ['plant', 'Заводы, оборудование, design-build'],
        ['epc', 'IPP / PPP / EPC под ключ'],
        ['small', 'Небольшие или простые работы'],
      ],
      design: [
        ['employer', 'Заказчик / его инженер'],
        ['contractor', 'Подрядчик'],
        ['shared', 'Смешанная ответственность'],
      ],
      price: [
        ['remeasure', 'Измеряемые объёмы / BoQ'],
        ['lump', 'Lump sum'],
        ['fixed', 'Максимально фиксированная цена и срок'],
        ['flexible', 'Гибкость важнее жёсткой цены'],
      ],
      funding: [
        ['mdb', 'World Bank / ADB / EBRD / другой МФО'],
        ['private', 'Частный инвестор / project finance'],
        ['public', 'Государственный или корпоративный заказчик'],
      ],
      risk: [
        ['balanced', 'Нужен сбалансированный риск'],
        ['employerCertainty', 'Заказчику нужна предсказуемость цены/срока'],
        ['contractorControl', 'Подрядчик готов брать больше риска за контроль'],
