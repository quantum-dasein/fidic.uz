const c = copy[lang];
const tx = (o: { ru: string; en: string; uz: string }) => o[lang];
const toolsHref = localizePath('/tools', lang);
const contactHref = localizePath('/', lang) + '#contact';
const pagePath = localizePath('/tools/contract-map', lang);
const heroPills = {
  ru: ['10 ключевых этапов', 'Единая логика', 'Практические инструменты'],
  en: ['10 key stages', 'One contract logic', 'Practical tools'],
  uz: ['10 asosiy bosqich', 'Yagona kontrakt logikasi', 'Amaliy vositalar'],
}[lang];
const principlesTitle = {
  ru: 'Контрактная логика',
  en: 'Contract logic',
  uz: 'Kontrakt logikasi',
}[lang];
const principles = {
  ru: [
    ['Risk allocation', 'Проектирование, сроки, цена и ESHS проверяются до submission'],
    ['Notice discipline', 'Событие, notice, records и detailed claim связаны в одну цепочку'],
    ['Evidence trail', 'Программа, переписка, фото и cost records не живут отдельно'],
    ['DAAB path', 'Engineer, DAAB, amicable settlement и arbitration разведены по этапам'],
  ],
  en: [
    ['Risk allocation', 'Design, time, price and ESHS are reviewed before submission'],
    ['Notice discipline', 'Event, notice, records and detailed claim stay connected'],
    ['Evidence trail', 'Programme, correspondence, photos and cost records are mapped together'],
    ['DAAB path', 'Engineer, DAAB, amicable settlement and arbitration are separated by stage'],
  ],
  uz: [
    ['Risk allocation', 'Design, muddat, narx va ESHS submissiondan oldin tekshiriladi'],
    ['Notice discipline', 'Hodisa, notice, records va detailed claim bitta zanjirda turadi'],
    ['Evidence trail', 'Dastur, yozishmalar, foto va cost records birga xaritalanadi'],
    ['DAAB path', 'Engineer, DAAB, amicable settlement va arbitration bosqichlarga ajratiladi'],
  ],
}[lang];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: c.h1,
  description: c.meta,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: stages.length,
  itemListElement: stages.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tx(s.title),
    description: tx(s.desc),
  })),
};
---
<Layout
  title={`${c.title} | ${site.name}`}
  description={c.meta}
  lang={lang}
  langUrls={{ ru: '/tools/contract-map', en: '/en/tools/contract-map', uz: '/uz/tools/contract-map' }}
  keywords="FIDIC contract lifecycle, FIDIC contract map, FIDIC stages, tender award taking-over DAAB, FIDIC 2017 lifecycle"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <section class="cmap-hero relative overflow-hidden border-b border-line pt-28">
    <div class="absolute inset-0 bp-grid opacity-50"></div>
    <div class="cmap-hero__inner relative z-10 mx-auto grid max-w-7xl gap-10 px-5 pb-12 md:px-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(22rem,1.1fr)] lg:items-center">
      <div class="cmap-hero__copy">
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="mt-5 max-w-4xl font-display font-700 leading-[1.0] text-fg" style="font-size: clamp(2.3rem, 7.4vw, 5rem)">{c.h1}</h1>
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-fg-dim md:text-lg">{c.sub}</p>
        <div class="cmap-hero__pills" aria-label={c.eyebrow}>
          {heroPills.map((pill) => <span>{pill}</span>)}
        </div>
      </div>
      <div class="cmap-scene" aria-hidden="true">
        <span class="cmap-scene__ring cmap-scene__ring--outer"></span>
        <span class="cmap-scene__ring cmap-scene__ring--mid"></span>
        <span class="cmap-scene__ring cmap-scene__ring--inner"></span>
        <span class="cmap-scene__document"><i></i><i></i><i></i></span>
        <span class="cmap-scene__rail cmap-scene__rail--one"></span>
        <span class="cmap-scene__rail cmap-scene__rail--two"></span>
        <span class="cmap-scene__node cmap-scene__node--a">01</span>
        <span class="cmap-scene__node cmap-scene__node--b">06</span>
        <span class="cmap-scene__node cmap-scene__node--c">10</span>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-10 md:px-8 md:py-14">
    <div id="cmap" class="cmap">
      <!-- Rail -->
      <div class="cmap-rail" role="tablist" aria-label={c.eyebrow}>
        <div class="cmap-rail__line" aria-hidden="true"><span></span></div>
        {stages.map((s, i) => (
          <button
            class="cmap-node"
            type="button"
            role="tab"
            data-stage={i}
            aria-selected={i === 0 ? 'true' : 'false'}
            style={`--node: ${s.color}`}
          >
            <span class="cmap-node__dot">{String(i + 1).padStart(2, '0')}</span>
            <span class="cmap-node__label">{tx(s.short)}</span>
          </button>
        ))}
      </div>

      <!-- Stage panels (all rendered for SEO / no-JS; JS shows one at a time) -->
      <div class="cmap-content">
        <div class="cmap-panels">
          {stages.map((s, i) => (
            <article class="cmap-stage" data-stage={i} aria-hidden={i === 0 ? 'false' : 'true'} style={`--node: ${s.color}`}>
              <div class="cmap-stage__bar"></div>
              <div class="cmap-stage__body">
                <div class="cmap-stage__head">
                  <span class="cmap-stage__num">{c.stageWord} {String(i + 1).padStart(2, '0')} / {String(stages.length).padStart(2, '0')}</span>
                  <span class="cmap-stage__clause">{c.clauseWord}: <strong>{s.clause}</strong></span>
                </div>
                <h2 class="cmap-stage__title">{tx(s.title)}</h2>
                <p class="cmap-stage__desc">{tx(s.desc)}</p>
                <p class="cmap-stage__related">{c.relatedWord}</p>
                <div class="cmap-stage__links">
                  {s.links.map((l) => (
                    <a href={localizePath(l.href, lang)} class="cmap-chip">{l.label}</a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>

        <aside class="cmap-principles" aria-label={principlesTitle}>
          <h2>{principlesTitle}</h2>
          <div>
            {principles.map(([title, text]) => (
              <p>
                <strong>{title}</strong>
                <span>{text}</span>
              </p>
            ))}
          </div>
        </aside>
      </div>
    </div>

    <div class="cmap-cta mt-12">
      <div>
        <p class="eyebrow">{c.ctaTitle}</p>
        <p>{c.ctaText}</p>
      </div>
      <div class="cmap-cta__actions">
        <a href={toolsHref} class="btn btn-ghost justify-center">{c.openTools}</a>
        <a href={contactHref} class="btn btn-primary justify-center">{c.consult}</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var root = document.getElementById('cmap');
      if (!root) return;
      root.classList.add('cmap--js');
      var nodes = Array.prototype.slice.call(root.querySelectorAll('.cmap-node'));
      var panels = Array.prototype.slice.call(root.querySelectorAll('.cmap-stage'));

      function select(index, shouldScroll) {
        var progress = nodes.length > 1 ? (index / (nodes.length - 1)) * 100 : 0;
        root.style.setProperty('--cmap-progress', progress.toFixed(2) + '%');
        nodes.forEach(function (n, i) { n.setAttribute('aria-selected', i === index ? 'true' : 'false'); });
        panels.forEach(function (p, i) {
          var on = i === index;
          p.classList.toggle('is-active', on);
          p.setAttribute('aria-hidden', on ? 'false' : 'true');
        });
        if (shouldScroll && nodes[index] && typeof nodes[index].scrollIntoView === 'function') {
          nodes[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      }

      nodes.forEach(function (n, i) {
        n.addEventListener('click', function () { select(i, true); });
        n.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); var ni = Math.min(i + 1, nodes.length - 1); nodes[ni].focus(); select(ni, true); }
          if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); var pi = Math.max(i - 1, 0); nodes[pi].focus(); select(pi, true); }
        });
      });
      select(0, false);

      // draw the rail line when it enters the viewport
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) { root.classList.add('cmap--drawn'); io.disconnect(); } });
        }, { threshold: 0.2 });
        io.observe(root);
      } else {
        root.classList.add('cmap--drawn');
      }
    })();
  </script>

  <style>
    .cmap-hero {
      min-height: min(48rem, 86svh);
      display: grid;
      align-items: end;
      background:
        linear-gradient(115deg, rgba(4, 7, 13, 0.98), rgba(8, 12, 19, 0.72) 48%, rgba(4, 7, 13, 0.96)),
        radial-gradient(circle at 84% 24%, rgba(201, 164, 92, 0.16), transparent 30rem),
        radial-gradient(circle at 16% 90%, rgba(91, 140, 255, 0.12), transparent 32rem),
        var(--color-ink);
    }
    .cmap-hero__inner {
      width: 100%;
    }
    .cmap-hero__copy {
      min-width: 0;
    }
    .cmap-hero__pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-top: 1.5rem;
    }
    .cmap-hero__pills span {
      border: 1px solid color-mix(in oklab, var(--color-brass) 34%, var(--color-line));
      border-radius: 999px;
      padding: 0.45rem 0.7rem;
      background: rgba(4, 6, 10, 0.5);
      color: var(--color-fg-dim);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
    }

    .cmap-scene {
      position: relative;
      min-height: clamp(18rem, 42vw, 32rem);
      perspective: 1100px;
      transform-style: preserve-3d;
      filter: drop-shadow(0 2rem 5rem rgba(0, 0, 0, 0.42));
    }
    .cmap-scene::after {
      content: "";
      position: absolute;
      inset: 32% 18% 26%;
      border: 1px solid rgba(201, 164, 92, 0.16);
      border-radius: 48% 52% 50% 50%;
      transform: rotateX(70deg) rotateZ(14deg) translateZ(1.2rem);
      background:
        linear-gradient(90deg, transparent 0 48%, rgba(201, 164, 92, 0.22) 49% 51%, transparent 52%),
        linear-gradient(0deg, transparent 0 48%, rgba(91, 140, 255, 0.16) 49% 51%, transparent 52%);
      opacity: 0.72;
    }
    .cmap-scene::before {
      content: "";
      position: absolute;
      inset: 10% 3% 8%;
      border: 1px solid rgba(91, 140, 255, 0.16);
      border-radius: 2rem;
      background:
        linear-gradient(90deg, rgba(91, 140, 255, 0.13) 1px, transparent 1px),
        linear-gradient(0deg, rgba(201, 164, 92, 0.11) 1px, transparent 1px);
      background-size: 44px 44px;
      transform: rotateX(64deg) rotateZ(-17deg) translateZ(-2rem);
      opacity: 0.82;
    }
    .cmap-scene__ring {
      position: absolute;
      inset: 16% 20%;
      border: 1px solid rgba(201, 164, 92, 0.34);
      border-radius: 50%;
      transform-style: preserve-3d;
      transform: rotateX(68deg) rotateZ(-19deg);
      box-shadow:
        inset 0 0 2.2rem rgba(201, 164, 92, 0.08),
        0 0 3rem rgba(91, 140, 255, 0.08);
    }
    .cmap-scene__ring--outer {
      inset: 7% 8%;
      border-color: rgba(91, 140, 255, 0.28);
      animation: cmapOrbit 18s linear infinite;
    }
    .cmap-scene__ring--mid {
      inset: 19% 22%;
      animation: cmapOrbit 24s linear infinite reverse;
    }
    .cmap-scene__ring--inner {
      inset: 32% 36%;
      border-color: rgba(255, 220, 145, 0.42);
      animation: cmapOrbit 14s linear infinite;
    }
    .cmap-scene__document {
      position: absolute;
