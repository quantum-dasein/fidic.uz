    color: 'var(--color-fidic-green)', clause: 'Clause 8',
    short: { ru: 'Старт работ', en: 'Commencement', uz: 'Boshlanish' },
    title: { ru: 'Начало работ', en: 'Commencement', uz: 'Ishlar boshlanishi' },
    desc: {
      ru: 'Дата начала, программа (Sub-Clause 8.3), Performance Security и роль Инженера.',
