        clarify: ['Clarify the boundary between Employer design, Contractor design and design review.', 'Confirm whether fitness-for-purpose, design liability and approvals have been modified.'],
      },
      {
        id: 'price',
        category: 'commercial',
        title: 'Price basis va payment mechanism',
        prompt: 'Price, BoQ, milestones, IPC va payment timing hidden cash-flow gapsiz ishlaydimi?',
        options: [
          ['low', 'Payment mechanism, measurement and IPC cycle workable', 0],
          ['medium', 'Cash-flow gaps, unclear milestones yoki measurement assumptions', 1],
          ['high', 'High payment risk: unclear BoQ, delayed certification yoki aggressive deductions', 2],
        ],
        clarify: ['Clarify measurement/payment basis, IPC documents and certification timing.', 'Confirm whether milestones, retention, advance payment and deductions are aligned.'],
      },
      {
        id: 'securities',
        category: 'commercial',
        title: 'Securities, guarantees va liquidated damages',
        prompt: 'Performance Security, advance guarantee, retention va delay damages riskka mutanosibmi?',
        options: [
          ['low', 'Amounts, durations and forms standard ko‘rinadi', 0],
          ['medium', 'Strict forms, extended validity yoki unclear release triggers', 1],
          ['high', 'Securities/LADs disproportionate exposure yoki cash trap yaratishi mumkin', 2],
        ],
        clarify: ['Confirm forms, expiry dates and release triggers for all securities.', 'Clarify LAD caps, delay damages mechanics and interaction with taking-over.'],
      },
      {
        id: 'time',
        category: 'time',
        title: 'Time for Completion va access',
        prompt: 'Dates, access, permits, handover va third-party dependencies realistikmi?',
        options: [
          ['low', 'Access, milestones and constraints priced and schedulable', 0],
          ['medium', 'Dependency assumptions bor, lekin yozib chiqish mumkin', 1],
          ['high', 'Critical access/permit/interface risks Contractor controlidan tashqarida', 2],
        ],
        clarify: ['Confirm site access dates, permit dependencies and interface responsibilities.', 'Clarify whether Employer-caused access delays entitle EOT and/or cost.'],
      },
      {
        id: 'notices',
        category: 'time',
        title: 'Notices and communication channels',
        prompt: 'Kim notices yuborishi, qaysi kanal va 28/84-day deadlines qanday nazorat qilinishi aniqmi?',
        options: [
          ['low', 'Channels, authorised persons and deadline workflow clear', 0],
          ['medium', 'Procedure bor, lekin internal notice register hali yo‘q', 1],
          ['high', 'Notice channel, service rules yoki time-bars unclear/aggressive', 2],
        ],
        clarify: ['Confirm official communication channels, authorised representatives and notice service rules.', 'Clarify claim notice and fully detailed claim deadlines if Particular Conditions modify them.'],
      },
      {
        id: 'claims',
        category: 'time',
        title: 'Claims, records and substantiation',
        prompt: 'Jamoa birinchi kundan EOT, disruption va prolongation costs uchun evidence file yurita oladimi?',
        options: [
          ['low', 'Records, programme updates and cost evidence planned', 0],
          ['medium', 'Records qisman bor, evidence architecture kuchayishi kerak', 1],
          ['high', 'Claims procedure jamoa yurita olmaydigan records talab qiladi', 2],
        ],
        clarify: ['Clarify record requirements for EOT, disruption, prolongation costs and variations.', 'Confirm programme update frequency, baseline approval and required claim particulars.'],
      },
      {
        id: 'eshs',
        category: 'governance',
        title: 'ESHS and MDB compliance',
        prompt: 'ESHS obligations, reporting, consequences va resources tushunilganmi?',
        options: [
          ['low', 'ESHS obligations staff, reports and costga mapped', 0],
          ['medium', 'Bank-specific obligations bor, resources/cost to‘liq priced emas', 1],
          ['high', 'ESHS scope heavy, penalties/reporting unclear, resources not priced', 2],
        ],
        clarify: ['Clarify ESHS reporting, staffing, deliverables and consequences of non-compliance.', 'Confirm whether ESHS obligations affect IPC, suspension, termination or evaluation.'],
      },
      {
        id: 'daab',
        category: 'governance',
        title: 'Engineer, DAAB and dispute pathway',
        prompt: 'Engineer determination, DAAB, amicable settlement va arbitration chain ishlaydimi?',
        options: [
          ['low', 'Roles, appointment and dispute escalation coherent', 0],
          ['medium', 'DAAB appointment, costs yoki timelines bo‘yicha open points', 1],
          ['high', 'Dispute pathway fragmented yoki board mechanics unclear', 2],
        ],
        clarify: ['Clarify DAAB appointment timing, standing/ad hoc status, cost sharing and procedural rules.', 'Confirm Engineer determination timelines and dispute escalation steps.'],
      },
      {
        id: 'procurement',
        category: 'governance',
        title: 'Procurement integrity and tender strategy',
        prompt: 'Evaluation criteria, deviations policy, conflict rules va rejection grounds aniqmi?',
        options: [
          ['low', 'Evaluation method and compliance rules clear', 0],
          ['medium', 'Scoring, deviations yoki experience evidence bo‘yicha ambiguity', 1],
          ['high', 'Bid price emas, compliance/evaluation sabab fail bo‘lishi mumkin', 2],
        ],
        clarify: ['Clarify evaluation criteria, permitted deviations and documentary evidence requirements.', 'Confirm how technical merit, experience and compliance gaps affect bid responsiveness.'],
      },
      {
        id: 'localAdmin',
        category: 'governance',
        title: 'Local administration assumptions',
        prompt: 'Permits, tax/admin interface, import, visas va local approvals assumptions ehtiyotkorlik bilan belgilanganmi?',
        options: [
          ['low', 'Assumptions identified and assigned to owners', 0],
          ['medium', 'Local admin assumptions awarddan oldin verification talab qiladi', 1],
          ['high', 'Price unverified local assumptionsga bog‘liq', 2],
        ],
        clarify: ['Clarify responsibility for permits, customs/import interfaces, local approvals and related delays.', 'Confirm which local administration assumptions are Employer risk, Contractor risk or shared risk.'],
      },
    ],
  },
} as const;

const c = copy[lang];
const contactHref = localizePath('/', lang) + '#contact';
const knowledgeHref = localizePath('/knowledge', lang);
const pagePath = localizePath('/tools/tender-risk-lab', lang);
const categoryIds = ['scope', 'commercial', 'time', 'governance'] as const;
---

<Layout
  title={`${c.title} | ${site.name}`}
  description={c.meta}
  lang={lang}
  langUrls={{
    ru: '/tools/tender-risk-lab',
    en: '/en/tools/tender-risk-lab',
    uz: '/uz/tools/tender-risk-lab',
  }}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: c.title,
      url: `${site.url}${pagePath}`,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      provider: {
        '@type': 'Organization',
        name: site.poweredBy,
        url: site.poweredByUrl,
      },
      description: c.meta,
    })}></script>
  </Fragment>

  <section class="risk-lab-hero relative min-h-[calc(100svh-5rem)] overflow-hidden border-b border-line">
    <div class="absolute inset-0 bp-grid opacity-55"></div>
    <canvas id="risk-lab-3d" aria-hidden="true"></canvas>
    <div class="risk-lab-fallback" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>

    <div class="risk-lab-hero-inner relative z-10 mx-auto grid min-h-[calc(100svh-5rem)] max-w-7xl gap-10 px-5 py-16 md:px-8 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-7">
        <p class="eyebrow mb-5">{c.badge}</p>
        <h1 class="risk-lab-title max-w-4xl font-display font-700 leading-[1.02] text-fg" style="font-size: clamp(2.25rem, 7.6vw, 5.4rem)">{c.h1}</h1>
        <p class="risk-lab-lead mt-6 max-w-2xl text-base leading-relaxed text-fg-dim sm:text-lg">{c.sub}</p>
        <div class="risk-lab-actions mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#assessment" class="btn btn-primary justify-center">{c.start}</a>
          <a href={contactHref} class="btn btn-ghost justify-center">{c.consult}</a>
        </div>
      </div>

      <aside class="risk-lab-hero-console lg:col-span-5">
        <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.live}</p>
        <div class="mt-5 grid grid-cols-2 gap-3">
          {categoryIds.map((id) => (
            <div class="risk-lab-mini">
              <span>{c.categories[id]}</span>
              <strong data-hero-cat={id}>0%</strong>
            </div>
          ))}
        </div>
        <div class="mt-5 h-2 overflow-hidden rounded-full bg-line">
          <div id="risk-hero-bar" class="h-full w-0 rounded-full bg-brass transition-[width] duration-500"></div>
        </div>
      </aside>
    </div>
  </section>

  <section id="assessment" class="mx-auto max-w-7xl px-5 py-12 md:px-8 md:py-16">
    <div class="grid gap-8 lg:grid-cols-12">
      <form id="risk-lab-form" class="space-y-4 lg:col-span-7">
        {c.questions.map((q, index) => (
          <fieldset class="risk-question" data-question={q.id} data-category={q.category}>
            <legend class="sr-only">{q.title}</legend>
            <div class="flex gap-4">
              <span class="risk-question__index">{String(index + 1).padStart(2, '0')}</span>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{q.title}</p>
                  <span class="risk-question__cat">{c.categories[q.category as keyof typeof c.categories]}</span>
                </div>
                <p class="mt-2 text-base leading-relaxed text-fg">{q.prompt}</p>
                <div class="mt-4 grid gap-2">
                  {q.options.map((opt) => (
                    <label class="risk-option">
                      <input
                        class="mt-1 accent-[var(--color-brass)]"
                        type="radio"
                        name={`risk-${q.id}`}
                        value={opt[2]}
                        data-risk-label={opt[0]}
                        checked={opt[2] === 0}
                      />
                      <span>{opt[1]}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>
          </fieldset>
        ))}
      </form>

      <aside class="lg:col-span-5">
        <div class="risk-console sticky top-28">
          <div class="risk-console__head">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.live}</p>
              <h2 id="risk-verdict-title" class="mt-3 font-display text-2xl font-700 text-fg">{c.controlledTitle}</h2>
            </div>
            <div class="risk-score">
              <span id="risk-score">0</span>
              <small>/100</small>
            </div>
          </div>

          <p id="risk-verdict-text" class="mt-4 text-sm leading-relaxed text-fg-dim">{c.controlledText}</p>
          <div class="mt-5">
            <div class="mb-2 flex items-center justify-between font-mono text-[11px] uppercase tracking-widest text-muted">
              <span>{c.riskScore}</span>
              <span id="risk-level">{c.levels.low}</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-line">
              <div id="risk-scorebar" class="h-full w-0 rounded-full bg-brass transition-[width] duration-500"></div>
            </div>
          </div>

          <div class="risk-console__block">
            <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.heatmap}</p>
            <div class="mt-4 space-y-3">
              {categoryIds.map((id) => (
                <div class="risk-heat-row" data-heat={id}>
                  <div class="mb-1 flex items-center justify-between gap-3 text-xs text-fg-dim">
                    <span>{c.categories[id]}</span>
                    <strong id={`risk-cat-${id}`}>0%</strong>
                  </div>
                  <div class="h-2 overflow-hidden rounded-full bg-line">
                    <span id={`risk-bar-${id}`}></span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="risk-console__block">
            <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.clarifications}</p>
            <ol id="risk-clarifications" class="mt-4 space-y-2 text-sm leading-relaxed text-fg-dim"></ol>
          </div>

          <div class="risk-console__block">
            <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.actions}</p>
            <ul id="risk-actions" class="mt-4 space-y-2 text-sm leading-relaxed text-fg-dim"></ul>
          </div>

          <div class="tool-action-dock mt-6">
            <div class="tool-action-dock__row">
              <button id="copy-risk-assessment" type="button" class="btn btn-ghost">{c.copy}</button>
              <button id="export-risk-report" type="button" class="btn btn-ghost">{c.exportPdf}</button>
            </div>
            <a href={contactHref} class="btn btn-primary">{c.ctaButton}</a>
          </div>
          <p class="mt-5 text-xs leading-relaxed text-muted">{c.ctaText}</p>
        </div>
      </aside>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <a class="risk-related" href={localizePath('/knowledge/world-bank-section-viii-contract-data', lang)}>World Bank Section VIII</a>
      <a class="risk-related" href={localizePath('/knowledge/notice-register-28-84-day-workflow', lang)}>Notice Register workflow</a>
      <a class="risk-related" href={knowledgeHref}>Knowledge Hub</a>
    </div>
    <p class="mt-6 max-w-3xl text-xs leading-relaxed text-muted">{c.disclaimer}</p>
  </section>

  <script is:inline define:vars={{ c, categoryIds, pagePath }}>
    (function () {
      var form = document.getElementById('risk-lab-form');
      if (!form) return;

      var scoreEl = document.getElementById('risk-score');
      var scoreBar = document.getElementById('risk-scorebar');
      var heroBar = document.getElementById('risk-hero-bar');
      var levelEl = document.getElementById('risk-level');
      var titleEl = document.getElementById('risk-verdict-title');
      var textEl = document.getElementById('risk-verdict-text');
      var clarificationsEl = document.getElementById('risk-clarifications');
      var actionsEl = document.getElementById('risk-actions');
      var copyBtn = document.getElementById('copy-risk-assessment');
      var exportBtn = document.getElementById('export-risk-report');
      var max = c.questions.length * 2;

      function riskLevel(score) {
        if (score > 75) return { key: 'critical', title: c.criticalTitle, text: c.criticalText };
        if (score > 50) return { key: 'high', title: c.highTitle, text: c.highText };
        if (score > 25) return { key: 'medium', title: c.watchTitle, text: c.watchText };
        return { key: 'low', title: c.controlledTitle, text: c.controlledText };
      }

      function colorFor(score) {
        if (score > 75) return '#c0362c';
        if (score > 50) return '#e0a82e';
        if (score > 25) return '#c9a45c';
        return '#2f8f5b';
      }

      function setSelectedStates() {
        form.querySelectorAll('.risk-option').forEach(function (label) {
          var input = label.querySelector('input');
          label.classList.toggle('is-selected', Boolean(input && input.checked));
        });
      }

      function calculate() {
        var raw = 0;
        var cat = {};
        categoryIds.forEach(function (id) { cat[id] = { raw: 0, max: 0 }; });
        var clarifications = [];

        c.questions.forEach(function (q) {
          var checked = form.querySelector('input[name="risk-' + q.id + '"]:checked');
          var severity = checked ? Number(checked.value || 0) : 0;
          raw += severity;
          cat[q.category].raw += severity;
          cat[q.category].max += 2;
          if (severity > 0) clarifications.push(q.clarify[Math.min(severity - 1, q.clarify.length - 1)]);
        });

        var score = Math.round((raw / max) * 100);
        var level = riskLevel(score);
        var color = colorFor(score);
        var categoryScores = categoryIds.map(function (id) {
          return cat[id].max ? Math.round((cat[id].raw / cat[id].max) * 100) : 0;
        });

        scoreEl.textContent = String(score);
        scoreBar.style.width = score + '%';
        scoreBar.style.background = color;
        if (heroBar) {
          heroBar.style.width = score + '%';
          heroBar.style.background = color;
        }
        levelEl.textContent = c.levels[level.key];
        levelEl.style.color = color;
        titleEl.textContent = level.title;
        textEl.textContent = level.text;

        categoryIds.forEach(function (id, index) {
          var pct = categoryScores[index];
          var bar = document.getElementById('risk-bar-' + id);
          var label = document.getElementById('risk-cat-' + id);
          var hero = document.querySelector('[data-hero-cat="' + id + '"]');
          if (bar) {
            bar.style.width = pct + '%';
            bar.style.background = colorFor(pct);
          }
          if (label) label.textContent = pct + '%';
          if (hero) hero.textContent = pct + '%';
        });

        clarificationsEl.innerHTML = '';
        var unique = Array.from(new Set(clarifications)).slice(0, 7);
        if (unique.length === 0) {
          var li = document.createElement('li');
          li.textContent = c.emptyClarifications;
          clarificationsEl.appendChild(li);
        } else {
          unique.forEach(function (item) {
            var li = document.createElement('li');
            li.textContent = item;
            clarificationsEl.appendChild(li);
          });
        }

        actionsEl.innerHTML = '';
        var actions = c.actionsByLevel[level.key] || [c.emptyActions];
        actions.forEach(function (item) {
          var li = document.createElement('li');
          li.textContent = item;
          actionsEl.appendChild(li);
        });

        setSelectedStates();
        window.dispatchEvent(new CustomEvent('risk-lab:update', {
          detail: { overall: score, categories: categoryScores },
        }));

        return { score: score, level: level, clarifications: unique, actions: actions, categories: categoryScores };
      }

      form.addEventListener('change', calculate);
      var result = calculate();
      setTimeout(calculate, 250);

      if (copyBtn) {
        copyBtn.addEventListener('click', async function () {
          result = calculate();
          var lines = [
            c.title,
            location.origin + pagePath,
            c.riskScore + ': ' + result.score + '/100 - ' + c.levels[result.level.key],
            '',
            c.clarifications + ':',
          ].concat(
            (result.clarifications.length ? result.clarifications : [c.emptyClarifications]).map(function (item) { return '- ' + item; }),
            [''],
            [c.actions + ':'],
            result.actions.map(function (item) { return '- ' + item; })
          );
          try {
            await navigator.clipboard.writeText(lines.join('\n'));
            var old = copyBtn.textContent;
            copyBtn.textContent = c.copied;
            setTimeout(function () { copyBtn.textContent = old; }, 1400);
          } catch (_) {
            window.prompt(c.copy, lines.join('\n'));
          }
        });
      }

      if (exportBtn) {
        exportBtn.addEventListener('click', function () {
          var result = calculate();
          var categoryRows = categoryIds.map(function (id, index) {
            return [c.categories[id], result.categories[index] + '%'];
          });
          var selectedRows = c.questions.map(function (q) {
            var checked = form.querySelector('input[name="risk-' + q.id + '"]:checked');
            var label = checked ? checked.getAttribute('data-risk-label') : 'low';
            return [q.title, c.levels[label] || label];
          });
          if (typeof window.FidicReportExport === 'function') {
            window.FidicReportExport({
              title: c.title,
              subtitle: location.origin + pagePath,
              sourceUrl: location.origin + pagePath,
              status: c.levels[result.level.key],
              summary: c.riskScore + ': ' + result.score + '/100 · ' + c.levels[result.level.key],
              nextActions: result.actions,
              sections: [
                { heading: c.riskScore, rows: [[c.riskScore, result.score + '/100'], [c.result || 'Verdict', c.levels[result.level.key]]] },
                { heading: c.heatmap, rows: categoryRows },
                { heading: c.clarifications, items: result.clarifications.length ? result.clarifications : [c.emptyClarifications] },
                { heading: c.actions, items: result.actions },
                { heading: 'Selected risk profile', rows: selectedRows },
              ],
            });
          }
        });
      }
    })();
  </script>

  <script>
    import '../../scripts/tenderRiskLab3d.js';
  </script>

  <style>
    #risk-lab-3d {
      position: absolute;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .risk-lab-hero {
      background:
        radial-gradient(circle at 78% 36%, rgba(201, 164, 92, 0.16), transparent 32%),
        radial-gradient(circle at 62% 68%, rgba(91, 140, 255, 0.12), transparent 30%),
        var(--color-ink);
    }

    .risk-lab-fallback {
      position: absolute;
      right: clamp(-8rem, -7vw, -2rem);
      top: 12%;
      width: min(48vw, 38rem);
      aspect-ratio: 1;
      border: 1px solid rgba(201, 164, 92, 0.22);
      transform: rotateX(62deg) rotateZ(-18deg);
      opacity: 0.5;
      background:
        linear-gradient(90deg, rgba(201, 164, 92, 0.16) 1px, transparent 1px),
        linear-gradient(0deg, rgba(91, 140, 255, 0.12) 1px, transparent 1px);
      background-size: 32px 32px;
      box-shadow: inset 0 0 90px rgba(201,164,92,0.08), 0 40px 120px rgba(0,0,0,0.45);
    }

    .risk-lab-fallback span {
      position: absolute;
      bottom: 18%;
      width: 9%;
      background: linear-gradient(180deg, var(--color-brass), rgba(201, 164, 92, 0.1));
      border: 1px solid rgba(255,255,255,0.16);
    }

    .risk-lab-fallback span:nth-child(1) { left: 25%; height: 22%; }
    .risk-lab-fallback span:nth-child(2) { left: 39%; height: 36%; background: linear-gradient(180deg, var(--color-blueprint), rgba(91,140,255,0.1)); }
    .risk-lab-fallback span:nth-child(3) { left: 53%; height: 48%; background: linear-gradient(180deg, var(--color-fidic-yellow), rgba(224,168,46,0.1)); }
    .risk-lab-fallback span:nth-child(4) { left: 67%; height: 30%; background: linear-gradient(180deg, var(--color-fidic-red), rgba(192,54,44,0.1)); }

    .risk-lab-hero-console,
    .risk-console,
    .risk-question {
      min-width: 0;
      border: 1px solid var(--color-line-soft);
      border-radius: 1rem;
      background: linear-gradient(180deg, color-mix(in oklab, var(--color-ink-2) 92%, transparent), color-mix(in oklab, var(--color-ink) 92%, transparent));
      box-shadow: 0 24px 80px rgba(0,0,0,0.24);
      backdrop-filter: blur(14px);
    }

    .risk-lab-hero-console {
      padding: 1.25rem;
    }

    .risk-lab-mini {
      min-width: 0;
      min-height: 5.6rem;
      border: 1px solid var(--color-line);
      border-radius: 0.75rem;
      padding: 0.9rem;
      background: color-mix(in oklab, var(--color-ink-3) 72%, transparent);
    }

    .risk-lab-mini span {
      display: block;
      min-height: 2.2rem;
      font-size: 0.72rem;
      line-height: 1.35;
      color: var(--color-fg-dim);
      overflow-wrap: anywhere;
    }

    .risk-lab-mini strong {
      display: block;
      margin-top: 0.5rem;
      font-family: var(--font-display);
      font-size: 1.6rem;
      color: var(--color-fg);
    }

    .risk-question {
      padding: 1.2rem;
      transition: border-color 0.35s var(--ease-out-expo), transform 0.35s var(--ease-out-expo);
    }

    .risk-question:hover {
      border-color: color-mix(in oklab, var(--color-brass) 40%, var(--color-line));
    }

    .risk-question__index {
      display: flex;
      width: 2.25rem;
      height: 2.25rem;
      flex: 0 0 auto;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--color-line);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: var(--color-brass);
    }

    .risk-question__cat {
      border: 1px solid var(--color-line);
      border-radius: 999px;
      padding: 0.18rem 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-muted);
    }

    .risk-option {
      display: flex;
      cursor: pointer;
