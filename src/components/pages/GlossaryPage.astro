---
import Layout from '../../layouts/Layout.astro';
import { getGlossary, getGlossaryCategories } from '../../data/glossary';
import { type Lang, defaultLang, useTranslations } from '../../i18n/ui';
import { site } from '../../data/site';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const sorted = getGlossary(lang).sort((a, b) => a.term.localeCompare(b.term));
const categories = [t('cat.all'), ...getGlossaryCategories(lang)];
const title = `${t('glossary.h1')} | ${site.name}`;
---
<Layout title={title} description={t('glossary.sub')} lang={lang}>
  <section class="relative border-b border-line">
    <div class="absolute inset-0 bp-grid opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
      <p class="eyebrow mb-4">{t('glossary.eyebrow')}</p>
      <h1 class="max-w-3xl font-display font-700 leading-[1.05] tracking-tight text-fg" style="font-size: clamp(2rem, 7vw, 3.75rem)">{t('glossary.h1')}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-fg-dim">{t('glossary.sub')}</p>

      <div class="mt-8 flex flex-col gap-4 md:flex-row md:items-center">
        <div class="relative flex-1 md:max-w-md">
          <svg class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-muted" fill="none" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m21 21-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <input id="glossary-search" type="text" placeholder={t('glossary.search')} class="w-full rounded-full border border-line bg-ink py-3 pl-11 pr-4 text-sm text-fg placeholder:text-muted focus:border-brass focus:outline-none" />
        </div>
        <div id="glossary-cats" class="flex flex-wrap gap-2">
          {categories.map((c, i) => (
            <button class="gcat-btn chip transition-colors hover:border-brass hover:text-brass" data-cat={c} data-all={i === 0 ? '1' : '0'} aria-pressed={i === 0 ? 'true' : 'false'}>{c}</button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-14 md:px-8">
    <div id="glossary-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {sorted.map((g, i) => (
        <div class="glossary-item card p-6 reveal" data-cat={g.category} data-search={`${g.term} ${g.label}`.toLowerCase()} data-delay={(i % 3) * 60}>
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-display text-lg font-700 text-fg">{g.term}</h3>
              <p class="font-mono text-xs text-brass">{g.label}</p>
            </div>
            <span class="chip shrink-0 !px-2.5 !py-1 !text-[10px]">{g.category}</span>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-fg-dim">{g.definition}</p>
        </div>
      ))}
    </div>
    <p id="glossary-empty" class="hidden py-16 text-center text-muted">{t('glossary.empty')}</p>
  </section>

  <script is:inline>
    (function () {
      var search = document.getElementById('glossary-search');
      var items = Array.prototype.slice.call(document.querySelectorAll('.glossary-item'));
      var btns = document.querySelectorAll('.gcat-btn');
      var empty = document.getElementById('glossary-empty');
      var activeCat = null; // null = all

      function apply() {
        var q = (search.value || '').toLowerCase().trim();
        var visible = 0;
        items.forEach(function (it) {
          var matchCat = activeCat === null || it.getAttribute('data-cat') === activeCat;
          var matchQ = !q || it.getAttribute('data-search').indexOf(q) !== -1;
          var show = matchCat && matchQ;
          it.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        empty.classList.toggle('hidden', visible !== 0);
      }
      search.addEventListener('input', apply);
      btns.forEach(function (b) {
        b.addEventListener('click', function () {
          activeCat = b.getAttribute('data-all') === '1' ? null : b.getAttribute('data-cat');
          btns.forEach(function (x) {
            var on = x === b;
            x.setAttribute('aria-pressed', on ? 'true' : 'false');
            x.style.borderColor = on ? 'var(--color-brass)' : '';
            x.style.color = on ? 'var(--color-brass)' : '';
          });
          apply();
        });
      });
    })();
  </script>
</Layout>
