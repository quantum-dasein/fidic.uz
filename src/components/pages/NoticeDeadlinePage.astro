    particularsDays: 'Detailed particulars period, days',
    defaults: 'Typical FIDIC 2017 values: notice - 28 days, fully detailed claim - 84 days. Check your contract.',
    projectName: 'Project / package name',
    projectNamePh: 'Example: Lot 2 Water Supply',
    scenario: 'Calculation scenario',
    scenario1999: 'FIDIC 1999',
    scenario2017: 'FIDIC 2017',
    scenarioCustom: 'Custom',
    calculate: 'Generate timeline',
    today: 'Today',
    noticeDeadline: 'Notice deadline',
    particularsDeadline: 'Detailed claim deadline',
    reminder7: '7-day reminder',
    reminder3: '3-day reminder',
    statusOk: 'Notice deadline has not passed yet',
    statusToday: 'Notice deadline is today',
    statusLate: 'The notice deadline appears to have passed',
    statusNoDate: 'Select an event date',
    result: 'Calculation status',
    risk: 'Risk',
    riskLow: 'Notice deadline is still controlled',
    riskToday: 'Deadline is today',
    riskHigh: 'Potential time-bar risk',
    reportAssumptions: 'Assumptions',
    reportAssumption1: 'The calculation uses calendar days from the event awareness date.',
    reportAssumption2: 'The scenario does not replace review of Particular Conditions and service of notice procedure.',
    reportLimitation: 'Limitation note',
    daysLeft: 'days left',
    daysLate: 'days late',
    copyTimeline: 'Copy timeline',
    exportPdf: 'Export PDF report',
    copied: 'Copied',
    updated: 'Updated',
