    consult: 'Request consultation',
    warningTitle: 'Important',
    warningText: 'The calculator uses calendar days and does not account for Particular Conditions, holidays, service of notice rules, deeming provisions or applicable law. Check the contract before submitting a claim.',
    readTitle: 'Useful reading',
    links: [
      ['The 28-day rule', '/knowledge/claims-28-days'],
      ['Claims substantiation', '/knowledge/claims-substantiation-records'],
      ['EOT and delay analysis', '/knowledge/eot-delay-analysis'],
    ],
  },
  uz: {
    title: 'FIDIC notice muddati kalkulyatori',
    h1: 'FIDIC notice muddati kalkulyatori',
    sub: 'Claims uchun tezkor kalendar yordamchisi: hodisadan xabardor bo‘lgan sana, notice muddati, detailed particulars muddati va eslatmalar. Bu shartnoma tekshiruvini almashtirmaydi.',
    meta: 'FIDIC notice deadline calculator: 28 kunlik notice, detailed particulars, reminder dates va claim muddati xavfini hisoblash.',
    badge: 'Claims vositasi',
    awareness: 'Tomon hodisa haqida bilgan yoki bilishi kerak bo‘lgan sana',
    awarenessHint: 'Muddat odatda claim yozilgan kundan emas, hodisa yoki holat haqida xabardorlikdan boshlanadi.',
    noticeDays: 'Notice muddati, kun',
    particularsDays: 'Detailed particulars muddati, kun',
    defaults: 'FIDIC 2017 uchun odatiy qiymatlar: notice - 28 kun, fully detailed claim - 84 kun. Shartnomangizni tekshiring.',
    projectName: 'Loyiha / paket nomi',
    projectNamePh: 'Masalan: Lot 2 Water Supply',
    scenario: 'Hisoblash ssenariysi',
    scenario1999: 'FIDIC 1999',
    scenario2017: 'FIDIC 2017',
    scenarioCustom: 'Custom',
    calculate: 'Timeline yaratish',
    today: 'Bugun',
    noticeDeadline: 'Notice deadline',
    particularsDeadline: 'Detailed claim deadline',
    reminder7: '7 kun oldin eslatma',
    reminder3: '3 kun oldin eslatma',
    statusOk: 'Notice muddati hali o‘tmagan',
    statusToday: 'Notice muddati bugun',
    statusLate: 'Notice muddati o‘tgan bo‘lishi mumkin',
    statusNoDate: 'Hodisa sanasini tanlang',
    result: 'Hisoblash statusi',
    risk: 'Risk',
    riskLow: 'Notice muddati hali nazoratda',
    riskToday: 'Deadline bugun',
    riskHigh: 'Time-bar risk bo‘lishi mumkin',
    reportAssumptions: 'Assumptions',
    reportAssumption1: 'Hisoblash hodisadan xabardorlik sanasidan kalendar kunlar asosida amalga oshiriladi.',
    reportAssumption2: 'Ssenariy Particular Conditions va service of notice procedure tekshiruvini almashtirmaydi.',
    reportLimitation: 'Limitation note',
    daysLeft: 'kun qoldi',
    daysLate: 'kun kechikish',
    copyTimeline: 'Timeline nusxalash',
    exportPdf: 'PDF report export',
    copied: 'Nusxalandi',
    updated: 'Yangilandi',
    cta: 'Claim readiness tekshirish',
    consult: 'Konsultatsiya so‘rash',
    warningTitle: 'Muhim',
    warningText: 'Kalkulyator kalendar kunlarni hisoblaydi va Particular Conditions, bayram kunlari, notice service rules, deeming provisions yoki qo‘llaniladigan huquqni hisobga olmaydi. Claim yuborishdan oldin shartnomani tekshiring.',
    readTitle: 'Foydali materiallar',
    links: [
      ['28 kunlik qoida', '/knowledge/claims-28-days'],
      ['Claims substantiation', '/knowledge/claims-substantiation-records'],
      ['EOT va delay analysis', '/knowledge/eot-delay-analysis'],
    ],
  },
} as const;

const c = copy[lang];
const readinessHref = localizePath('/tools/claim-readiness', lang);
const contactHref = localizePath('/', lang) + '#contact';
const pagePath = localizePath('/tools/notice-deadline', lang);
---

<Layout
  title={`${c.title} | ${site.name}`}
  description={c.meta}
  lang={lang}
  langUrls={{
    ru: '/tools/notice-deadline',
    en: '/en/tools/notice-deadline',
    uz: '/uz/tools/notice-deadline',
  }}
>
  <section class="relative border-b border-line">
    <div class="absolute inset-0 bp-grid opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
      <p class="eyebrow mb-4">{c.badge}</p>
      <div class="grid gap-10 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <h1 class="max-w-4xl font-display font-700 leading-[1.05] tracking-tight text-fg" style="font-size: clamp(2rem, 6vw, 4rem)">{c.h1}</h1>
          <p class="mt-5 max-w-3xl text-lg leading-relaxed text-fg-dim">{c.sub}</p>
        </div>
        <aside class="card p-5 lg:col-span-4">
          <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.warningTitle}</p>
          <p class="mt-3 text-sm leading-relaxed text-fg-dim">{c.warningText}</p>
        </aside>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-12 md:px-8 md:py-16">
    <div class="grid gap-8 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <form id="notice-calculator" class="notice-form card p-6 md:p-8" novalidate>
          <label class="block">
            <span class="mb-2 block font-mono text-[11px] uppercase tracking-widest text-brass">{c.projectName}</span>
            <input id="notice-project-name" type="text" class="w-full rounded-lg border border-line bg-ink-2 px-4 py-3 text-fg focus:border-brass focus:outline-none" placeholder={c.projectNamePh} />
          </label>

          <fieldset class="notice-scenarios mt-5">
            <legend class="mb-2 block font-mono text-[11px] uppercase tracking-widest text-brass">{c.scenario}</legend>
            <div class="notice-scenario-grid">
              <label>
                <input type="radio" name="notice-scenario" value="1999" />
                <span>{c.scenario1999}</span>
              </label>
              <label>
                <input type="radio" name="notice-scenario" value="2017" checked />
                <span>{c.scenario2017}</span>
              </label>
              <label>
                <input type="radio" name="notice-scenario" value="custom" />
                <span>{c.scenarioCustom}</span>
              </label>
            </div>
          </fieldset>

          <label class="mt-5 block">
            <span class="mb-2 block font-mono text-[11px] uppercase tracking-widest text-brass">{c.awareness}</span>
            <input id="awareness-date" type="date" class="w-full rounded-lg border border-line bg-ink-2 px-4 py-3 text-fg focus:border-brass focus:outline-none" />
            <span class="mt-2 block text-sm leading-relaxed text-muted">{c.awarenessHint}</span>
          </label>

          <div class="notice-form__grid mt-6 grid gap-4 sm:grid-cols-2">
            <label class="notice-field block">
              <span class="mb-2 block font-mono text-[11px] uppercase tracking-widest text-brass">{c.noticeDays}</span>
              <input id="notice-days" type="number" min="1" max="365" inputmode="numeric" value="28" class="w-full rounded-lg border border-line bg-ink-2 px-4 py-3 text-fg focus:border-brass focus:outline-none" />
            </label>
            <label class="notice-field block">
              <span class="mb-2 block font-mono text-[11px] uppercase tracking-widest text-brass">{c.particularsDays}</span>
              <input id="particulars-days" type="number" min="1" max="730" inputmode="numeric" value="84" class="w-full rounded-lg border border-line bg-ink-2 px-4 py-3 text-fg focus:border-brass focus:outline-none" />
            </label>
          </div>

          <p class="mt-4 text-sm leading-relaxed text-muted">{c.defaults}</p>

          <div class="tool-action-dock mt-7">
            <button id="notice-calculate" type="submit" class="btn btn-primary">{c.calculate}</button>
            <div class="tool-action-dock__row">
              <button id="copy-notice-timeline" type="button" class="btn btn-ghost">{c.copyTimeline}</button>
              <button id="export-notice-report" type="button" class="btn btn-ghost">{c.exportPdf}</button>
            </div>
          </div>
        </form>
      </div>

      <div class="lg:col-span-7">
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            ['today', c.today],
            ['notice', c.noticeDeadline],
            ['particulars', c.particularsDeadline],
            ['reminder7', c.reminder7],
            ['reminder3', c.reminder3],
            ['status', c.result],
            ['risk', c.risk],
          ].map((item) => (
            <div class="notice-result-card card p-5">
              <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{item[1]}</p>
              <p id={`nd-${item[0]}`} class="mt-3 min-h-[2rem] font-display text-2xl font-700 text-fg">-</p>
            </div>
          ))}
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="card p-5">
            <p class="font-mono text-[11px] uppercase tracking-widest text-brass">{c.readTitle}</p>
            <div class="mt-4 space-y-2">
              {c.links.map((r) => (
                <a class="link-underline block text-sm text-fg-dim hover:text-brass" href={localizePath(r[1], lang)}>{r[0]}</a>
              ))}
            </div>
          </div>
          <div class="card p-5">
            <p class="font-mono text-[11px] uppercase tracking-widest text-brass">Bridge Consult</p>
            <p class="mt-3 text-sm leading-relaxed text-fg-dim">{c.warningText}</p>
            <div class="mt-5 flex flex-col gap-3">
              <a href={readinessHref} class="btn btn-ghost justify-center">{c.cta}</a>
              <a href={contactHref} class="btn btn-primary justify-center">{c.consult}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .notice-form input:not([type="radio"]) {
      min-height: 3.9rem;
      font-variant-numeric: tabular-nums;
    }

    .notice-scenario-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.5rem;
    }

    .notice-scenario-grid label {
      display: block;
      min-width: 0;
    }

    .notice-scenario-grid input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .notice-scenario-grid span {
      display: flex;
      min-height: 2.75rem;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--color-line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.025);
      color: var(--color-fg-dim);
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
      transition: border-color 0.2s var(--ease-out-expo), background 0.2s var(--ease-out-expo), color 0.2s var(--ease-out-expo);
    }

    .notice-scenario-grid input:checked + span {
      border-color: color-mix(in oklab, var(--color-brass) 70%, var(--color-line));
      background: color-mix(in oklab, var(--color-brass) 18%, transparent);
      color: var(--color-fg);
    }

    .notice-form[data-notice-state="ready"] {
      border-color: color-mix(in oklab, var(--color-brass) 58%, var(--color-line));
      box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-brass) 18%, transparent);
    }

    .notice-result-card {
      min-height: 9rem;
      transition: border-color 0.2s var(--ease-out-expo), background 0.2s var(--ease-out-expo);
    }

    .notice-result-card[data-ready="true"] {
      border-color: color-mix(in oklab, var(--color-brass) 38%, var(--color-line));
      background:
        radial-gradient(circle at 90% 12%, rgba(201, 164, 92, 0.10), transparent 11rem),
        rgba(8, 11, 17, 0.78);
    }

    .notice-result-card[data-risk="low"] {
      border-color: color-mix(in oklab, #4ade80 36%, var(--color-line));
    }

    .notice-result-card[data-risk="medium"] {
      border-color: color-mix(in oklab, var(--color-brass) 62%, var(--color-line));
    }

    .notice-result-card[data-risk="high"] {
      border-color: color-mix(in oklab, #fb7185 56%, var(--color-line));
      background:
        radial-gradient(circle at 92% 10%, rgba(251, 113, 133, 0.12), transparent 12rem),
        rgba(8, 11, 17, 0.78);
    }

    .notice-result-card p[id] {
      overflow-wrap: anywhere;
      line-height: 1.15;
    }

    @media (min-width: 640px) {
      .notice-field > span:first-child {
        display: flex;
        min-height: 2.7rem;
        align-items: flex-end;
      }
    }

    @media (max-width: 639px) {
      .notice-form {
        padding: 1.1rem;
      }

      .notice-form__grid {
        grid-template-columns: 1fr;
      }

      .notice-scenario-grid {
        grid-template-columns: 1fr;
      }

      .notice-result-card {
        min-height: 7.5rem;
      }
    }
  </style>

  <script is:inline define:vars={{ c, pagePath }}>
    (function () {
      var form = document.getElementById('notice-calculator');
      if (!form) return;

      var awareness = document.getElementById('awareness-date');
      var projectName = document.getElementById('notice-project-name');
      var noticeDays = document.getElementById('notice-days');
      var particularsDays = document.getElementById('particulars-days');
      var scenarios = Array.prototype.slice.call(form.querySelectorAll('input[name="notice-scenario"]'));
      var copyBtn = document.getElementById('copy-notice-timeline');
      var exportBtn = document.getElementById('export-notice-report');
      var out = {
        today: document.getElementById('nd-today'),
        notice: document.getElementById('nd-notice'),
        particulars: document.getElementById('nd-particulars'),
        reminder7: document.getElementById('nd-reminder7'),
        reminder3: document.getElementById('nd-reminder3'),
        status: document.getElementById('nd-status'),
        risk: document.getElementById('nd-risk'),
      };

      function parseLocalDate(value) {
        if (!value) return null;
        var parts = value.split('-').map(Number);
        return new Date(parts[0], parts[1] - 1, parts[2]);
      }

      function addDays(date, days) {
        var d = new Date(date.getFullYear(), date.getMonth(), date.getDate());
        d.setDate(d.getDate() + Number(days || 0));
        return d;
      }

      function startOfToday() {
        var d = new Date();
        return new Date(d.getFullYear(), d.getMonth(), d.getDate());
      }

      function diffDays(a, b) {
        return Math.round((a.getTime() - b.getTime()) / 86400000);
      }

      function fmt(date) {
        if (!date) return '-';
        return new Intl.DateTimeFormat(document.documentElement.lang || 'ru', { day: '2-digit', month: 'long', year: 'numeric' }).format(date);
      }

      function normalizeDays(input, fallback, max) {
        var value = parseInt(input.value, 10);
        if (!Number.isFinite(value)) value = fallback;
        value = Math.max(1, Math.min(max, value));
        input.value = String(value);
        return value;
      }

      function getScenario() {
        var selected = scenarios.find(function (input) { return input.checked; });
        return selected ? selected.value : '2017';
      }

      function setScenario(value) {
        scenarios.forEach(function (input) {
          input.checked = input.value === value;
        });
      }

      function scenarioLabel(value) {
        if (value === '1999') return c.scenario1999;
        if (value === '2017') return c.scenario2017;
        return c.scenarioCustom;
      }

      function setRiskCards(level) {
        Object.keys(out).forEach(function (key) {
          var card = out[key] && out[key].closest('.notice-result-card');
          if (!card) return;
          card.dataset.ready = level ? 'true' : 'false';
          delete card.dataset.risk;
        });
        var riskCard = out.risk && out.risk.closest('.notice-result-card');
        var statusCard = out.status && out.status.closest('.notice-result-card');
        if (riskCard && level) riskCard.dataset.risk = level;
        if (statusCard && level) statusCard.dataset.risk = level;
      }

      function resetResults() {
        form.dataset.noticeState = 'idle';
        out.today.textContent = fmt(startOfToday());
        out.notice.textContent = '-';
        out.particulars.textContent = '-';
        out.reminder7.textContent = '-';
        out.reminder3.textContent = '-';
        out.status.textContent = c.statusNoDate;
        out.risk.textContent = '-';
        setRiskCards(null);
      }

      function calculate() {
        var eventDate = parseLocalDate(awareness.value);
        var today = startOfToday();
        out.today.textContent = fmt(today);

        if (!eventDate) {
          out.notice.textContent = '-';
          out.particulars.textContent = '-';
          out.reminder7.textContent = '-';
          out.reminder3.textContent = '-';
          out.status.textContent = c.statusNoDate;
          out.risk.textContent = '-';
          setRiskCards(null);
          return null;
        }

        var ndays = normalizeDays(noticeDays, 28, 365);
        var pdays = normalizeDays(particularsDays, 84, 730);
        var nd = addDays(eventDate, ndays);
        var pd = addDays(eventDate, pdays);
        var r7 = addDays(nd, -7);
        var r3 = addDays(nd, -3);
        var delta = diffDays(nd, today);

        out.notice.textContent = fmt(nd);
        out.particulars.textContent = fmt(pd);
        out.reminder7.textContent = fmt(r7);
        out.reminder3.textContent = fmt(r3);
        var riskLevel = 'low';
        var riskText = c.riskLow;
        if (delta > 0) out.status.textContent = c.statusOk + ' · ' + delta + ' ' + c.daysLeft;
        else if (delta === 0) {
          out.status.textContent = c.statusToday;
          riskLevel = 'medium';
          riskText = c.riskToday;
        } else {
          out.status.textContent = c.statusLate + ' · ' + Math.abs(delta) + ' ' + c.daysLate;
          riskLevel = 'high';
          riskText = c.riskHigh;
        }
        out.risk.textContent = riskText;
        form.dataset.noticeState = 'ready';
        setRiskCards(riskLevel);

        return {
          projectName: (projectName && projectName.value.trim()) || '-',
          scenario: scenarioLabel(getScenario()),
          noticeDays: ndays,
          particularsDays: pdays,
          eventDate: eventDate,
          notice: nd,
          particulars: pd,
          reminder7: r7,
          reminder3: r3,
          status: out.status.textContent,
          risk: riskText,
          riskLevel: riskLevel
        };
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        calculate();
      });
      scenarios.forEach(function (input) {
        input.addEventListener('change', function () {
          if (input.checked && input.value !== 'custom') {
            noticeDays.value = '28';
            particularsDays.value = '84';
          }
          resetResults();
        });
      });
      [noticeDays, particularsDays].forEach(function (el) {
        el.addEventListener('input', function () {
          setScenario('custom');
          resetResults();
        });
      });
      [awareness, projectName].forEach(function (el) {
        if (el) el.addEventListener('input', resetResults);
      });
      resetResults();

      if (copyBtn) {
        copyBtn.addEventListener('click', async function () {
          var result = calculate();
          if (!result) return;
          var lines = [
            c.title,
            location.origin + pagePath,
            c.projectName + ': ' + result.projectName,
            c.scenario + ': ' + result.scenario,
            c.awareness + ': ' + fmt(result.eventDate),
            c.noticeDays + ': ' + result.noticeDays,
            c.particularsDays + ': ' + result.particularsDays,
            c.noticeDeadline + ': ' + fmt(result.notice),
            c.particularsDeadline + ': ' + fmt(result.particulars),
            c.reminder7 + ': ' + fmt(result.reminder7),
            c.reminder3 + ': ' + fmt(result.reminder3),
            c.result + ': ' + result.status,
            c.risk + ': ' + result.risk,
          ];
          try {
            await navigator.clipboard.writeText(lines.join('\n'));
            var old = copyBtn.textContent;
            copyBtn.textContent = c.copied;
            setTimeout(function () { copyBtn.textContent = old; }, 1400);
          } catch (e) {
            window.prompt(c.copyTimeline, lines.join('\n'));
          }
        });
      }

      if (exportBtn) {
        exportBtn.addEventListener('click', function () {
          var result = calculate();
          if (!result || typeof window.FidicReportExport !== 'function') return;
          window.FidicReportExport({
            title: c.title,
            subtitle: location.origin + pagePath,
            sourceUrl: location.origin + pagePath,
            projectName: result.projectName,
            preparedBy: 'Bridge Consult / FIDIC.uz',
            status: result.status,
            summary: c.noticeDeadline + ': ' + fmt(result.notice) + ' · ' + c.particularsDeadline + ': ' + fmt(result.particulars) + ' · ' + c.risk + ': ' + result.risk,
            assumptions: [
              c.reportAssumption1,
              c.reportAssumption2,
              c.scenario + ': ' + result.scenario,
              c.noticeDays + ': ' + result.noticeDays,
              c.particularsDays + ': ' + result.particularsDays
            ],
            limitationNote: c.warningText,
            nextActions: [
              c.warningText,
              c.cta,
              c.consult
            ],
            sections: [
              {
                heading: c.result || c.noticeDeadline,
                rows: [
                  [c.projectName, result.projectName],
                  [c.scenario, result.scenario],
                  [c.awareness, fmt(result.eventDate)],
                  [c.noticeDays, result.noticeDays],
                  [c.particularsDays, result.particularsDays],
                  [c.noticeDeadline, fmt(result.notice)],
                  [c.particularsDeadline, fmt(result.particulars)],
                  [c.reminder7, fmt(result.reminder7)],
                  [c.reminder3, fmt(result.reminder3)],
                  [c.status || 'Status', result.status],
                  [c.risk, result.risk],
                ],
              },
              { heading: c.warningTitle, text: c.warningText },
            ],
          });
        });
      }
    })();
  </script>
</Layout>
