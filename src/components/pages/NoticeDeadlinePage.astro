    noticeDays: 'Notice muddati, kun',
    particularsDays: 'Detailed particulars muddati, kun',
    defaults: 'FIDIC 2017 uchun odatiy qiymatlar: notice - 28 kun, fully detailed claim - 84 kun. Shartnomangizni tekshiring.',
    calculate: 'Hisoblash',
    today: 'Bugun',
    noticeDeadline: 'Notice deadline',
    particularsDeadline: 'Detailed claim deadline',
    reminder7: '7 kun oldin eslatma',
    reminder3: '3 kun oldin eslatma',
    statusOk: 'Notice muddati hali o‘tmagan',
