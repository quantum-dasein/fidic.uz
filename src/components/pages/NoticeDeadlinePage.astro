    statusNoDate: 'Выберите дату события',
    result: 'Статус расчёта',
    risk: 'Риск',
    riskLow: 'Срок notice ещё контролируется',
    riskToday: 'Дедлайн сегодня',
    riskHigh: 'Возможный time-bar риск',
    reportAssumptions: 'Assumptions',
    reportAssumption1: 'Расчёт использует календарные дни от даты осведомлённости о событии.',
    reportAssumption2: 'Сценарий не заменяет проверку Particular Conditions и процедуры service of notices.',
    reportLimitation: 'Limitation note',
    daysLeft: 'дн. осталось',
    daysLate: 'дн. просрочки',
    copyTimeline: 'Скопировать timeline',
    exportPdf: 'Export PDF report',
    copied: 'Скопировано',
