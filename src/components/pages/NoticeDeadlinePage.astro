    readTitle: 'Полезные материалы',
    links: [
      ['Правило 28 дней', '/knowledge/claims-28-days'],
      ['Обоснование claims', '/knowledge/claims-substantiation-records'],
      ['EOT и delay analysis', '/knowledge/eot-delay-analysis'],
    ],
  },
  en: {
    title: 'Notice Deadline Calculator',
    h1: 'FIDIC notice deadline calculator',
    sub: 'A quick calendar helper for claims: awareness date, notice deadline, detailed particulars deadline and reminder dates. It does not replace contract review; Particular Conditions may change the procedure.',
    meta: 'FIDIC notice deadline calculator for 28-day notices, detailed particulars, reminder dates and claim time-bar risk.',
    badge: 'Claims tool',
    awareness: 'Date when the party became, or should have become, aware of the event',
    awarenessHint: 'The period normally runs from awareness of the event or circumstance, not from the date when the claim is drafted.',
