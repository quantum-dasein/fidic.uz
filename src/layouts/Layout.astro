---
import '../styles/global.css';
import { site, comingSoon } from '../data/site';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LeadCapturePanel from '../components/LeadCapturePanel.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { type Lang, defaultLang, locales, stripLocale, localizePath, ensureTrailingSlash } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  keywords?: string;
  published?: string;
  lang?: Lang;
  langUrls?: Partial<Record<Lang, string>>;
  noHeaderOffset?: boolean;
  /** Render normally even when the site is in coming-soon mode (e.g. /verify). */
  alwaysOpen?: boolean;
  /** Force noindex regardless of coming-soon (pages with personal data). */
  forceNoindex?: boolean;
  /** Standalone page: no marketing header/footer/chrome, just the slot. */
  bare?: boolean;
}

const keywordsByLang: Record<Lang, string> = {
  ru: 'FIDIC, контракты FIDIC, FIDIC Узбекистан, Red Book, Yellow Book, Silver Book, Pink Book, EPC контракты, claims FIDIC, DAAB, разрешение споров, инфраструктурные контракты, проекты МФО, Всемирный банк, АБР, ЕБРР, строительный арбитраж, Bridge Consult, FCCE, FCCP',
  en: 'FIDIC, FIDIC contracts, FIDIC Uzbekistan, Red Book, Yellow Book, Silver Book, Pink Book, EPC contracts, FIDIC claims, DAAB, dispute resolution, infrastructure contracts, MDB projects, World Bank, ADB, EBRD, construction arbitration, Bridge Consult, FCCE, FCCP',
  uz: 'FIDIC, FIDIC shartnomalari, FIDIC Oʻzbekiston, Red Book, Yellow Book, Silver Book, Pink Book, EPC shartnomalar, FIDIC claims, DAAB, nizolarni hal qilish, infratuzilma shartnomalari, XTB loyihalari, Jahon banki, ADB, EBRD, qurilish arbitraji, Bridge Consult, FCCE, FCCP',
};
const ogLocaleByLang: Record<Lang, string> = { ru: 'ru_RU', en: 'en_US', uz: 'uz_UZ' };

const {
  title,
  description = site.description,
  image,
  type = 'website',
  lang = defaultLang,
  langUrls,
  keywords = keywordsByLang[lang],
  published,
  noHeaderOffset = false,
  alwaysOpen = false,
  forceNoindex = false,
  bare = false,
} = Astro.props;

// Gate the page behind the coming-soon screen unless it opts out (alwaysOpen).
const gated = comingSoon && !alwaysOpen;
const noindex = gated || forceNoindex;

const resolvedTitle = gated
  ? `${site.name} — СКОРО / Coming soon`
  : (title ?? `${site.name} — ${site.taglineRu}`);
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const pageOrigin = new URL(pageUrl).origin;
// Per-page Open Graph image: use an explicit image if given, otherwise the
// dynamic branded generator at /api/og (PNG for social cards).
const ogTitle = resolvedTitle.replace(/\s*[—|]\s*FIDIC\.uz.*$/i, '').trim() || site.name;
const ogTagByType: Record<string, string> = {
  article: 'Knowledge Hub',
  website: 'Infrastructure Contracts Knowledge Hub',
};
const ogTag = ogTagByType[type] ?? 'FIDIC.uz';
const ogImage = image
  ? (image.startsWith('http') ? image : new URL(image, pageUrl).toString())
  : `${pageOrigin}/api/og?title=${encodeURIComponent(ogTitle)}&tag=${encodeURIComponent(ogTag)}`;
const ogImageAlt = `${site.name}: ${ogTitle}`;
const ogImageType = image ? undefined : 'image/svg+xml';

// hreflang alternates for the same logical page across all languages.
const { gscVerification, gaId } = site.analytics;
const canonical = stripLocale(Astro.url.pathname);
const origin = (Astro.site ?? new URL(Astro.url.origin)).origin;
const altLinks = locales.map((l) => ({ lang: l, href: origin + ensureTrailingSlash(langUrls?.[l] ?? localizePath(canonical, l)) }));
const xDefault = origin + ensureTrailingSlash(langUrls?.ru ?? localizePath(canonical, 'ru'));
const alternateOgLocales = locales.filter((l) => l !== lang).map((l) => ogLocaleByLang[l]);
const pageSchemaId = `${pageUrl}#webpage`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <title>{resolvedTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={site.poweredBy} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <Fragment>
        <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
      </Fragment>
    )}
    <meta name="theme-color" content="#0a0c11" />
    <meta name="color-scheme" content="dark" />
    <meta name="geo.region" content="UZ" />
    <meta name="geo.placename" content="Tashkent" />
    <link rel="canonical" href={pageUrl} />
    {altLinks.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={ogLocaleByLang[lang]} />
    {alternateOgLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
    {published && <meta property="article:published_time" content={published} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebSite',
          '@id': `${site.url}/#website`,
          name: site.name,
          url: site.url,
          description: site.description,
          inLanguage: lang,
          publisher: { '@id': `${site.url}/#organization` },
          potentialAction: {
            '@type': 'SearchAction',
            target: `${site.url}${localizePath('/knowledge', lang)}?q={search_term_string}`,
            'query-input': 'required name=search_term_string',
          },
        },
        {
          '@type': 'WebPage',
          '@id': pageSchemaId,
          url: pageUrl,
          name: resolvedTitle,
          description,
          inLanguage: lang,
          isPartOf: { '@id': `${site.url}/#website` },
          publisher: { '@id': `${site.url}/#organization` },
          primaryImageOfPage: { '@type': 'ImageObject', url: ogImage },
          about: [
            { '@type': 'Thing', name: 'FIDIC contracts' },
            { '@type': 'Thing', name: 'Infrastructure contracts' },
            { '@type': 'Thing', name: 'Construction claims' },
            { '@type': 'Thing', name: 'MDB procurement' },
          ],
        },
        {
          '@type': 'Organization',
          '@id': `${site.url}/#organization`,
          name: site.poweredBy,
          alternateName: 'FIDIC.uz',
          url: site.url,
          logo: `${site.url}/favicon.svg`,
          email: site.contacts.email,
          telephone: site.contacts.phone,
          areaServed: ['Uzbekistan', 'Central Asia'],
          sameAs: [site.poweredByUrl, site.contacts.telegram, site.contacts.linkedin],
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Tashkent',
            addressCountry: 'UZ',
          },
          knowsAbout: ['FIDIC', 'EPC contracts', 'Construction claims', 'DAAB', 'Dispute resolution', 'MDB-financed projects'],
        },
      ],
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {gaId && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`}></script>
      </Fragment>
    )}
    <slot name="head" />
  </head>
  <body class="grain">
    {gated ? (
      <ComingSoon lang={lang} />
    ) : bare ? (
      <slot />
    ) : (
      <Fragment>
        <div id="scroll-progress"></div>
        <div id="cursor-dot" aria-hidden="true"></div>
        <div id="cursor-ring" aria-hidden="true"></div>
        <SiteHeader lang={lang} langUrls={langUrls} />
        <main class={noHeaderOffset ? '' : 'pt-20'}>
          <slot />
        </main>
        <SiteFooter lang={lang} />
        <LeadCapturePanel lang={lang} />
        <script src="/main.js" defer></script>
        <script>
          import '../scripts/app.js';
        </script>
      </Fragment>
    )}
  </body>
</html>
