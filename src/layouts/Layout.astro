---
import '../styles/global.css';
import { site } from '../data/site';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  keywords?: string;
  published?: string;
  noHeaderOffset?: boolean;
}

const defaultKeywords =
  'FIDIC, контракты FIDIC, FIDIC Узбекистан, Red Book, Yellow Book, Silver Book, Pink Book, EPC контракты, claims FIDIC, DAAB, разрешение споров, инфраструктурные контракты, проекты МФО, Всемирный банк, АБР, ЕБРР, строительный арбитраж, Bridge Consult, FCCE, FCCP';

const {
  title = `${site.name} — ${site.taglineRu}`,
  description = site.description,
  image = '/og-image.svg',
  type = 'website',
  keywords = defaultKeywords,
  published,
  noHeaderOffset = false,
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImage = image.startsWith('http') ? image : new URL(image, pageUrl).toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={site.poweredBy} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#0a0c11" />
    <meta name="geo.region" content="UZ" />
    <meta name="geo.placename" content="Tashkent" />
    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" hreflang="ru" href={pageUrl} />
    <link rel="alternate" hreflang="x-default" href={pageUrl} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="ru_RU" />
    {published && <meta property="article:published_time" content={published} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebSite',
          '@id': `${site.url}/#website`,
          name: site.name,
          url: site.url,
          description: site.description,
          inLanguage: 'ru',
          publisher: { '@id': `${site.url}/#organization` },
        },
        {
          '@type': 'Organization',
          '@id': `${site.url}/#organization`,
          name: site.poweredBy,
          alternateName: 'FIDIC.uz',
          url: site.url,
          logo: `${site.url}/favicon.svg`,
          email: site.contacts.email,
          telephone: site.contacts.phone,
          areaServed: ['Uzbekistan', 'Central Asia'],
          sameAs: [site.poweredByUrl, site.contacts.telegram, site.contacts.linkedin],
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Tashkent',
            addressCountry: 'UZ',
          },
          knowsAbout: ['FIDIC', 'EPC contracts', 'Construction claims', 'DAAB', 'Dispute resolution', 'MDB-financed projects'],
        },
      ],
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400&family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class="grain">
    <div id="scroll-progress"></div>
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>
    <SiteHeader />
    <main class={noHeaderOffset ? '' : 'pt-20'}>
      <slot />
    </main>
    <SiteFooter />
    <script src="/main.js" defer></script>
    <script>
      import '../scripts/app.js';
    </script>
  </body>
</html>
